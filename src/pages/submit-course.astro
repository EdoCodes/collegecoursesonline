---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Submit a Course | College Courses Online"
  description="Submit your online college course to be listed in our directory. Help students discover accredited online courses from your institution."
>
  <main class="submit-page">
    <div class="hero-banner">
      <div class="container">
        <div class="hero-content">
          <span class="hero-badge">For Institutions & Educators</span>
          <h1>Submit a Course</h1>
          <p>Add your online college course to our directory and reach thousands of students searching for accredited online education.</p>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="page-grid">

        <!-- Form -->
        <section class="form-section">
          <div class="form-card">
            <h2>Course Details</h2>
            <p class="form-intro">Fill out the form below and our team will review your submission within 2–3 business days.</p>

            <form class="submit-form" id="submitForm">

              <div class="form-group">
                <label for="courseTitle">Course Title <span class="required">*</span></label>
                <input type="text" id="courseTitle" name="courseTitle" placeholder="e.g. Introduction to Computer Science" required />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="collegeName">College / Institution <span class="required">*</span></label>
                  <input type="text" id="collegeName" name="collegeName" placeholder="e.g. MIT OpenCourseWare" required />
                </div>
                <div class="form-group">
                  <label for="collegeWebsite">Institution Website <span class="required">*</span></label>
                  <input type="url" id="collegeWebsite" name="collegeWebsite" placeholder="https://yourschool.edu" required />
                </div>
              </div>

              <div class="form-group">
                <label for="courseUrl">Course URL <span class="required">*</span></label>
                <input type="url" id="courseUrl" name="courseUrl" placeholder="https://yourschool.edu/courses/intro-cs" required />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="category">Subject Category <span class="required">*</span></label>
                  <select id="category" name="category" required>
                    <option value="">Select a category</option>
                    <option value="computer-science">Computer Science</option>
                    <option value="business">Business & Management</option>
                    <option value="data-science">Data Science</option>
                    <option value="engineering">Engineering</option>
                    <option value="arts-humanities">Arts & Humanities</option>
                    <option value="health">Health & Medicine</option>
                    <option value="social-sciences">Social Sciences</option>
                    <option value="mathematics">Mathematics</option>
                    <option value="education">Education</option>
                    <option value="language">Language & Linguistics</option>
                    <option value="certificate-programs">Certificate Programs</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="level">Course Level <span class="required">*</span></label>
                  <select id="level" name="level" required>
                    <option value="">Select level</option>
                    <option value="Beginner">Beginner</option>
                    <option value="Intermediate">Intermediate</option>
                    <option value="Advanced">Advanced</option>
                    <option value="All Levels">All Levels</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="price">Price</label>
                  <select id="price" name="price">
                    <option value="Free">Free</option>
                    <option value="Paid">Paid (specify below)</option>
                    <option value="Audit Available">Free to Audit</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="duration">Duration</label>
                  <input type="text" id="duration" name="duration" placeholder="e.g. 8 weeks, Self-paced" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="accreditation">Accreditation Type</label>
                  <select id="accreditation" name="accreditation">
                    <option value="Regional">Regional</option>
                    <option value="National">National</option>
                    <option value="International">International</option>
                    <option value="None">None / Not Applicable</option>
                  </select>
                </div>
                <div class="form-group certificate-group">
                  <label>Transcript available upon completion?</label>
                  <div class="radio-group">
                    <label class="radio-label">
                      <input type="radio" name="certificate" value="yes" /> Yes
                    </label>
                    <label class="radio-label">
                      <input type="radio" name="certificate" value="no" checked /> No
                    </label>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label for="shortDescription">Short Description <span class="required">*</span></label>
                <input type="text" id="shortDescription" name="shortDescription" placeholder="One-line summary shown on course cards (max 120 characters)" maxlength="120" required />
                <span class="char-count" id="charCount">0 / 120</span>
              </div>

              <div class="form-group">
                <label for="description">Full Description <span class="required">*</span></label>
                <textarea id="description" name="description" rows="5" placeholder="Describe what students will learn, prerequisites, and what makes this course unique..." required></textarea>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="contactName">Your Name <span class="required">*</span></label>
                  <input type="text" id="contactName" name="contactName" placeholder="Full name" required />
                </div>
                <div class="form-group">
                  <label for="contactEmail">Your Email <span class="required">*</span></label>
                  <input type="email" id="contactEmail" name="contactEmail" placeholder="you@institution.edu" required />
                </div>
              </div>

              <div class="form-group">
                <label class="checkbox-label">
                  <input type="checkbox" name="agree" required />
                  I confirm this is an accredited or legitimate educational course and I have the authority to submit it.
                </label>
              </div>

              <button type="submit" class="submit-btn" id="submitBtn">
                <span class="btn-text">Submit Course for Review</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="success-message" id="successMessage" style="display: none;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" fill="#10b981"/>
                  <path d="M8 12L10.5 14.5L16 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div>
                  <strong>Submission received!</strong>
                  <p>We'll review your course and get back to you within 2–3 business days.</p>
                </div>
              </div>

            </form>
          </div>
        </section>

        <!-- Sidebar info -->
        <aside class="sidebar">
          <div class="info-card">
            <h3>What happens next?</h3>
            <ol class="steps-list">
              <li>
                <span class="step-num">1</span>
                <div>
                  <strong>Review</strong>
                  <p>Our team reviews your submission for accuracy and quality within 2–3 business days.</p>
                </div>
              </li>
              <li>
                <span class="step-num">2</span>
                <div>
                  <strong>Approval</strong>
                  <p>You'll receive an email confirming whether your course was approved or if we need more information.</p>
                </div>
              </li>
              <li>
                <span class="step-num">3</span>
                <div>
                  <strong>Listed</strong>
                  <p>Approved courses go live in our directory, visible to thousands of students searching for online education.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="info-card">
            <h3>Listing Requirements</h3>
            <ul class="requirements-list">
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Offered by an accredited college or recognized institution
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Accessible fully or partially online
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Active and enrolling students
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Accurate and up-to-date course information
              </li>
            </ul>
          </div>

          <div class="info-card highlight-card">
            <h3>Questions?</h3>
            <p>Reach out to us at <a href="mailto:listings@collegecoursesonline.com">listings@collegecoursesonline.com</a> and we'll help you get your course listed.</p>
          </div>
        </aside>

      </div>
    </div>
  </main>
</Layout>

<style>
  .submit-page {
    min-height: 80vh;
    padding-bottom: calc(var(--spacing) * 10);
  }

  .hero-banner {
    background: linear-gradient(135deg, #1e40af 0%, #0ea5e9 100%);
    padding: calc(var(--spacing) * 8) 0 calc(var(--spacing) * 7);
    margin-bottom: calc(var(--spacing) * 8);
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: calc(var(--spacing) * 0.75) calc(var(--spacing) * 2);
    border-radius: 100px;
    margin-bottom: calc(var(--spacing) * 2);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .hero-banner h1 {
    color: white;
    font-size: 2.75rem;
    margin-bottom: calc(var(--spacing) * 2);
  }

  .hero-banner p {
    color: rgba(255,255,255,0.85);
    font-size: 1.125rem;
    line-height: 1.7;
    margin: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 calc(var(--spacing) * 3);
  }

  .page-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: calc(var(--spacing) * 5);
    align-items: start;
  }

  /* Form Card */
  .form-card {
    background: white;
    border-radius: 16px;
    padding: calc(var(--spacing) * 5);
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    border: 1px solid var(--neutral-100);
  }

  .form-card h2 {
    font-size: 1.75rem;
    margin-bottom: calc(var(--spacing) * 1);
  }

  .form-intro {
    color: var(--neutral-500);
    margin-bottom: calc(var(--spacing) * 4);
    font-size: 0.9375rem;
  }

  .submit-form {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(var(--spacing) * 3);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 1);
    position: relative;
  }

  .form-group label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--neutral-700);
  }

  .required {
    color: #ef4444;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: calc(var(--spacing) * 1.75) calc(var(--spacing) * 2);
    border: 2px solid var(--neutral-200);
    border-radius: 10px;
    font-size: 1rem;
    font-family: var(--font-primary);
    color: var(--neutral-800);
    background: white;
    transition: var(--transition);
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .char-count {
    font-size: 0.8125rem;
    color: var(--neutral-400);
    text-align: right;
    margin-top: -4px;
  }

  .radio-group {
    display: flex;
    gap: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 1.75) calc(var(--spacing) * 2);
    border: 2px solid var(--neutral-200);
    border-radius: 10px;
    background: white;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 1);
    cursor: pointer;
    font-weight: 400;
    color: var(--neutral-700);
    font-size: 1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: calc(var(--spacing) * 1.5);
    cursor: pointer;
    font-size: 0.9375rem;
    color: var(--neutral-600);
    line-height: 1.5;
    font-weight: 400;
  }

  .checkbox-label input {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    flex-shrink: 0;
    accent-color: var(--color-primary);
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: calc(var(--spacing) * 1.5);
    padding: calc(var(--spacing) * 2.5) calc(var(--spacing) * 4);
    background: linear-gradient(135deg, #1e40af 0%, #0ea5e9 100%);
    color: white;
    font-size: 1.0625rem;
    font-weight: 700;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: 0 4px 16px rgba(30, 64, 175, 0.25);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(30, 64, 175, 0.35);
  }

  .success-message {
    display: flex;
    align-items: flex-start;
    gap: calc(var(--spacing) * 2);
    padding: calc(var(--spacing) * 3);
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
  }

  .success-message strong {
    display: block;
    color: #15803d;
    margin-bottom: 4px;
  }

  .success-message p {
    color: #166534;
    font-size: 0.9375rem;
    margin: 0;
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    position: sticky;
    top: 90px;
  }

  .info-card {
    background: white;
    border-radius: 16px;
    padding: calc(var(--spacing) * 4);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 1px solid var(--neutral-100);
  }

  .info-card h3 {
    font-size: 1.125rem;
    margin-bottom: calc(var(--spacing) * 3);
    color: var(--neutral-900);
  }

  .highlight-card {
    background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
    border-color: #bfdbfe;
  }

  .highlight-card h3 {
    color: var(--color-primary);
  }

  .highlight-card p {
    color: var(--neutral-600);
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .steps-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
  }

  .steps-list li {
    display: flex;
    gap: calc(var(--spacing) * 2);
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .steps-list strong {
    display: block;
    color: var(--neutral-800);
    margin-bottom: 4px;
    font-size: 0.9375rem;
  }

  .steps-list p {
    color: var(--neutral-500);
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }

  .requirements-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);
  }

  .requirements-list li {
    display: flex;
    align-items: flex-start;
    gap: calc(var(--spacing) * 1.5);
    font-size: 0.9375rem;
    color: var(--neutral-600);
    line-height: 1.5;
  }

  .requirements-list svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .page-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .hero-banner h1 {
      font-size: 2rem;
    }
  }
</style>

<script>
  const shortDesc = document.getElementById('shortDescription') as HTMLInputElement;
  const charCount = document.getElementById('charCount');

  shortDesc?.addEventListener('input', () => {
    const len = shortDesc.value.length;
    if (charCount) {
      charCount.textContent = `${len} / 120`;
      charCount.style.color = len > 100 ? '#f59e0b' : 'var(--neutral-400)';
    }
  });

  const form = document.getElementById('submitForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const successMessage = document.getElementById('successMessage');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.querySelector('.btn-text')!.textContent = 'Submitting...';

    setTimeout(() => {
      form.style.display = 'none';
      if (successMessage) successMessage.style.display = 'flex';
    }, 800);
  });
</script>
