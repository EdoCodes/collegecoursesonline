---
import Layout from '../../../layouts/Layout.astro';

const { id } = Astro.params;

export function getStaticPaths() {
  return [];
}
---

<Layout
  title="Forum | College Courses Online"
  description="Community Q&A thread on College Courses Online."
>
  <div class="redirect-wrap">
    <div class="redirect-card">
      <h1>Opening thread…</h1>
      <p>If you are not redirected automatically, use the link below.</p>
      <a id="fallbackLink" href={`/forum/post/?id=${id ?? ''}`}>Open thread</a>
    </div>
  </div>
</Layout>

<script define:vars={{ id }}>
  const fallbackId = id || window.location.pathname.split('/').filter(Boolean).pop();
  if (fallbackId) {
    window.location.replace(`/forum/post/?id=${encodeURIComponent(fallbackId)}`);
  }
</script>

<style>
  .redirect-wrap {
    min-height: 50vh;
    display: grid;
    place-items: center;
    background: #f1f5f9;
    padding: 2rem;
  }
  .redirect-card {
    width: min(560px, 100%);
    background: #fff;
    border: 1px solid #dbe5f2;
    border-left: 3px solid #2563eb;
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1rem;
  }
  .redirect-card h1 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    color: #0f172a;
  }
  .redirect-card p {
    margin: 0 0 0.75rem;
    color: #475569;
    font-size: 0.95rem;
  }
  .redirect-card a {
    color: #1d4ed8;
    font-weight: 700;
    text-decoration: none;
  }
</style>
