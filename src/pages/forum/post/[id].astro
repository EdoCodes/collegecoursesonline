---
import Layout from '../../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { id } = Astro.params;

const { data: post } = await supabase
  .from('posts')
  .select('*')
  .eq('id', id)
  .eq('is_approved', true)
  .single();

if (!post) return Astro.redirect('/forum', 302);

const { data: replies } = await supabase
  .from('replies')
  .select('*')
  .eq('post_id', id)
  .eq('is_approved', true)
  .order('is_staff_reply', { ascending: false })
  .order('created_at', { ascending: true });

const { data: topic } = await supabase
  .from('topics')
  .select('name, slug, icon')
  .eq('slug', post.topic_slug)
  .single();

export const prerender = false;
---

<Layout
  title={`${post.title} | Forum | College Courses Online`}
  description={`${post.title} — Community discussion on College Courses Online.`}
>
  <div class="post-page">
    <div class="post-hero">
      <div class="post-hero__inner">
        <div class="post-hero__breadcrumb">
          <a href="/forum">Forum</a>
          <span>›</span>
          <a href={`/forum/${topic?.slug}`}>{topic?.icon} {topic?.name}</a>
        </div>
        <h1 class="post-hero__title">{post.title}</h1>
        <div class="post-hero__meta">
          Asked by <strong>{post.author_name}</strong> · {new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </div>
      </div>
    </div>

    <div class="post-body">
      <div class="post-main">
        <!-- Original question -->
        <div class="question-card">
          <div class="question-card__body">{post.body}</div>
        </div>

        <!-- Replies -->
        {replies && replies.length > 0 && (
          <div class="replies-section">
            <h2 class="replies-section__title">{replies.length} {replies.length === 1 ? 'Reply' : 'Replies'}</h2>
            <div class="replies-list">
              {replies.map((reply) => (
                <div class={`reply-card ${reply.is_staff_reply ? 'reply-card--staff' : ''}`}>
                  {reply.is_staff_reply && (
                    <div class="reply-card__staff-badge">✅ Staff Answer</div>
                  )}
                  <div class="reply-card__body">{reply.body}</div>
                  <div class="reply-card__meta">
                    <strong>{reply.author_name}</strong>
                    <span>·</span>
                    <span>{new Date(reply.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Reply form -->
        <div class="reply-section" id="reply">
          <h2 class="reply-section__title">Add a reply</h2>
          <p class="reply-section__sub">Help a fellow student — share what you know. No account needed.</p>

          <form class="reply-form" id="replyForm">
            <input type="hidden" name="post_id" value={post.id} />
            <div class="reply-form__field">
              <label class="reply-form__label" for="reply-body">Your reply</label>
              <textarea class="reply-form__textarea" id="reply-body" name="body" rows="5" placeholder="Share your experience or answer..." required></textarea>
            </div>
            <div class="reply-form__row">
              <div class="reply-form__field">
                <label class="reply-form__label" for="reply-name">Your name</label>
                <input class="reply-form__input" type="text" id="reply-name" name="author_name" placeholder="First name is fine" required />
              </div>
              <div class="reply-form__field">
                <label class="reply-form__label" for="reply-email">Your email</label>
                <input class="reply-form__input" type="email" id="reply-email" name="author_email" placeholder="Not shown publicly" required />
              </div>
            </div>
            <button class="reply-form__submit" type="submit">Post reply →</button>
            <p class="reply-form__note">Replies are reviewed before appearing. Usually approved within 24 hours.</p>
          </form>
          <div class="reply-success" id="replySuccess" style="display:none">
            <div class="reply-success__icon">✅</div>
            <strong>Reply submitted!</strong>
            <p>It will appear here after a quick review. Thank you!</p>
          </div>
        </div>
      </div>

      <aside class="post-sidebar">
        <a href={`/forum/${topic?.slug}#ask`} class="sidebar-ask-btn">+ Ask a new question</a>
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Related guides</h3>
          <ul class="sidebar-card__list">
            <li><a href="/resources/blog/prerequisite-courses-for-nursing-school">Nursing prerequisites</a></li>
            <li><a href="/resources/blog/how-to-become-physician-assistant">How to become a PA</a></li>
            <li><a href="/resources/blog/prerequisite-college-courses-by-major">Prereqs by major</a></li>
            <li><a href="/resources/blog/enrollment-decline-college-closures-hybrid-campus">Enrollment trends</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('replyForm') as HTMLFormElement;
  const success = document.getElementById('replySuccess');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Submitting…';

    const data = Object.fromEntries(new FormData(form));

    const res = await fetch('/api/forum-reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      form.style.display = 'none';
      if (success) success.style.display = 'block';
    } else {
      btn.disabled = false;
      btn.textContent = 'Post reply →';
      alert('Something went wrong. Please try again.');
    }
  });
</script>

<style>
  .post-hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    padding: 3rem 1.5rem 2.5rem;
  }
  .post-hero__inner { max-width: 1060px; margin: 0 auto; }
  .post-hero__breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.875rem; color: #93c5fd; margin-bottom: 1rem;
  }
  .post-hero__breadcrumb a { color: #93c5fd; text-decoration: none; }
  .post-hero__breadcrumb a:hover { color: #fff; }
  .post-hero__breadcrumb span { color: #60a5fa; }
  .post-hero__title { font-size: clamp(1.25rem, 3vw, 1.875rem); font-weight: 900; color: #fff; margin: 0 0 0.75rem; }
  .post-hero__meta { font-size: 0.875rem; color: #bfdbfe; }
  .post-body {
    max-width: 1060px; margin: 0 auto; padding: 2rem 1.5rem 4rem;
    display: grid; grid-template-columns: 1fr 240px; gap: 2rem; align-items: start;
  }
  .question-card {
    background: #fff; border: 1px solid #e2e8f0; border-radius: 14px;
    padding: 1.5rem; margin-bottom: 2rem;
    border-left: 4px solid #2563eb;
  }
  .question-card__body { font-size: 1rem; color: #374151; line-height: 1.7; white-space: pre-wrap; }
  .replies-section { margin-bottom: 2.5rem; }
  .replies-section__title { font-size: 1rem; font-weight: 800; color: #0f172a; margin: 0 0 1rem; }
  .replies-list { display: flex; flex-direction: column; gap: 1rem; }
  .reply-card {
    background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.25rem;
  }
  .reply-card--staff {
    border-color: #059669; background: #f0fdf4;
    border-left: 4px solid #059669;
  }
  .reply-card__staff-badge {
    font-size: 0.75rem; font-weight: 700; color: #065f46;
    text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.6rem;
  }
  .reply-card__body { font-size: 0.9375rem; color: #374151; line-height: 1.65; white-space: pre-wrap; margin-bottom: 0.75rem; }
  .reply-card__meta { font-size: 0.8rem; color: #94a3b8; display: flex; gap: 0.35rem; }
  .reply-section { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.75rem; }
  .reply-section__title { font-size: 1.125rem; font-weight: 800; color: #0f172a; margin: 0 0 0.25rem; }
  .reply-section__sub { font-size: 0.875rem; color: #64748b; margin: 0 0 1.5rem; }
  .reply-form__field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .reply-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .reply-form__label { font-size: 0.8125rem; font-weight: 600; color: #374151; }
  .reply-form__input, .reply-form__textarea {
    width: 100%; padding: 0.6rem 0.875rem; border: 1.5px solid #e2e8f0;
    border-radius: 8px; font-size: 0.9rem; color: #0f172a; background: #fff;
    font-family: inherit; box-sizing: border-box; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .reply-form__input:focus, .reply-form__textarea:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
  .reply-form__textarea { resize: vertical; min-height: 120px; }
  .reply-form__submit {
    margin-top: 0.5rem; background: #2563eb; color: #fff; font-weight: 700;
    font-size: 0.9375rem; padding: 0.65rem 1.5rem; border: none; border-radius: 8px;
    cursor: pointer; font-family: inherit; transition: background 0.15s;
  }
  .reply-form__submit:hover { background: #1d4ed8; }
  .reply-form__submit:disabled { background: #93c5fd; cursor: not-allowed; }
  .reply-form__note { font-size: 0.8rem; color: #94a3b8; margin: 0.75rem 0 0; }
  .reply-success { text-align: center; padding: 2rem; }
  .reply-success__icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .reply-success strong { display: block; font-size: 1.125rem; color: #0f172a; margin-bottom: 0.35rem; }
  .reply-success p { color: #64748b; font-size: 0.9rem; margin: 0; }
  .sidebar-ask-btn {
    display: block; text-align: center; background: #2563eb; color: #fff;
    font-weight: 700; font-size: 0.9375rem; padding: 0.75rem 1rem;
    border-radius: 10px; text-decoration: none; margin-bottom: 1rem;
    transition: background 0.15s;
  }
  .sidebar-ask-btn:hover { background: #1d4ed8; }
  .sidebar-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.25rem; }
  .sidebar-card__title { font-size: 0.875rem; font-weight: 800; color: #0f172a; margin: 0 0 0.75rem; }
  .sidebar-card__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-card__list li { font-size: 0.875rem; }
  .sidebar-card__list a { color: #2563eb; text-decoration: none; font-weight: 500; }
  .sidebar-card__list a:hover { text-decoration: underline; }
  @media (max-width: 768px) {
    .post-body { grid-template-columns: 1fr; }
    .reply-form__row { grid-template-columns: 1fr; }
  }
</style>
