---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Forum | College Courses Online"
  description="Community Q&A thread on College Courses Online."
>
  <div class="thread-header">
    <div class="thread-header__inner">
      <div class="thread-header__breadcrumb" id="breadcrumb">
        <a href="/forum">Forum</a>
        <span aria-hidden="true">›</span>
        <a href="/forum" id="topicLink">Loading…</a>
        <span aria-hidden="true">›</span>
        <span>Thread</span>
      </div>
    </div>
  </div>

  <div class="thread-layout">
    <div class="thread-layout__inner">
      <div class="thread-main">
        <div class="op-card" id="questionCard">
          <div class="op-card__skeleton"></div>
        </div>
        <div id="repliesSection"></div>

        <div class="reply-card reply-card--form" id="replySection">
          <h2 class="reply-card__form-title">Add a reply</h2>
          <p class="reply-card__form-sub">Help a fellow student — share what you know. No account needed.</p>
          <form class="reply-form" id="replyForm">
            <input type="hidden" name="post_id" id="postIdInput" value="" />
            <div class="reply-form__field">
              <label class="reply-form__label" for="reply-body">Your reply</label>
              <textarea class="reply-form__textarea" id="reply-body" name="body" rows="5" placeholder="Share your experience or answer…" required></textarea>
            </div>
            <div class="reply-form__row">
              <div class="reply-form__field">
                <label class="reply-form__label" for="reply-name">Your name</label>
                <input class="reply-form__input" type="text" id="reply-name" name="author_name" placeholder="First name is fine" required />
              </div>
              <div class="reply-form__field">
                <label class="reply-form__label" for="reply-email">Email (not shown)</label>
                <input class="reply-form__input" type="email" id="reply-email" name="author_email" placeholder="Not shown publicly" required />
              </div>
            </div>
            <button class="reply-form__submit" type="submit">Post reply →</button>
            <p class="reply-form__note">Replies are reviewed before appearing publicly. Usually within 24 hours.</p>
          </form>
          <div class="reply-success" id="replySuccess" style="display:none">
            <div class="reply-success__icon">✅</div>
            <strong>Reply submitted!</strong>
            <p>It will appear here after a quick review. Thank you!</p>
          </div>
        </div>
      </div>

      <aside class="thread-sidebar">
        <a href="/forum" class="sidebar-btn sidebar-btn--new" id="newQuestionBtn">+ Ask a new question</a>
        <a href="/forum" class="sidebar-btn sidebar-btn--back">← Back to forum</a>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">📖 Related Guides</h3>
          <ul class="sidebar-card__links">
            <li><a href="/resources/blog/prerequisite-courses-for-nursing-school">Nursing prerequisites</a></li>
            <li><a href="/resources/blog/how-to-become-physician-assistant">How to become a PA</a></li>
            <li><a href="/resources/blog/prerequisite-college-courses-by-major">Prereqs by major</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function timeAgo(d) {
    const diff = Math.floor((Date.now() - new Date(d)) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    if (diff < 2592000) return `${Math.floor(diff/86400)}d ago`;
    return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  async function sbFetch(path) {
    const res = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
      headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
    });
    return res.json();
  }

  function avatarInitials(name) {
    return name ? name.trim().charAt(0).toUpperCase() : '?';
  }

  async function init() {
    const postId = new URLSearchParams(window.location.search).get('id');
    if (!postId) {
      document.getElementById('questionCard').innerHTML = '<div class="not-found">Missing thread ID.</div>';
      return;
    }

    const [posts, replies] = await Promise.all([
      sbFetch(`posts?id=eq.${postId}&is_approved=eq.true&select=*`),
      sbFetch(`replies?post_id=eq.${postId}&is_approved=eq.true&order=is_staff_reply.desc,created_at.asc&select=*`)
    ]);

    const post = posts[0];
    if (!post) {
      document.getElementById('questionCard').innerHTML = '<div class="not-found">Question not found or not yet approved.</div>';
      return;
    }

    document.title = `${post.title} | Forum | College Courses Online`;
    document.getElementById('topicLink').textContent = post.topic_slug.replace(/-/g, ' ');
    document.getElementById('topicLink').href = `/forum/${post.topic_slug}`;
    const newQBtn = document.getElementById('newQuestionBtn');
    if (newQBtn) newQBtn.href = `/forum/${post.topic_slug}#ask`;
    document.getElementById('postIdInput').value = post.id;

    document.getElementById('questionCard').innerHTML = `
      <div class="op-card__header">
        <div class="op-avatar op-avatar--blue">${avatarInitials(post.author_name)}</div>
        <div class="op-card__meta">
          <span class="op-card__author">${escHtml(post.author_name)}</span>
          <span class="op-card__badge op-card__badge--op">OP</span>
          <span class="op-card__dot">·</span>
          <span class="op-card__time">${timeAgo(post.created_at)}</span>
        </div>
      </div>
      <h1 class="op-card__title">${escHtml(post.title)}</h1>
      ${post.body && post.body !== '(no details provided)' ? `<div class="op-card__body">${escHtml(post.body)}</div>` : ''}
      <div class="op-card__footer">
        <span class="op-card__reply-count">${replies.length} ${replies.length === 1 ? 'reply' : 'replies'}</span>
      </div>`;

    if (replies.length) {
      document.getElementById('repliesSection').innerHTML = `
        <div class="replies-list">
          ${replies.map((r, i) => `
            <div class="reply-item ${r.is_staff_reply ? 'reply-item--staff' : ''}">
              <div class="reply-item__header">
                <div class="reply-avatar ${r.is_staff_reply ? 'reply-avatar--green' : ''}">${avatarInitials(r.author_name)}</div>
                <div class="reply-item__meta">
                  <span class="reply-item__author">${escHtml(r.author_name)}</span>
                  ${r.is_staff_reply ? '<span class="reply-item__staff-badge">✅ Staff Answer</span>' : ''}
                  <span class="reply-item__dot">·</span>
                  <span class="reply-item__time">${timeAgo(r.created_at)}</span>
                </div>
              </div>
              <div class="reply-item__body">${escHtml(r.body)}</div>
              <div class="reply-item__footer">
                <span class="reply-item__num">#${i + 1}</span>
              </div>
            </div>`).join('')}
        </div>`;
    }
  }

  const form = document.getElementById('replyForm');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true; btn.textContent = 'Submitting…';
    const data = Object.fromEntries(new FormData(form));
    const res = await fetch('/api/forum-reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (res.ok) {
      form.style.display = 'none';
      document.getElementById('replySuccess').style.display = 'block';
    } else {
      btn.disabled = false; btn.textContent = 'Post reply →';
      alert('Something went wrong. Please try again.');
    }
  });

  init();
</script>

<style>
  .thread-header { background: linear-gradient(135deg, #0f2744 0%, #1d4ed8 100%); padding: 0.875rem 0; }
  .thread-header__inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
  .thread-header__breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8375rem; color: #93c5fd; flex-wrap: wrap; }
  .thread-header__breadcrumb a { color: #93c5fd; text-decoration: none; font-weight: 500; }
  .thread-header__breadcrumb a:hover { color: #fff; }
  .thread-header__breadcrumb span { color: #60a5fa; }
  .thread-layout { background: #f1f5f9; min-height: 70vh; padding: 1.75rem 0 4rem; }
  .thread-layout__inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr 240px; gap: 1.5rem; align-items: start; }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .op-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.5rem; margin-bottom: 1.25rem; border-left: 4px solid #2563eb; }
  .op-card__skeleton { height: 120px; border-radius: 8px; background: linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation: shimmer 1.4s infinite; }
  .op-card__header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
  .op-avatar { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; color: #fff; flex-shrink: 0; }
  .op-avatar--blue { background: linear-gradient(135deg, #2563eb, #1d4ed8); }
  .op-card__meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .op-card__author { font-size: 0.9rem; font-weight: 700; color: #0f172a; }
  .op-card__badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; padding: 1px 6px; border-radius: 4px; }
  .op-card__badge--op { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; }
  .op-card__dot { color: #cbd5e1; font-size: 0.75rem; }
  .op-card__time { font-size: 0.8125rem; color: #94a3b8; }
  .op-card__title { font-size: 1.25rem; font-weight: 800; color: #0f172a; margin: 0 0 0.875rem; line-height: 1.4; }
  .op-card__body { font-size: 0.9375rem; color: #374151; line-height: 1.7; white-space: pre-wrap; margin-bottom: 1rem; }
  .op-card__footer { border-top: 1px solid #f1f5f9; padding-top: 0.75rem; }
  .op-card__reply-count { font-size: 0.8125rem; color: #94a3b8; font-weight: 600; }
  .not-found { color: #94a3b8; font-size: 0.9375rem; padding: 2rem; text-align: center; }
  .replies-list { display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem; }
  .reply-item { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.25rem; }
  .reply-item--staff { border-color: #059669; border-left: 4px solid #059669; background: #f0fdf4; }
  .reply-item__header { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.75rem; }
  .reply-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.8rem; color: #fff; flex-shrink: 0; background: linear-gradient(135deg, #64748b, #475569); }
  .reply-avatar--green { background: linear-gradient(135deg, #059669, #047857); }
  .reply-item__meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .reply-item__author { font-size: 0.875rem; font-weight: 700; color: #0f172a; }
  .reply-item__staff-badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; padding: 1px 6px; border-radius: 4px; background: #dcfce7; color: #065f46; border: 1px solid #bbf7d0; }
  .reply-item__dot { color: #cbd5e1; font-size: 0.75rem; }
  .reply-item__time { font-size: 0.8rem; color: #94a3b8; }
  .reply-item__body { font-size: 0.9375rem; color: #374151; line-height: 1.65; white-space: pre-wrap; margin-bottom: 0.75rem; }
  .reply-item__num { font-size: 0.75rem; color: #cbd5e1; font-weight: 600; }
  .reply-card--form { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.5rem; }
  .reply-card__form-title { font-size: 1.125rem; font-weight: 800; color: #0f172a; margin: 0 0 0.25rem; }
  .reply-card__form-sub { font-size: 0.875rem; color: #64748b; margin: 0 0 1.25rem; }
  .reply-form__field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .reply-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .reply-form__label { font-size: 0.8125rem; font-weight: 600; color: #374151; }
  .reply-form__input, .reply-form__textarea { width: 100%; padding: 0.6rem 0.875rem; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; color: #0f172a; background: #fff; font-family: inherit; box-sizing: border-box; }
  .reply-form__textarea { resize: vertical; min-height: 120px; }
  .reply-form__submit { margin-top: 0.5rem; background: #2563eb; color: #fff; font-weight: 700; font-size: 0.9375rem; padding: 0.65rem 1.5rem; border: none; border-radius: 8px; cursor: pointer; font-family: inherit; }
  .reply-form__submit:disabled { background: #93c5fd; cursor: not-allowed; }
  .reply-form__note { font-size: 0.8rem; color: #94a3b8; margin: 0.75rem 0 0; }
  .reply-success { text-align: center; padding: 2rem; }
  .reply-success__icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .reply-success strong { display: block; font-size: 1.125rem; color: #0f172a; margin-bottom: 0.35rem; }
  .reply-success p { color: #64748b; font-size: 0.9rem; margin: 0; }
  .sidebar-btn { display: block; text-align: center; font-weight: 700; font-size: 0.875rem; padding: 0.625rem 1rem; border-radius: 10px; text-decoration: none; margin-bottom: 0.625rem; }
  .sidebar-btn--new { background: #2563eb; color: #fff; }
  .sidebar-btn--back { background: #fff; color: #374151; border: 1.5px solid #e2e8f0; }
  .sidebar-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.25rem; margin-bottom: 1rem; }
  .sidebar-card__title { font-size: 0.875rem; font-weight: 800; color: #0f172a; margin: 0 0 0.75rem; }
  .sidebar-card__links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-card__links li { font-size: 0.875rem; color: #374151; }
  .sidebar-card__links a { color: #2563eb; text-decoration: none; font-weight: 500; }
  @media (max-width: 768px) {
    .thread-layout__inner { grid-template-columns: 1fr; }
    .thread-sidebar { display: none; }
    .reply-form__row { grid-template-columns: 1fr; }
  }
</style>
