---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Community Forum | College Courses Online"
  description="Ask questions, share experiences, and get answers about college courses, prerequisites, nursing school, PA programs, and online learning."
>
  <div class="forum-page">

    <!-- Hero / Header -->
    <div class="forum-hero">
      <div class="forum-hero__inner">
        <h1 class="forum-hero__title">Community Forum</h1>
        <p class="forum-hero__desc">
          Ask questions, share experiences, and get answers from students and our editorial team.
          No account needed.
        </p>
        <div class="forum-search-wrap">
          <svg class="forum-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input class="forum-search-input" id="forumSearch" type="search" placeholder="Search questions…" aria-label="Search forum questions" />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="forum-stats-bar">
      <div class="forum-stats-bar__inner">
        <div class="forum-stat" id="statTopics"><span class="forum-stat__num">5</span><span class="forum-stat__label">Categories</span></div>
        <div class="forum-stat" id="statPosts"><span class="forum-stat__num" id="totalPostsNum">—</span><span class="forum-stat__label">Questions</span></div>
        <div class="forum-stat"><span class="forum-stat__num" id="totalRepliesNum">—</span><span class="forum-stat__label">Replies</span></div>
        <div class="forum-stat"><span class="forum-stat__num">Free</span><span class="forum-stat__label">No account needed</span></div>
      </div>
    </div>

    <!-- Main content -->
    <div class="forum-body">
      <div class="forum-main">

        <!-- Category section label -->
        <div class="section-header">
          <h2 class="section-header__title">Browse by category</h2>
          <p class="section-header__sub">Pick a topic to see questions and post your own.</p>
        </div>

        <!-- Categories grid -->
        <div id="categoriesGrid" class="categories-grid">
          <!-- Skeleton placeholders -->
          <div class="cat-skeleton"></div>
          <div class="cat-skeleton"></div>
          <div class="cat-skeleton"></div>
          <div class="cat-skeleton"></div>
          <div class="cat-skeleton"></div>
        </div>

        <!-- Recent questions section -->
        <div class="section-header" style="margin-top:2.5rem">
          <h2 class="section-header__title">Recent questions</h2>
        </div>
        <div id="recentPosts" class="recent-posts">
          <div class="loading">Loading recent questions…</div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="forum-sidebar">
        <div class="sidebar-card sidebar-card--cta">
          <div class="sidebar-card__icon">✏️</div>
          <h3 class="sidebar-card__title">Have a question?</h3>
          <p class="sidebar-card__desc">Pick a category below and ask. No account or signup required.</p>
          <a href="/forum/general#ask" class="sidebar-btn">Ask a question →</a>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">📖 Related guides</h3>
          <ul class="sidebar-links">
            <li><a href="/resources/blog/prerequisite-courses-for-nursing-school">Nursing school prerequisites</a></li>
            <li><a href="/resources/blog/how-to-become-physician-assistant">How to become a PA</a></li>
            <li><a href="/resources/blog/prerequisite-college-courses-by-major">Prereqs by major</a></li>
            <li><a href="/resources/blog/enrollment-decline-college-closures-hybrid-campus">Enrollment trends 2026</a></li>
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--rules">
          <h3 class="sidebar-card__title">🤝 Community guidelines</h3>
          <ul class="sidebar-links">
            <li>Be respectful and helpful</li>
            <li>Share your own experience</li>
            <li>No spam or self-promotion</li>
            <li>All posts reviewed before publishing</li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  async function sbFetch(path) {
    const res = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
      headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
    });
    return res.json();
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function timeAgo(dateStr) {
    const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    if (diff < 2592000) return `${Math.floor(diff/86400)}d ago`;
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  async function init() {
    const [topics, posts] = await Promise.all([
      sbFetch('topics?is_active=eq.true&order=name.asc&select=*'),
      sbFetch('posts?is_approved=eq.true&order=created_at.desc&limit=8&select=id,title,author_name,topic_slug,reply_count,created_at')
    ]);

    // Stats
    const totalPosts = topics.reduce((s, t) => s + t.post_count, 0);
    document.getElementById('totalPostsNum').textContent = totalPosts;

    // Count total replies
    const repliesRes = await sbFetch('replies?is_approved=eq.true&select=id');
    document.getElementById('totalRepliesNum').textContent = Array.isArray(repliesRes) ? repliesRes.length : '—';

    // Categories grid
    const grid = document.getElementById('categoriesGrid');
    grid.innerHTML = topics.map(t => `
      <a href="/forum/${t.slug}" class="cat-card" data-topic="${t.slug}">
        <div class="cat-card__top">
          <div class="cat-card__icon-wrap">
            <span class="cat-card__icon">${t.icon}</span>
          </div>
          <div class="cat-card__info">
            <h3 class="cat-card__name">${escHtml(t.name)}</h3>
            <p class="cat-card__desc">${escHtml(t.description)}</p>
          </div>
        </div>
        <div class="cat-card__footer">
          <span class="cat-card__stat"><strong>${t.post_count}</strong> questions</span>
          <span class="cat-card__cta">View →</span>
        </div>
      </a>`).join('');

    // Recent posts
    const recentEl = document.getElementById('recentPosts');
    if (!posts.length) {
      recentEl.innerHTML = '<p class="empty-msg">No questions yet — be the first to ask!</p>';
    } else {
      recentEl.innerHTML = posts.map(p => {
        const topic = topics.find(t => t.slug === p.topic_slug);
        return `
          <a href="/forum/post/${p.id}" class="recent-row">
            <div class="recent-row__left">
              <span class="recent-row__topic-icon">${topic?.icon || '💬'}</span>
              <div>
                <p class="recent-row__title">${escHtml(p.title)}</p>
                <div class="recent-row__meta">
                  <span class="recent-row__topic-name">${topic?.name || p.topic_slug}</span>
                  <span class="recent-row__dot">·</span>
                  <span>by ${escHtml(p.author_name)}</span>
                  <span class="recent-row__dot">·</span>
                  <span>${timeAgo(p.created_at)}</span>
                </div>
              </div>
            </div>
            <div class="recent-row__replies">
              <span class="recent-row__reply-num">${p.reply_count}</span>
              <span class="recent-row__reply-lbl">${p.reply_count === 1 ? 'reply' : 'replies'}</span>
            </div>
          </a>`;
      }).join('');
    }
  }

  // Search filter
  document.getElementById('forumSearch').addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.recent-row').forEach(row => {
      const title = row.querySelector('.recent-row__title').textContent.toLowerCase();
      row.style.display = title.includes(q) ? '' : 'none';
    });
    document.querySelectorAll('.cat-card').forEach(card => {
      const name = card.querySelector('.cat-card__name').textContent.toLowerCase();
      const desc = card.querySelector('.cat-card__desc').textContent.toLowerCase();
      card.style.display = (name.includes(q) || desc.includes(q)) ? '' : 'none';
    });
  });

  init();
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .forum-hero {
    background: linear-gradient(135deg, #0f2744 0%, #1d4ed8 100%);
    padding: 3.5rem 1.5rem 2.5rem;
  }
  .forum-hero__inner { max-width: 860px; margin: 0 auto; }
  .forum-hero__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 0.625rem;
  }
  .forum-hero__desc {
    font-size: 1.0625rem;
    color: #bfdbfe;
    margin: 0 0 1.5rem;
    max-width: 560px;
    line-height: 1.6;
  }
  .forum-search-wrap {
    position: relative;
    max-width: 520px;
  }
  .forum-search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    pointer-events: none;
  }
  .forum-search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    border: none;
    border-radius: 10px;
    font-size: 0.9375rem;
    color: #0f172a;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    font-family: inherit;
    box-sizing: border-box;
  }
  .forum-search-input:focus { outline: 2px solid #60a5fa; }

  /* ── Stats bar ────────────────────────────────────────────────────────── */
  .forum-stats-bar {
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
    padding: 0.875rem 1.5rem;
  }
  .forum-stats-bar__inner {
    max-width: 1160px;
    margin: 0 auto;
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }
  .forum-stat { display: flex; align-items: baseline; gap: 0.4rem; }
  .forum-stat__num { font-size: 1.125rem; font-weight: 800; color: #0f172a; }
  .forum-stat__label { font-size: 0.8rem; color: #64748b; font-weight: 500; }

  /* ── Body layout ──────────────────────────────────────────────────────── */
  .forum-body {
    max-width: 1160px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Section headers ──────────────────────────────────────────────────── */
  .section-header { margin-bottom: 1.25rem; }
  .section-header__title { font-size: 1.125rem; font-weight: 800; color: #0f172a; margin: 0 0 0.2rem; }
  .section-header__sub { font-size: 0.875rem; color: #64748b; margin: 0; }

  /* ── Categories grid ──────────────────────────────────────────────────── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .cat-skeleton {
    height: 130px;
    border-radius: 14px;
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
  }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  .cat-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.25rem 1.375rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
    box-shadow: 0 1px 3px rgba(15,23,42,0.05);
  }
  .cat-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 20px rgba(37,99,235,0.12);
    transform: translateY(-2px);
  }
  .cat-card__top { display: flex; gap: 1rem; align-items: flex-start; }
  .cat-card__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #eff6ff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.5rem;
  }
  .cat-card__info { flex: 1; }
  .cat-card__name { font-size: 0.9375rem; font-weight: 800; color: #0f172a; margin: 0 0 0.3rem; }
  .cat-card__desc { font-size: 0.8125rem; color: #64748b; margin: 0; line-height: 1.5; }
  .cat-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
  }
  .cat-card__stat { font-size: 0.8rem; color: #94a3b8; }
  .cat-card__stat strong { color: #374151; font-weight: 700; }
  .cat-card__cta { font-size: 0.8rem; font-weight: 700; color: #2563eb; }

  /* ── Recent posts ─────────────────────────────────────────────────────── */
  .recent-posts {
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
  }
  .loading { color: #94a3b8; font-size: 0.9rem; padding: 1.5rem; }
  .empty-msg { color: #94a3b8; font-size: 0.9rem; padding: 1.5rem; margin: 0; }
  .recent-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #f8fafc;
    text-decoration: none;
    transition: background 0.12s;
  }
  .recent-row:last-child { border-bottom: none; }
  .recent-row:hover { background: #f8faff; }
  .recent-row__left { display: flex; align-items: flex-start; gap: 0.75rem; flex: 1; min-width: 0; }
  .recent-row__topic-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 1px; }
  .recent-row__title { font-size: 0.9rem; font-weight: 700; color: #0f172a; margin: 0 0 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 520px; }
  .recent-row__meta { font-size: 0.775rem; color: #94a3b8; display: flex; align-items: center; gap: 0.25rem; flex-wrap: wrap; }
  .recent-row__topic-name { color: #2563eb; font-weight: 600; }
  .recent-row__dot { color: #cbd5e1; }
  .recent-row__replies { text-align: center; flex-shrink: 0; min-width: 48px; }
  .recent-row__reply-num { display: block; font-size: 1.125rem; font-weight: 800; color: #2563eb; line-height: 1; }
  .recent-row__reply-lbl { font-size: 0.65rem; color: #94a3b8; font-weight: 600; }

  /* ── Sidebar ──────────────────────────────────────────────────────────── */
  .forum-sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .sidebar-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.375rem;
  }
  .sidebar-card--cta {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    border: none;
    text-align: center;
  }
  .sidebar-card--rules { background: #fafbff; }
  .sidebar-card__icon { font-size: 1.75rem; display: block; margin-bottom: 0.5rem; }
  .sidebar-card__title { font-size: 0.9375rem; font-weight: 800; margin: 0 0 0.4rem; color: #0f172a; }
  .sidebar-card--cta .sidebar-card__title { color: #fff; }
  .sidebar-card__desc { font-size: 0.8375rem; color: #64748b; margin: 0 0 1rem; line-height: 1.5; }
  .sidebar-card--cta .sidebar-card__desc { color: #bfdbfe; }
  .sidebar-btn {
    display: inline-block;
    background: #fff;
    color: #1d4ed8;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .sidebar-btn:hover { background: #eff6ff; }
  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sidebar-links li { font-size: 0.875rem; color: #374151; padding-left: 0.9rem; position: relative; }
  .sidebar-links li::before { content: '→'; position: absolute; left: 0; color: #2563eb; font-size: 0.75rem; top: 1px; }
  .sidebar-links a { color: #2563eb; text-decoration: none; font-weight: 500; }
  .sidebar-links a:hover { text-decoration: underline; }

  @media (max-width: 900px) {
    .forum-body { grid-template-columns: 1fr; }
    .forum-sidebar { order: -1; }
    .categories-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 540px) {
    .forum-stats-bar__inner { gap: 1.25rem; flex-wrap: wrap; }
  }
</style>
