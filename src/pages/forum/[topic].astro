---
import Layout from '../../layouts/Layout.astro';

const { topic: topicSlug } = Astro.params;

export function getStaticPaths() {
  return [
    { params: { topic: 'nursing-school' } },
    { params: { topic: 'physician-assistant' } },
    { params: { topic: 'prerequisites-courses' } },
    { params: { topic: 'online-hybrid-learning' } },
    { params: { topic: 'general' } },
  ];
}
---

<Layout
  title="Forum | College Courses Online"
  description="Ask and answer questions on College Courses Online community forum."
>
  <!-- Top bar (Reddit-style subreddit banner) -->
  <div class="topic-header">
    <div class="topic-header__bar">
      <div class="topic-header__inner">
        <a href="/forum" class="topic-header__back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Forum
        </a>
        <div class="topic-header__badge" id="topicBadge">
          <span id="topicIcon">💬</span>
          <span id="topicName">Loading…</span>
        </div>
      </div>
    </div>
    <div class="topic-header__hero">
      <div class="topic-header__inner">
        <p class="topic-header__desc" id="topicDesc">Loading topic…</p>
        <div class="topic-header__stats" id="topicStats"></div>
      </div>
    </div>
  </div>

  <!-- Page body: main + sidebar -->
  <div class="topic-layout">
    <div class="topic-layout__inner">

      <!-- Main column -->
      <div class="topic-main">

        <!-- Sort + Ask bar -->
        <div class="topic-toolbar">
          <div class="topic-toolbar__tabs">
            <button class="tb-tab tb-tab--active" data-sort="new">New</button>
            <button class="tb-tab" data-sort="top">Most Replied</button>
          </div>
          <a href="#ask" class="tb-ask-btn">+ Ask a question</a>
        </div>

        <!-- Post list -->
        <div id="postsList">
          <div class="post-skeleton"></div>
          <div class="post-skeleton"></div>
          <div class="post-skeleton"></div>
        </div>

        <!-- Ask section -->
        <div class="ask-card" id="ask">
          <div class="ask-card__head">
            <h2 class="ask-card__title">Ask a question</h2>
            <p class="ask-card__sub">No account needed. Your question will appear after a quick review.</p>
          </div>
          <form class="ask-form" id="postForm">
            <input type="hidden" name="topic_slug" id="topicSlugInput" value={topicSlug} />
            <div class="ask-form__field">
              <label class="ask-form__label" for="post-title">Question title</label>
              <input class="ask-form__input" type="text" id="post-title" name="title" placeholder="e.g. Do nursing schools accept online A&P?" required maxlength="200" />
            </div>
            <div class="ask-form__field">
              <label class="ask-form__label" for="post-body">Details (optional but helpful)</label>
              <textarea class="ask-form__textarea" id="post-body" name="body" rows="4" placeholder="Add any context that helps someone answer your question…"></textarea>
            </div>
            <div class="ask-form__row">
              <div class="ask-form__field">
                <label class="ask-form__label" for="post-name">Your name</label>
                <input class="ask-form__input" type="text" id="post-name" name="author_name" placeholder="First name is fine" required />
              </div>
              <div class="ask-form__field">
                <label class="ask-form__label" for="post-email">Email (not shown)</label>
                <input class="ask-form__input" type="email" id="post-email" name="author_email" placeholder="For reply notifications" required />
              </div>
            </div>
            <button class="ask-form__submit" type="submit">Submit question →</button>
            <p class="ask-form__note">Questions are reviewed before appearing publicly. Usually within 24 hours.</p>
          </form>
          <div class="ask-success" id="postSuccess" style="display:none">
            <div class="ask-success__icon">✅</div>
            <strong>Question submitted!</strong>
            <p>It will appear here after a quick review. Thank you!</p>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="topic-sidebar">
        <div class="sidebar-card sidebar-card--cta">
          <div class="sidebar-card__cta-icon">✏️</div>
          <p class="sidebar-card__cta-text">Have a question in this topic?</p>
          <a href="#ask" class="sidebar-card__cta-btn">Ask now</a>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Other Topics</h3>
          <ul class="sidebar-card__links" id="otherTopics">
            <li><a href="/forum/nursing-school">🩺 Nursing School</a></li>
            <li><a href="/forum/physician-assistant">⚕️ Physician Assistant</a></li>
            <li><a href="/forum/prerequisites-courses">📚 Prerequisites &amp; Courses</a></li>
            <li><a href="/forum/online-hybrid-learning">💻 Online &amp; Hybrid Learning</a></li>
            <li><a href="/forum/general">💬 General</a></li>
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--light">
          <h3 class="sidebar-card__title">📖 Related Guides</h3>
          <ul class="sidebar-card__links">
            <li><a href="/resources/blog/prerequisite-courses-for-nursing-school">Nursing prerequisites</a></li>
            <li><a href="/resources/blog/how-to-become-physician-assistant">How to become a PA</a></li>
            <li><a href="/resources/blog/prerequisite-college-courses-by-major">Prereqs by major</a></li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<script define:vars={{ topicSlug, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  let allPosts = [];
  let currentSort = 'new';

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function timeAgo(d) {
    const diff = Math.floor((Date.now() - new Date(d)) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    if (diff < 2592000) return `${Math.floor(diff/86400)}d ago`;
    return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  async function sbFetch(path) {
    const res = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
      headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
    });
    return res.json();
  }

  function renderPosts(posts) {
    const el = document.getElementById('postsList');
    if (!posts.length) {
      el.innerHTML = '<div class="empty-state"><div class="empty-state__icon">💬</div><p>No questions yet — be the first to ask!</p></div>';
      return;
    }
    el.innerHTML = posts.map(p => `
      <a href="/forum/post/?id=${encodeURIComponent(p.id)}" class="post-row">
        <div class="post-row__vote-col">
          <div class="post-row__reply-box">
            <span class="post-row__reply-num">${p.reply_count}</span>
            <span class="post-row__reply-lbl">${p.reply_count === 1 ? 'reply' : 'replies'}</span>
          </div>
        </div>
        <div class="post-row__body">
          <h3 class="post-row__title">${escHtml(p.title)}</h3>
          <div class="post-row__meta">
            <span>by <strong>${escHtml(p.author_name)}</strong></span>
            <span class="dot">·</span>
            <span>${timeAgo(p.created_at)}</span>
          </div>
        </div>
        <div class="post-row__arrow">→</div>
      </a>`).join('');
  }

  async function init() {
    const [topics, posts] = await Promise.all([
      sbFetch(`topics?slug=eq.${topicSlug}&select=*`),
      sbFetch(`posts?topic_slug=eq.${topicSlug}&is_approved=eq.true&order=created_at.desc&select=id,title,author_name,reply_count,created_at`)
    ]);

    const topic = topics[0];
    if (topic) {
      document.getElementById('topicIcon').textContent = topic.icon;
      document.getElementById('topicName').textContent = topic.name;
      document.getElementById('topicDesc').textContent = topic.description;
      document.getElementById('topicStats').innerHTML = `<span>${topic.post_count} questions</span>`;
      document.title = `${topic.name} | Forum | College Courses Online`;
    }

    allPosts = posts;
    renderPosts(allPosts);

    document.querySelectorAll('.tb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tb-tab').forEach(b => b.classList.remove('tb-tab--active'));
        btn.classList.add('tb-tab--active');
        currentSort = btn.dataset.sort;
        const sorted = [...allPosts].sort((a,b) =>
          currentSort === 'top' ? b.reply_count - a.reply_count : new Date(b.created_at) - new Date(a.created_at)
        );
        renderPosts(sorted);
      });
    });
  }

  const form = document.getElementById('postForm');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true; btn.textContent = 'Submitting…';
    const data = Object.fromEntries(new FormData(form));
    if (!data.body) data.body = '(no details provided)';
    const res = await fetch('/api/forum-post', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (res.ok) { form.style.display = 'none'; document.getElementById('postSuccess').style.display = 'block'; }
    else { btn.disabled = false; btn.textContent = 'Submit question →'; alert('Something went wrong. Please try again.'); }
  });

  init();
</script>

<style>
  /* ── Topic header ─────────────────────────────────────────────────────── */
  .topic-header { background: linear-gradient(135deg, #0f2744 0%, #1d4ed8 100%); }
  .topic-header__bar { border-bottom: 1px solid rgba(255,255,255,0.1); }
  .topic-header__inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
  .topic-header__bar .topic-header__inner { display: flex; align-items: center; gap: 1rem; height: 48px; }
  .topic-header__back {
    display: inline-flex; align-items: center; gap: 0.4rem;
    color: #93c5fd; font-size: 0.875rem; font-weight: 600; text-decoration: none;
    transition: color 0.12s;
  }
  .topic-header__back:hover { color: #fff; }
  .topic-header__badge {
    display: flex; align-items: center; gap: 0.5rem;
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 20px; padding: 0.25rem 0.875rem;
    font-size: 0.875rem; font-weight: 700; color: #fff;
  }
  .topic-header__hero { padding: 1.75rem 0 1.75rem; }
  .topic-header__hero .topic-header__inner { padding-top: 0; padding-bottom: 0; }
  .topic-header__desc { font-size: 0.9375rem; color: #bfdbfe; margin: 0 0 0.5rem; }
  .topic-header__stats { font-size: 0.8rem; color: #93c5fd; font-weight: 600; }

  /* ── Layout ───────────────────────────────────────────────────────────── */
  .topic-layout { background: #f1f5f9; min-height: 60vh; padding: 1.75rem 0 4rem; }
  .topic-layout__inner { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr 260px; gap: 1.5rem; align-items: start; }

  /* ── Toolbar ──────────────────────────────────────────────────────────── */
  .topic-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .topic-toolbar__tabs { display: flex; gap: 0.375rem; }
  .tb-tab { padding: 0.3rem 0.875rem; font-size: 0.8rem; font-weight: 700; border: 1.5px solid #e2e8f0; border-radius: 20px; background: #fff; color: #64748b; cursor: pointer; font-family: inherit; transition: all 0.15s; }
  .tb-tab:hover { border-color: #2563eb; color: #2563eb; }
  .tb-tab--active { background: #2563eb; border-color: #2563eb; color: #fff; }
  .tb-ask-btn { padding: 0.4rem 1rem; font-size: 0.8rem; font-weight: 700; background: #0f172a; color: #fff; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
  .tb-ask-btn:hover { background: #1e293b; }

  /* ── Post list ────────────────────────────────────────────────────────── */
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .post-skeleton { height: 76px; border-radius: 12px; margin-bottom: 4px; background: linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation: shimmer 1.4s infinite; }
  .post-row { display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1.125rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; margin-bottom: 4px; text-decoration: none; transition: box-shadow 0.15s, border-color 0.15s; }
  .post-row:hover { border-color: #2563eb; box-shadow: 0 2px 12px rgba(37,99,235,0.08); }
  .post-row__vote-col { flex-shrink: 0; }
  .post-row__reply-box { width: 52px; text-align: center; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 0.35rem 0; }
  .post-row__reply-num { display: block; font-size: 1.125rem; font-weight: 800; color: #2563eb; line-height: 1; }
  .post-row__reply-lbl { font-size: 0.6rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; }
  .post-row__body { flex: 1; min-width: 0; }
  .post-row__title { font-size: 0.9375rem; font-weight: 700; color: #0f172a; margin: 0 0 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .post-row__meta { font-size: 0.8rem; color: #94a3b8; display: flex; align-items: center; gap: 0.3rem; }
  .dot { color: #cbd5e1; }
  .post-row__arrow { font-size: 1rem; color: #cbd5e1; flex-shrink: 0; transition: color 0.12s; }
  .post-row:hover .post-row__arrow { color: #2563eb; }

  /* ── Empty ────────────────────────────────────────────────────────────── */
  .empty-state { text-align: center; padding: 3rem 1rem; color: #94a3b8; font-size: 0.9375rem; }
  .empty-state__icon { font-size: 2.5rem; margin-bottom: 0.75rem; }

  /* ── Ask card ─────────────────────────────────────────────────────────── */
  .ask-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.75rem; margin-top: 1.5rem; }
  .ask-card__head { margin-bottom: 1.25rem; }
  .ask-card__title { font-size: 1.125rem; font-weight: 800; color: #0f172a; margin: 0 0 0.25rem; }
  .ask-card__sub { font-size: 0.875rem; color: #64748b; margin: 0; }
  .ask-form__field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .ask-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .ask-form__label { font-size: 0.8125rem; font-weight: 600; color: #374151; }
  .ask-form__input, .ask-form__textarea { width: 100%; padding: 0.6rem 0.875rem; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 0.9rem; color: #0f172a; background: #fff; font-family: inherit; box-sizing: border-box; transition: border-color 0.15s, box-shadow 0.15s; }
  .ask-form__input:focus, .ask-form__textarea:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
  .ask-form__textarea { resize: vertical; min-height: 100px; }
  .ask-form__submit { margin-top: 0.5rem; background: #2563eb; color: #fff; font-weight: 700; font-size: 0.9375rem; padding: 0.65rem 1.5rem; border: none; border-radius: 8px; cursor: pointer; font-family: inherit; transition: background 0.15s; }
  .ask-form__submit:hover { background: #1d4ed8; }
  .ask-form__submit:disabled { background: #93c5fd; cursor: not-allowed; }
  .ask-form__note { font-size: 0.8rem; color: #94a3b8; margin: 0.75rem 0 0; }
  .ask-success { text-align: center; padding: 2rem; }
  .ask-success__icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .ask-success strong { display: block; font-size: 1.125rem; color: #0f172a; margin-bottom: 0.35rem; }
  .ask-success p { color: #64748b; font-size: 0.9rem; margin: 0; }

  /* ── Sidebar ──────────────────────────────────────────────────────────── */
  .sidebar-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.25rem; margin-bottom: 1rem; }
  .sidebar-card--cta { background: linear-gradient(135deg, #0f2744 0%, #1d4ed8 100%); border: none; text-align: center; }
  .sidebar-card__cta-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }
  .sidebar-card__cta-text { font-size: 0.875rem; color: #bfdbfe; margin: 0 0 0.875rem; }
  .sidebar-card__cta-btn { display: inline-block; background: #fff; color: #1d4ed8; font-weight: 700; font-size: 0.875rem; padding: 0.45rem 1.25rem; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
  .sidebar-card__cta-btn:hover { background: #eff6ff; }
  .sidebar-card--light { background: #eff6ff; border-color: #bfdbfe; }
  .sidebar-card__title { font-size: 0.875rem; font-weight: 800; color: #0f172a; margin: 0 0 0.75rem; }
  .sidebar-card__links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-card__links li { font-size: 0.875rem; }
  .sidebar-card__links a { color: #2563eb; text-decoration: none; font-weight: 500; }
  .sidebar-card__links a:hover { text-decoration: underline; }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .topic-layout__inner { grid-template-columns: 1fr; }
    .topic-sidebar { display: none; }
    .ask-form__row { grid-template-columns: 1fr; }
    .tb-ask-btn { display: none; }
  }
</style>
