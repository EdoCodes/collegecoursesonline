---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="News | Online College Courses"
  description="Find education guides under Resources and Colleges. In-depth articles on online courses, accreditation, financial aid, and more."
>
  <div class="page-header">
    <div class="container">
      <h1>News</h1>
      <p class="subtitle">Guides and articles are published in Resources and Colleges—see links below.</p>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="empty-state">
        <p>
          In-depth guides and articles are on{' '}
          <a href="/resources/blog">Resources → Blog</a> and{' '}
          <a href="/colleges">Colleges</a>.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 3rem 0 2.5rem;
  }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    max-width: 560px;
  }

  .main-content {
    padding: 3rem 0 5rem;
  }

  .empty-state {
    text-align: center;
    color: #64748b;
    padding: 3rem 1rem;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.65;
  }
  .empty-state a {
    color: #2563eb;
    font-weight: 600;
    text-decoration: none;
  }
  .empty-state a:hover {
    text-decoration: underline;
  }
</style>
