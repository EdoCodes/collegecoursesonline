---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="News | Online College Courses"
	description="News and announcements. In-depth guides are listed under Resources → Guides."
>
	<div class="page-header">
		<div class="container">
			<h1>News</h1>
			<p class="subtitle">
				There are no news articles published yet. For education guides, see{' '}
				<a href="/resources/guides">Resources → Guides</a>.
			</p>
		</div>
	</div>

	<main class="main-content">
		<div class="container">
			<div class="empty-state" aria-live="polite">
				<p>No news articles yet.</p>
			</div>
		</div>
	</main>
</Layout>

<style>
	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.page-header {
		background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
		color: white;
		padding: 3rem 0 2.5rem;
	}

	.page-header h1 {
		color: white;
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		font-size: 1.0625rem;
		color: rgba(255, 255, 255, 0.75);
		margin: 0;
		max-width: 640px;
		line-height: 1.5;
	}
	.subtitle a {
		color: rgba(255, 255, 255, 0.95);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.subtitle a:hover {
		color: white;
	}

	.main-content {
		padding: 3rem 0 5rem;
	}

	.empty-state {
		text-align: center;
		color: #64748b;
		padding: 4rem 1rem;
		font-size: 1.0625rem;
	}
</style>
