---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function readingTime(body: string) {
  const words = body.split(/\s+/).length;
  const mins = Math.ceil(words / 200);
  return `${mins} min read`;
}
---

<Layout
  title="Blog | Online College Courses"
  description="Guides, tips, and insights on online learning, accreditation, financial aid, and choosing the right college course for your goals."
>
  <div class="page-header">
    <div class="container">
      <div class="header-inner">
        <span class="header-label">Blog</span>
        <h1>Online Learning Guides & Insights</h1>
        <p class="subtitle">Expert advice to help you find, choose, and succeed in online college courses.</p>
      </div>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            {post.data.image && (
              <div class="card-image">
                <img src={post.data.image} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="card-body">
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="card-label">{post.data.tags[0]}</span>
              )}
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-footer">
                {post.data.tags && post.data.tags.length > 1 && (
                  <div class="card-tags">
                    {post.data.tags.slice(1, 4).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <div class="card-meta">
                  <span>{formatDate(post.data.pubDate)}</span>
                  <span class="dot">·</span>
                  <span>{readingTime(post.body)}</span>
                </div>
              </div>
              <span class="card-cta">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 3.5rem 0 3rem;
  }

  .header-inner {
    max-width: 680px;
  }

  .header-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.3rem 0.875rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.625rem;
    line-height: 1.15;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    line-height: 1.6;
  }

  .main-content {
    padding: 3.5rem 0 6rem;
    background: #f8fafc;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    height: 100%;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    border-color: #1e40af;
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: #f1f5f9;
    flex-shrink: 0;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1e40af;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.35;
    margin-bottom: 0.625rem;
    letter-spacing: -0.02em;
  }

  .post-card:hover .card-title {
    color: #1e40af;
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    margin-bottom: 1rem;
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #f1f5f9;
    color: #475569;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: #94a3b8;
  }

  .dot { opacity: 0.5; }

  .card-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1e40af;
    transition: color 0.2s;
    margin-top: auto;
  }

  .post-card:hover .card-cta {
    color: #1e3a8a;
  }

  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
