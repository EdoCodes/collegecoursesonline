---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="News | Online College Courses"
  description="The latest news, updates, and announcements from Online College Courses."
>
  <div class="page-header">
    <div class="container">
      <h1>News</h1>
      <p class="subtitle">Updates and announcements — check back soon</p>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10l6 6v8a2 2 0 0 1-2 2z"/>
          <polyline points="17 2 17 8 23 8"/>
          <line x1="9" y1="15" x2="15" y2="15"/>
          <line x1="9" y1="11" x2="11" y2="11"/>
        </svg>
        <h2>Coming Soon</h2>
        <p>We're working on something great. News and updates will appear here shortly.</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 3rem 0 2.5rem;
  }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  .main-content {
    padding: 5rem 0 8rem;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    color: #94a3b8;
  }

  .empty-state svg {
    color: #cbd5e1;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #334155;
    margin: 0;
  }

  .empty-state p {
    font-size: 1rem;
    color: #64748b;
    max-width: 380px;
    margin: 0;
    line-height: 1.6;
  }
</style>
