---
import BlogArticleLayout from '../../components/blog/BlogArticleLayout.astro';
import ArticleProse from '../../components/blog/ArticleProse.astro';

const title =
  'Academic Acronyms Glossary: Degree, Nursing, IT, and Accreditation Terms';
const description =
  'Explore a complete academic acronyms glossary covering degree abbreviations, nursing acronyms, IT terms, and accreditation language used across U.S. higher education.';
const publishDate = '2026-04-17';
const updatedDate = '2026-04-17';
const author = 'Editorial Team';
const readingTime = '14 min read';
const canonicalPath = '/academic-acronyms-glossary/';
const heroImageUrl =
  'https://images.pexels.com/photos/159775/library-la-trobe-study-students-159775.jpeg?auto=compress&cs=tinysrgb&w=1200';

const siteOrigin = (Astro.site?.href ?? 'https://collegecoursesonline.netlify.app/').replace(
  /\/$/,
