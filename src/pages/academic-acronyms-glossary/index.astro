              <td>Certified Nursing Assistant</td>
              <td>Entry-level patient care role.</td>
            </tr>
            <tr>
              <td>ADN</td>
              <td>Associate Degree in Nursing</td>
              <td>Common RN pathway.</td>
            </tr>
            <tr>
              <td>ASN</td>
              <td>Associate of Science in Nursing</td>
              <td>Common RN pathway.</td>
            </tr>
            <tr>
              <td>BSN</td>
