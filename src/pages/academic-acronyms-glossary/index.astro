        '@type': 'Answer',
        text: 'BSN means Bachelor of Science in Nursing.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does ASc mean?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ASc is a variant abbreviation for Associate of Science.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does BSc mean?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'BSc means Bachelor of Science.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is CHEA?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CHEA is the Council for Higher Education Accreditation.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is ABET?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ABET is the Accreditation Board for Engineering and Technology.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between accreditation and a degree abbreviation?',
      acceptedAnswer: {
        '@type': 'Answer',
