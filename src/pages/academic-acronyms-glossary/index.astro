const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Resources',
      item: `${siteOrigin}/resources`,
