---
import Layout from '../layouts/Layout.astro';
import { supabase, isSupabaseConfigured } from '../lib/supabase';
import { getCollection } from 'astro:content';
import type { Course } from '../lib/supabase';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

let coursesData: Course[] = [];
let categories: any[] = [];

if (isSupabaseConfigured && supabase) {
	const { data: courses } = await supabase
		.from('courses')
		.select(`*, colleges (*), course_categories (*)`)
		.order('featured', { ascending: false })
		.order('created_at', { ascending: false })
		.limit(50);

	coursesData = courses || [];

	const { data: cats } = await supabase
		.from('course_categories')
		.select('*')
		.order('name');

	categories = cats || [];
}
---

<Layout
  title="Online College Courses | Find Accredited Programs"
  description="Search thousands of accredited online college courses, degrees, and certificate programs from top institutions."
>

	<!-- Teal Page Header -->
	<div class="page-header">
		<div class="container">
			<h1>Online College Courses</h1>
			<p class="motto">Find your program. Advance your career.™</p>
			<div class="search-wrapper">
				<div class="search-box">
					<svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<circle cx="11" cy="11" r="8"/>
						<path d="M21 21l-4.35-4.35"/>
					</svg>
					<input
						type="text"
						id="searchInput"
						placeholder="Search for courses, subjects, or colleges..."
						autocomplete="off"
					/>
				</div>
			</div>
		</div>
	</div>

	<!-- Main Content -->
	<div class="container">
		<div class="unified-section">

			<div class="section-heading">
				<h2>Course Directory</h2>
				<p>Accredited degrees, certificates, and courses from top institutions</p>
			</div>

			<!-- Filters -->
			<div class="filters-bar">
				<div class="filter-group">
					<label for="categoryFilter">Subject</label>
					<select id="categoryFilter" class="filter-select">
						<option value="">All Subjects</option>
						{categories?.map(cat => (
							<option value={cat.slug}>{cat.icon} {cat.name}</option>
						))}
					</select>
				</div>
				<div class="filter-group">
					<label for="levelFilter">Level</label>
					<select id="levelFilter" class="filter-select">
						<option value="">All Levels</option>
						<option value="Beginner">Beginner</option>
						<option value="Intermediate">Intermediate</option>
						<option value="Advanced">Advanced</option>
					</select>
				</div>
				<div class="filter-group">
					<label for="priceFilter">Price</label>
					<select id="priceFilter" class="filter-select">
						<option value="">All Prices</option>
						<option value="Free">Free Only</option>
						<option value="Paid">Paid</option>
					</select>
				</div>
				<div class="filter-group">
					<label for="sortFilter">Sort By</label>
					<select id="sortFilter" class="filter-select">
						<option value="featured">Featured</option>
						<option value="popularity">Popularity</option>
						<option value="price-low">Price: Low to High</option>
						<option value="price-high">Price: High to Low</option>
					</select>
				</div>
				<div class="results-count">
					Showing <span id="courseCount">{coursesData.length}</span> courses
				</div>
			</div>

			<!-- Course Cards Grid -->
			<div class="unified-grid" id="coursesGrid">
				{coursesData.map(course => (
					<a
						href={course.course_url || '#'}
						target="_blank"
						rel="noopener noreferrer"
						class="card"
						data-course-id={course.id}
						data-category={course.course_categories?.slug}
						data-level={course.level}
						data-price={course.price}
						data-popularity={course.colleges?.popularity_score}
						data-featured={course.featured}
						data-created={course.created_at}
					>
						<div class="card-image">
							<img
								src={course.image_url || 'https://images.pexels.com/photos/267885/pexels-photo-267885.jpeg?auto=compress&cs=tinysrgb&w=800'}
								alt={course.title}
								loading="lazy"
							/>
							{course.featured && <span class="badge-featured">Featured</span>}
							{course.price === 'Free'
								? <span class="badge-price free">Free</span>
								: course.price && <span class="badge-price">{course.price}</span>
							}
						</div>
						<div class="card-body">
							<span class="card-label">
								{course.course_categories ? `${course.course_categories.icon ?? ''} ${course.course_categories.name}` : 'Course'}
							</span>
							<h3 class="card-title">{course.title}</h3>
							{course.colleges && <p class="card-brand">{course.colleges.name}</p>}
							<p class="card-excerpt">
								{course.short_description || course.description?.slice(0, 160)}
							</p>
							<span class="card-cta">View program →</span>
						</div>
					</a>
				))}
			</div>

			<div class="no-results" id="noResults" style="display:none;">
				<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
				</svg>
				<h3>No courses found</h3>
				<p>Try adjusting your filters or search terms</p>
			</div>

		</div>
	</div>

	<!-- From Our Blog -->
	{latestPosts.length > 0 && (
	<div class="blog-section">
		<div class="container">
			<div class="blog-header">
				<div>
					<h2>From Our Blog</h2>
					<p>Guides and insights to help you succeed in online learning</p>
				</div>
				<a href="/blog" class="view-all">View all articles →</a>
			</div>
			<div class="blog-grid">
				{latestPosts.map((post) => (
					<a href={`/blog/${post.slug}`} class="card">
						{post.data.image && (
							<div class="card-image">
								<img src={post.data.image} alt={post.data.title} loading="lazy" />
							</div>
						)}
						<div class="card-body">
							{post.data.tags && post.data.tags.length > 0 && (
								<span class="card-label">{post.data.tags[0]}</span>
							)}
							<h3 class="card-title">{post.data.title}</h3>
							<p class="card-excerpt">{post.data.description}</p>
							<div class="card-meta">
								<span>{formatDate(post.data.pubDate)}</span>
								{post.data.author && <><span class="dot">·</span><span>{post.data.author}</span></>}
							</div>
							<span class="card-cta">Read article →</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</div>
	)}

	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "EducationalOrganization",
		"name": "Online College Courses",
		"description": "Directory of online college courses from accredited institutions",
		"url": "https://onlinecourses.edu",
		"offers": coursesData.slice(0, 10).map(course => ({
			"@type": "Course",
			"name": course.title,
			"description": course.description,
			"provider": {
				"@type": "Organization",
				"name": course.colleges?.name
			}
		}))
	})} />

</Layout>

<style>
	/* ── Page Header ── */
	.page-header {
		background: linear-gradient(135deg, #0d9488 0%, #0891b2 100%);
		color: white;
		padding: 3rem 0 2.5rem;
		text-align: center;
	}

	.page-header h1 {
		color: white;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-bottom: 0.375rem;
		line-height: 1.2;
	}

	.motto {
		font-size: 1.125rem;
		color: rgba(255,255,255,0.9);
		font-weight: 500;
		letter-spacing: 0.01em;
		margin-bottom: 1.75rem;
	}

	.search-wrapper {
		max-width: 520px;
		margin: 0 auto;
	}

	.search-box {
		position: relative;
		display: flex;
		align-items: center;
	}

	.search-icon {
		position: absolute;
		left: 1.125rem;
		color: #64748b;
		pointer-events: none;
		z-index: 1;
	}

	#searchInput {
		width: 100%;
		padding: 0.9375rem 1.25rem 0.9375rem 3rem;
		font-size: 1rem;
		border: none;
		border-radius: 50px;
		background: rgba(255,255,255,0.97);
		color: #0f172a;
		box-shadow: 0 4px 20px rgba(0,0,0,0.15);
		transition: box-shadow 0.2s;
		font-family: 'Inter', sans-serif;
	}

	#searchInput::placeholder { color: #94a3b8; }
	#searchInput:focus {
		outline: none;
		background: white;
		box-shadow: 0 4px 28px rgba(0,0,0,0.22);
	}

	/* ── Container ── */
	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ── Unified Section ── */
	.unified-section {
		padding: 2.5rem 0 3rem;
	}

	.section-heading {
		margin-bottom: 1.5rem;
	}

	.section-heading h2 {
		font-size: 1.875rem;
		font-weight: 800;
		color: #0f172a;
		letter-spacing: -0.03em;
		margin-bottom: 0.375rem;
	}

	.section-heading p {
		font-size: 1rem;
		color: #64748b;
		margin: 0;
	}

	/* ── Filters Bar ── */
	.filters-bar {
		display: flex;
		align-items: flex-end;
		gap: 1rem;
		flex-wrap: wrap;
		background: white;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 1.25rem 1.5rem;
		margin-bottom: 2rem;
		box-shadow: 0 1px 4px rgba(0,0,0,0.05);
	}

	.filter-group {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		min-width: 140px;
	}

	.filter-group label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #64748b;
	}

	.filter-select {
		padding: 0.5rem 0.75rem;
		border: 1.5px solid #e2e8f0;
		border-radius: 8px;
		font-size: 0.9rem;
		color: #334155;
		background: white;
		cursor: pointer;
		transition: border-color 0.15s;
		font-family: 'Inter', sans-serif;
	}

	.filter-select:focus {
		outline: none;
		border-color: #0d9488;
	}

	.results-count {
		font-size: 0.875rem;
		color: #64748b;
		margin-left: auto;
		align-self: flex-end;
		padding-bottom: 0.5rem;
		white-space: nowrap;
	}

	#courseCount {
		font-weight: 700;
		color: #0d9488;
	}

	/* ── Card Grid ── */
	.unified-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 1.5rem;
		align-items: start;
	}

	/* ── Card ── */
	.card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		height: 100%;
	}

	.card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0,0,0,0.10);
		border-color: #0d9488;
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 200px;
		overflow: hidden;
		background: #f1f5f9;
		flex-shrink: 0;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.card:hover .card-image img { transform: scale(1.06); }

	.badge-featured {
		position: absolute;
		top: 10px;
		left: 10px;
		padding: 3px 9px;
		background: linear-gradient(135deg, #f59e0b, #ea580c);
		color: white;
		font-size: 0.65rem;
		font-weight: 700;
		border-radius: 5px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.badge-price {
		position: absolute;
		top: 10px;
		right: 10px;
		padding: 3px 9px;
		background: rgba(15,23,42,0.75);
		color: white;
		font-size: 0.75rem;
		font-weight: 700;
		border-radius: 5px;
		backdrop-filter: blur(6px);
	}

	.badge-price.free {
		background: linear-gradient(135deg, #10b981, #059669);
	}

	.card-body {
		padding: 1.25rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #0d9488;
		margin-bottom: 0.5rem;
		display: inline-block;
	}

	.card-title {
		font-size: 1.125rem;
		font-weight: 700;
		color: #0f172a;
		line-height: 1.4;
		margin-bottom: 0.375rem;
		letter-spacing: -0.02em;
	}

	.card:hover .card-title { color: #0d9488; }

	.card-brand {
		font-size: 0.85rem;
		color: #94a3b8;
		margin-bottom: 0.5rem;
		font-weight: 500;
	}

	.card-excerpt {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
		margin-bottom: 1rem;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8rem;
		color: #94a3b8;
		margin-bottom: 0.75rem;
	}

	.dot { opacity: 0.5; }

	.card-cta {
		font-size: 0.875rem;
		font-weight: 600;
		color: #0d9488;
		transition: color 0.2s;
		margin-top: auto;
	}

	.card:hover .card-cta { color: #0f766e; }

	/* ── No Results ── */
	.no-results {
		text-align: center;
		padding: 5rem 0;
		color: #94a3b8;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.no-results h3 { font-size: 1.25rem; color: #475569; }
	.no-results p { font-size: 0.9375rem; color: #94a3b8; }

	/* ── Blog Section ── */
	.blog-section {
		background: #f8fafc;
		border-top: 1px solid #e2e8f0;
		padding: 3rem 0 4rem;
		margin-top: 1rem;
	}

	.blog-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-bottom: 1.75rem;
		gap: 1rem;
	}

	.blog-header h2 {
		font-size: 1.875rem;
		font-weight: 800;
		color: #0f172a;
		letter-spacing: -0.03em;
		margin-bottom: 0.25rem;
	}

	.blog-header p {
		font-size: 1rem;
		color: #64748b;
		margin: 0;
	}

	.view-all {
		font-size: 0.9375rem;
		font-weight: 600;
		color: #0d9488;
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.view-all:hover { color: #0f766e; }

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.blog-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 768px) {
		.unified-grid { grid-template-columns: 1fr; }
		.blog-grid { grid-template-columns: 1fr; }
		.filters-bar { flex-direction: column; align-items: stretch; }
		.results-count { margin-left: 0; }
		.blog-header { flex-direction: column; align-items: flex-start; }
	}
</style>

<script>
	const coursesData = JSON.parse(document.getElementById('coursesData')?.textContent || '[]');
	let filteredCourses = [...coursesData];

	const coursesGrid = document.getElementById('coursesGrid');
	const noResults = document.getElementById('noResults');
	const courseCount = document.getElementById('courseCount');

	const searchInput = document.getElementById('searchInput') as HTMLInputElement;
	const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement;
	const sortFilter = document.getElementById('sortFilter') as HTMLSelectElement;
	const levelFilter = document.getElementById('levelFilter') as HTMLSelectElement;
	const priceFilter = document.getElementById('priceFilter') as HTMLSelectElement;

	let searchQuery = '';

	function filterAndSort() {
		filteredCourses = coursesData.filter((course: any) => {
			const matchesSearch = searchQuery === '' ||
				course.title?.toLowerCase().includes(searchQuery) ||
				course.description?.toLowerCase().includes(searchQuery) ||
				course.colleges?.name?.toLowerCase().includes(searchQuery) ||
				course.course_categories?.name?.toLowerCase().includes(searchQuery);

			const matchesCategory = !categoryFilter?.value ||
				course.course_categories?.slug === categoryFilter.value;

			const matchesLevel = !levelFilter?.value || course.level === levelFilter.value;

			const matchesPrice = !priceFilter?.value ||
				(priceFilter.value === 'Free' && course.price === 'Free') ||
				(priceFilter.value === 'Paid' && course.price !== 'Free');

			return matchesSearch && matchesCategory && matchesLevel && matchesPrice;
		});

		const sortValue = sortFilter?.value || 'featured';
		filteredCourses.sort((a: any, b: any) => {
			if (sortValue === 'popularity') return (b.colleges?.popularity_score || 0) - (a.colleges?.popularity_score || 0);
			if (sortValue === 'price-low') return (a.price_numeric || 0) - (b.price_numeric || 0);
			if (sortValue === 'price-high') return (b.price_numeric || 0) - (a.price_numeric || 0);
			if (b.featured !== a.featured) return b.featured ? 1 : -1;
			return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
		});

		if (courseCount) courseCount.textContent = filteredCourses.length.toString();

		if (filteredCourses.length === 0) {
			if (coursesGrid) coursesGrid.style.display = 'none';
			if (noResults) noResults.style.display = 'flex';
		} else {
			if (coursesGrid) coursesGrid.style.display = 'grid';
			if (noResults) noResults.style.display = 'none';
			coursesGrid?.querySelectorAll('.card').forEach((card) => {
				const id = (card as HTMLElement).dataset.courseId;
				(card as HTMLElement).style.display = filteredCourses.some((c: any) => c.id === id) ? 'flex' : 'none';
			});
		}
	}

	searchInput?.addEventListener('input', (e) => {
		searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
		filterAndSort();
	});

	categoryFilter?.addEventListener('change', filterAndSort);
	sortFilter?.addEventListener('change', filterAndSort);
	levelFilter?.addEventListener('change', filterAndSort);
	priceFilter?.addEventListener('change', filterAndSort);
</script>

<script id="coursesData" type="application/json" set:html={JSON.stringify(coursesData)} />
