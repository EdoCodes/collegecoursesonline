---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { supabase, isSupabaseConfigured } from '../lib/supabase';
import type { Course } from '../lib/supabase';
import { resolveCourseImageUrl } from '../lib/courseImageOverrides';
import CoursePrice from '../components/CoursePrice.astro';
import { filterDirectoryCourses } from '../lib/excludedCourseSlugs';
import {
	resourcesBlogPosts,
	type ResourcesBlogPost,
	getResourcesBlogPostHref,
	resourcesGuidesIndexPath,
} from '../data/resourcesBlogPosts';

let coursesData: Course[] = [];
let featuredCourses: Course[] = [];
let categories: any[] = [];

if (isSupabaseConfigured && supabase) {
	const { data: courses } = await supabase
		.from('courses')
		.select(`*, colleges (*), course_categories (*)`)
		.order('featured', { ascending: false })
		.order('created_at', { ascending: false })
		.limit(50);

	coursesData = filterDirectoryCourses(courses || []);
	featuredCourses = coursesData.filter(c => c.featured).slice(0, 3);

	const { data: cats } = await supabase
		.from('course_categories')
		.select('*')
		.order('name');

	categories = cats || [];
}

// Fallback static categories (shown in filter even if Supabase is empty)
if (categories.length === 0) {
	categories = [
	{ slug: 'business',        name: 'Business',          icon: '💼' },
	{ slug: 'computer-science',name: 'Computer Science',  icon: '💻' },
	{ slug: 'data-science',    name: 'Data Science',      icon: '📊' },
	{ slug: 'education',       name: 'Education',         icon: '🎓' },
	{ slug: 'engineering',     name: 'Engineering',       icon: '⚙️' },
	{ slug: 'health',          name: 'Health & Medicine', icon: '🏥' },
	{ slug: 'humanities',      name: 'Humanities',        icon: '📚' },
	{ slug: 'mathematics',     name: 'Mathematics',       icon: '➗' },
	{ slug: 'psychology',      name: 'Psychology',        icon: '🧠' },
	{ slug: 'science',         name: 'Natural Sciences',  icon: '🔬' },
	];
}

const _staticCoursesData = [
	{
		id: '1',
		slug: 'straighterline-introductory-algebra',
		featured: true,
		title: 'Introductory Algebra (MAT099)',
		short_description: 'ACE-recommended college prep algebra — self-paced, transfers to 3,000+ schools.',
		course_url: 'https://www.straighterline.com/online-college-courses/introductory-algebra/',
		image_url: '/images/courses/straighterline-introductory-algebra.png',
		level: 'Beginner',
		price: '$79',
		price_numeric: 79,
		certificate_available: true,
		credits: 'ACE-recommended (non-credit prep)',
		created_at: '2024-03-01T00:00:00Z',
		colleges: {
			name: 'StraighterLine',
			slug: 'straighterline',
			accreditation_level: 'National',
			popularity_score: 87,
			ease_of_access_score: 98,
		},
		course_categories: { slug: 'mathematics', name: 'Mathematics', icon: '➗' },
	},
	{
		id: '2',
		slug: 'sophia-anatomy-physiology-1',
		featured: true,
		title: 'Anatomy and Physiology I',
		short_description: 'ACE & DEAC-recommended A&P I — 3 credits, self-paced, free trial.',
		course_url: 'https://www.sophia.org/online-courses/science/anatomy-and-physiology-i/',
		image_url: '/images/courses/sophia-anatomy-physiology-1.png',
		level: 'Introductory',
		price: 'Free trial',
		price_numeric: 0,
		certificate_available: true,
		credits: '3 credits (ACE & DEAC-recommended)',
		created_at: '2024-03-02T00:00:00Z',
		colleges: {
			name: 'Sophia Learning',
			slug: 'sophia-learning',
			accreditation_level: 'National',
			popularity_score: 88,
			ease_of_access_score: 97,
		},
		course_categories: { slug: 'health', name: 'Health & Medicine', icon: '🏥' },
	},
	{
		id: '3',
		slug: 'straighterline-anatomy-physiology-1-lab',
		featured: false,
		title: 'Anatomy & Physiology I Lab (BIO201L)',
		short_description: 'Hands-on at-home lab — ACE-recommended, 1 credit, kit required.',
		course_url: 'https://www.straighterline.com/online-college-courses/anatomy-physiology-i-lab/',
		image_url: '/images/courses/straighterline-anatomy-physiology-1-lab.png',
		level: 'Introductory',
		price: '$69',
		price_numeric: 69,
		certificate_available: true,
		credits: '1 credit (ACE-recommended)',
		created_at: '2024-03-03T00:00:00Z',
		colleges: {
			name: 'StraighterLine',
			slug: 'straighterline',
			accreditation_level: 'National',
			popularity_score: 87,
			ease_of_access_score: 98,
		},
		course_categories: { slug: 'health', name: 'Health & Medicine', icon: '🏥' },
	},
];
// _staticCoursesData is kept as reference only — not used when Supabase is live

// Homepage articles: left column = three guides; right = one large featured guide (see resourcesBlogPosts.ts)
const HOW_TO_CHOOSE_SLUG = 'how-to-choose-right-online-college';
const HOMEPAGE_FEATURED_SLUG = 'prerequisite-courses-for-nursing-school';

const HOMEPAGE_SIDE_SLUGS = [
	'campus-edu-review',
	'fafsa-financial-aid-online-college-degrees',
	'international-students-online-us-colleges',
] as const;

const homepageFeaturedPost =
	resourcesBlogPosts.find((p) => p.slug === HOMEPAGE_FEATURED_SLUG) ??
	resourcesBlogPosts.find((p) => p.slug === HOW_TO_CHOOSE_SLUG) ??
	resourcesBlogPosts[0];

const homepageSidePosts = HOMEPAGE_SIDE_SLUGS.map((slug) =>
	resourcesBlogPosts.find((p) => p.slug === slug),
).filter((p): p is ResourcesBlogPost => p != null);
---

<Layout>
	<Hero />

	{featuredCourses.length > 0 && (
		<section class="featured-section">
			<div class="container">
				<div class="section-heading">
					<h2>Featured Courses</h2>
					<p>Hand-picked programs from top institutions</p>
				</div>
				<div class="unified-grid">
					{featuredCourses.map(course => (
						<a href={`/courses/${course.slug}`} class="card" data-course-id={course.id} data-category={course.course_categories?.slug} data-level={course.level} data-price={course.price} data-certificate={course.certificate_available} data-accreditation={course.colleges?.accreditation_level} data-popularity={course.colleges?.popularity_score} data-ease={course.colleges?.ease_of_access_score} data-featured={course.featured} data-created={course.created_at}>
							<div class="card-image">
								<img
									src={resolveCourseImageUrl(course.slug, course.image_url)}
									alt={course.title}
									loading="lazy"
								/>
								<span class="card-badge-featured">Featured</span>
								{course.price === 'Free'
									? <span class="card-badge-price free">Free</span>
									: course.price && <span class="card-badge-price"><CoursePrice price={course.price} colleges={course.colleges} courseSlug={course.slug} /></span>
								}
							</div>
							<div class="card-body">
								<span class="card-label">
									{course.course_categories ? `${course.course_categories.icon ?? ''} ${course.course_categories.name}` : 'Course'}
								</span>
								<h3 class="card-title">{course.title}</h3>
								{course.colleges && <p class="card-brand">{course.colleges.name}</p>}
								<p class="card-excerpt">
									{course.short_description || course.description?.slice(0, 160)}
								</p>
								<span class="card-cta">View program →</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<section class="blog-section" aria-labelledby="home-featured-articles-heading">
		<div class="container">
			<div class="blog-header">
				<h2 id="home-featured-articles-heading">Featured education articles</h2>
				<a href={resourcesGuidesIndexPath} class="blog-view-all">View all guides →</a>
			</div>
			<div class="blog-layout">
				<div class="blog-list">
					{homepageSidePosts.map((post) => (
						<a href={getResourcesBlogPostHref(post)} class="blog-list-item">
							<div
								class:list={[
									'blog-list-img',
									post.imageObjectFit === 'contain' && post.imageContainVariant === 'white' && 'blog-list-img--contain-white',
									post.imageObjectFit === 'contain' && post.imageContainVariant === 'blue' && 'blog-list-img--contain-blue',
								]}
							>
								<img src={post.image} alt={post.imageAlt ?? post.title} loading="lazy" decoding="async" />
							</div>
							<div class="blog-list-body">
								<h3 class="blog-list-title">{post.title}</h3>
								<p class="blog-list-excerpt">{post.excerpt}</p>
							</div>
						</a>
					))}
				</div>
				<a
					href={getResourcesBlogPostHref(homepageFeaturedPost)}
					class:list={[
						'blog-featured-card',
						homepageFeaturedPost.imageObjectFit === 'contain' &&
							homepageFeaturedPost.imageContainVariant === 'white' &&
							'blog-featured-card--light-img',
					]}
				>
					<div class="blog-featured-img">
						<img
							src={homepageFeaturedPost.image}
							alt={homepageFeaturedPost.imageAlt ?? homepageFeaturedPost.title}
							loading="lazy"
							decoding="async"
						/>
						<div class="blog-featured-overlay">
							<div class="blog-featured-body">
								<span class="blog-featured-label">{homepageFeaturedPost.label}</span>
								<h3 class="blog-featured-title">{homepageFeaturedPost.title}</h3>
								<div class="blog-featured-meta">
									<span class="blog-featured-author">by Editorial Team</span>
									<span class="blog-featured-dot">·</span>
									<span class="blog-featured-time">{homepageFeaturedPost.readingTime}</span>
								</div>
							</div>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<main class="main-content">
		<div class="container">
			<section class="filters-section">
				<div class="filters-header">
					<h2>Browse Courses</h2>
					<div class="results-count" id="resultsCount">
						Showing <span id="courseCount">{coursesData.length}</span> courses
					</div>
				</div>

				<div class="search-box">
					<svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
						<circle cx="9" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
						<path d="M13 13L17 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
					</svg>
					<input
						type="text"
						id="searchInput"
						placeholder="Search for courses (e.g., Algebra, Computer Science)..."
						class="search-input"
					/>
				</div>

				<div class="filters">
					<div class="filter-group">
						<label for="categoryFilter">Subject</label>
						<select id="categoryFilter" class="filter-select">
							<option value="">All Subjects</option>
							{categories?.map(cat => (
								<option value={cat.slug}>{cat.icon} {cat.name}</option>
							))}
						</select>
					</div>

					<div class="filter-group">
						<label for="sortFilter">Sort By</label>
						<select id="sortFilter" class="filter-select">
							<option value="featured">Featured</option>
							<option value="popularity">Popularity</option>
							<option value="price-low">Price: Low to High</option>
							<option value="price-high">Price: High to Low</option>
							<option value="ease">Ease of Access</option>
							<option value="accreditation">Accreditation</option>
						</select>
					</div>

					<div class="filter-group">
						<label for="levelFilter">Level</label>
						<select id="levelFilter" class="filter-select">
							<option value="">All Levels</option>
							<option value="Beginner">Beginner</option>
							<option value="Intermediate">Intermediate</option>
							<option value="Advanced">Advanced</option>
						</select>
					</div>

					<div class="filter-group">
						<label for="priceFilter">Price</label>
						<select id="priceFilter" class="filter-select">
							<option value="">All Prices</option>
							<option value="Free">Free Only</option>
							<option value="Paid">Paid</option>
						</select>
					</div>

					<div class="filter-group">
						<label for="certificateFilter">Transcript</label>
						<select id="certificateFilter" class="filter-select">
							<option value="">All</option>
							<option value="true">Transcript available upon completion</option>
						</select>
					</div>

					<div class="filter-group">
						<label for="accreditationFilter">Accreditation</label>
						<select id="accreditationFilter" class="filter-select">
							<option value="">All Types</option>
							<option value="Regional">Regional</option>
							<option value="National">National</option>
							<option value="International">International</option>
						</select>
					</div>
				</div>
			</section>

			<section class="courses-section">
				<div class="courses-grid" id="coursesGrid">
				{coursesData.map(course => (
					<a href={`/courses/${course.slug}`} class="card" data-course-id={course.id} data-category={course.course_categories?.slug} data-level={course.level} data-price={course.price} data-certificate={course.certificate_available} data-accreditation={course.colleges?.accreditation_level} data-popularity={course.colleges?.popularity_score} data-ease={course.colleges?.ease_of_access_score} data-featured={course.featured} data-created={course.created_at}>
							<div class="card-image">
								<img
									src={resolveCourseImageUrl(course.slug, course.image_url)}
									alt={course.title}
									loading="lazy"
								/>
								{course.price === 'Free'
									? <span class="card-badge-price free">Free</span>
									: course.price && <span class="card-badge-price"><CoursePrice price={course.price} colleges={course.colleges} courseSlug={course.slug} /></span>
								}
							</div>
							<div class="card-body">
								<span class="card-label">
									{course.course_categories ? `${course.course_categories.icon ?? ''} ${course.course_categories.name}` : 'Course'}
								</span>
								<h3 class="card-title">{course.title}</h3>
								{course.colleges && <p class="card-brand">{course.colleges.name}</p>}
								<p class="card-excerpt">
									{course.short_description || course.description?.slice(0, 160)}
								</p>
								<span class="card-cta">View program →</span>
							</div>
						</a>
					))}
				</div>

				<div class="no-results" id="noResults" style="display: none;">
					<svg width="120" height="120" viewBox="0 0 120 120" fill="none">
						<circle cx="60" cy="60" r="50" fill="#f5f5f5"/>
						<path d="M45 50C45 47.2386 47.2386 45 50 45H70C72.7614 45 75 47.2386 75 50V70C75 72.7614 72.7614 75 70 75H50C47.2386 75 45 72.7614 45 70V50Z" stroke="#a3a3a3" stroke-width="3"/>
						<circle cx="55" cy="57" r="3" fill="#a3a3a3"/>
						<circle cx="65" cy="57" r="3" fill="#a3a3a3"/>
						<path d="M52 67C52 67 56 63 60 63C64 63 68 67 68 67" stroke="#a3a3a3" stroke-width="3" stroke-linecap="round"/>
					</svg>
					<h3>No courses found</h3>
					<p>Try adjusting your filters or search terms</p>
				</div>
			</section>
		</div>
	</main>

	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "EducationalOrganization",
		"name": "Online College Courses",
		"description": "Directory of online college courses from accredited institutions",
		"url": "https://onlinecourses.edu",
		"offers": coursesData.slice(0, 10).map(course => ({
			"@type": "Course",
			"name": course.title,
			"description": course.short_description,
			"provider": {
				"@type": "Organization",
				"name": course.colleges?.name
			}
		}))
	})} />
</Layout>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		height: 100%;
	}

	.card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.10);
		border-color: #2563eb;
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 200px;
		overflow: hidden;
		background: #f1f5f9;
		flex-shrink: 0;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.card:hover .card-image img {
		transform: scale(1.06);
	}

	.card-body {
		padding: 1.25rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #2563eb;
		margin-bottom: 0.5rem;
		display: inline-block;
	}

	.card-title {
		font-family: 'Inter', sans-serif;
		font-size: 1.125rem;
		font-weight: 700;
		color: #0f172a;
		line-height: 1.4;
		margin-bottom: 0.625rem;
		letter-spacing: -0.02em;
	}

	.card:hover .card-title {
		color: #2563eb;
	}

	.card-brand {
		font-size: 0.85rem;
		color: #94a3b8;
		margin-bottom: 0.625rem;
		font-weight: 500;
	}

	.card-excerpt {
		font-size: 0.875rem;
		color: #334155;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
		margin-bottom: 1rem;
	}

	.card-cta {
		font-size: 0.875rem;
		font-weight: 600;
		color: #2563eb;
		transition: color 0.2s;
		margin-top: auto;
	}

	.card:hover .card-cta {
		color: #1d4ed8;
	}

	.card-badge-featured {
		position: absolute;
		top: 12px;
		left: 12px;
		padding: 4px 10px;
		background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
		color: white;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border-radius: 6px;
	}

	/* ── Featured Section ─────────────────────────────────────────────────── */
	.featured-section {
		padding: calc(var(--spacing) * 8) 0 calc(var(--spacing) * 4);
		background: linear-gradient(180deg, #f8faff 0%, #ffffff 100%);
	}

	.section-heading {
		margin-bottom: calc(var(--spacing) * 5);
	}

	.section-heading h2 {
		font-size: 2rem;
		font-weight: 800;
		color: var(--neutral-900);
		letter-spacing: -0.03em;
		margin-bottom: 0.35rem;
	}

	.section-heading p {
		font-size: 1rem;
		color: var(--neutral-500);
	}

	.unified-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 1.5rem;
	}

	@media (max-width: 768px) {
		.unified-grid { grid-template-columns: 1fr; }
		.featured-section { padding: calc(var(--spacing) * 5) 0 calc(var(--spacing) * 3); }
		.section-heading h2 { font-size: 1.5rem; }
	}

	.card-badge-price {
		position: absolute;
		top: 12px;
		right: 12px;
		padding: 4px 10px;
		background: rgba(15, 23, 42, 0.80);
		color: white;
		font-size: 0.8rem;
		font-weight: 700;
		border-radius: 6px;
		backdrop-filter: blur(8px);
	}

	.card-badge-price.free {
		background: linear-gradient(135deg, #10b981 0%, #059669 100%);
	}

	/* ── Featured education articles (Resources guides) ─────────────────── */
	.blog-section {
		padding: 4rem 0;
		background: #fff;
		border-top: 1px solid #f1f5f9;
	}

	.blog-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.75rem;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.blog-header h2 {
		font-size: 1.375rem;
		font-weight: 700;
		color: #1e40af;
		letter-spacing: -0.01em;
	}

	.blog-view-all {
		font-size: 0.9rem;
		font-weight: 600;
		color: #2563eb;
		text-decoration: none;
		white-space: nowrap;
	}

	.blog-view-all:hover {
		text-decoration: underline;
	}

	.blog-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		align-items: start;
	}

	.blog-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.blog-list-item {
		display: grid;
		grid-template-columns: 96px 1fr;
		gap: 1rem;
		text-decoration: none;
		color: inherit;
		align-items: start;
	}

	.blog-list-img {
		width: 96px;
		height: 72px;
		border-radius: 8px;
		overflow: hidden;
		flex-shrink: 0;
		background: #f1f5f9;
	}

	.blog-list-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.blog-list-item:hover .blog-list-img img {
		transform: scale(1.06);
	}

	.blog-list-img--contain-white,
	.blog-list-img--contain-blue {
		padding: 4px;
		box-sizing: border-box;
	}

	.blog-list-img--contain-white {
		background: #ffffff;
	}

	.blog-list-img--contain-blue {
		background: #eff6ff;
	}

	.blog-list-img--contain-white img,
	.blog-list-img--contain-blue img {
		object-fit: contain;
	}

	.blog-list-item:hover .blog-list-img--contain-white img,
	.blog-list-item:hover .blog-list-img--contain-blue img {
		transform: none;
	}

	.blog-list-body {
		display: flex;
		flex-direction: column;
