	}

	.blog-featured-card--light-img:hover .blog-featured-img img {
		filter: none;
		transform: none;
	}

	.blog-featured-card--light-img .blog-featured-overlay {
		background: linear-gradient(
			to top,
			rgba(15, 23, 42, 0.92) 0%,
			rgba(15, 23, 42, 0.45) 50%,
			transparent 75%
		);
	}

	.blog-featured-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: flex-end;
		padding: 1.75rem;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 60%);
	}

	.blog-featured-body {
		width: 100%;
	}

	.blog-featured-label {
		display: inline-block;
		background: rgba(255, 255, 255, 0.18);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 3px 10px;
		border-radius: 4px;
		margin-bottom: 0.625rem;
		backdrop-filter: blur(4px);
	}

	.blog-featured-title {
		font-size: 1.375rem;
		font-weight: 800;
		color: #ffffff;
		line-height: 1.3;
		letter-spacing: -0.02em;
		margin-bottom: 0.75rem;
	}

	.blog-featured-meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.blog-featured-author,
	.blog-featured-time {
		font-size: 0.8125rem;
		color: rgba(255, 255, 255, 0.8);
		font-weight: 500;
	}

	.blog-featured-dot {
		color: rgba(255, 255, 255, 0.5);
		font-size: 0.8rem;
	}

	@media (max-width: 900px) {
		.blog-layout {
			grid-template-columns: 1fr;
		}
		.blog-featured-card {
			aspect-ratio: 16/9;
		}
	}

	@media (max-width: 600px) {
		.blog-list-img {
			width: 72px;
			height: 56px;
		}
		.blog-list-title {
			font-size: 0.875rem;
		}
	}

	@media (max-width: 768px) {
		.unified-grid,
		.courses-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Main Content */
	.main-content {
		padding: calc(var(--spacing) * 8) 0;
		min-height: 60vh;
	}

	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.filters-section {
		margin-bottom: calc(var(--spacing) * 5);
	}

	.search-box {
		position: relative;
		margin-bottom: calc(var(--spacing) * 3);
	}

	.search-icon {
		position: absolute;
		left: calc(var(--spacing) * 2);
		top: 50%;
		transform: translateY(-50%);
		color: var(--neutral-400);
		pointer-events: none;
	}

	.search-input {
		width: 100%;
		padding: calc(var(--spacing) * 2.5) calc(var(--spacing) * 2.5) calc(var(--spacing) * 2.5) calc(var(--spacing) * 6);
		border: 2px solid var(--neutral-200);
		border-radius: calc(var(--border-radius) * 1.25);
		font-size: 1.125rem;
		color: var(--neutral-800);
		background: white;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
	}

	.search-input:hover {
		border-color: var(--color-primary-light);
		box-shadow: 0 4px 12px rgba(30, 64, 175, 0.08);
	}

	.search-input:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 4px 16px rgba(30, 64, 175, 0.15), 0 0 0 4px rgba(30, 64, 175, 0.1);
	}

	.search-input::placeholder {
		color: var(--neutral-400);
	}

	.filters-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: calc(var(--spacing) * 3);
		flex-wrap: wrap;
		gap: calc(var(--spacing) * 2);
	}

	.filters-header h2 {
		font-size: 2rem;
		color: var(--neutral-900);
	}

	.results-count {
		font-size: 1rem;
		color: var(--neutral-600);
	}

	#courseCount {
		font-weight: 600;
		color: var(--color-primary);
	}

	.filters {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: calc(var(--spacing) * 2);
		padding: calc(var(--spacing) * 4);
		background: white;
		border-radius: calc(var(--border-radius) * 1.25);
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
		border: 1px solid var(--neutral-100);
	}

	.filter-group label {
		display: block;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--neutral-700);
		margin-bottom: calc(var(--spacing) * 1);
	}

	.filter-select {
		width: 100%;
		padding: calc(var(--spacing) * 1.75);
		border: 2px solid var(--neutral-200);
		border-radius: calc(var(--border-radius) * 0.75);
		font-size: 1rem;
		color: var(--neutral-800);
		background: white;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		cursor: pointer;
	}

	.filter-select:hover {
		border-color: var(--color-primary-light);
		box-shadow: 0 2px 8px rgba(30, 64, 175, 0.06);
	}

	.filter-select:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 2px 12px rgba(30, 64, 175, 0.12), 0 0 0 3px rgba(30, 64, 175, 0.1);
	}

	.courses-section {
		position: relative;
	}

	.courses-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 1.5rem;
		margin-bottom: calc(var(--spacing) * 5);
	}

	.no-results {
		text-align: center;
		padding: calc(var(--spacing) * 10) 0;
	}

	.no-results svg {
		margin: 0 auto calc(var(--spacing) * 3);
	}

	.no-results h3 {
		font-size: 1.5rem;
		color: var(--neutral-700);
		margin-bottom: calc(var(--spacing) * 1);
	}

	.no-results p {
		font-size: 1rem;
		color: var(--neutral-500);
	}

	@media (max-width: 768px) {
		.main-content {
			padding: calc(var(--spacing) * 5) 0;
		}

		.filters-header h2 {
			font-size: 1.5rem;
		}

		.filters {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const coursesGrid = document.getElementById('coursesGrid') as HTMLElement | null;
	const noResults   = document.getElementById('noResults')   as HTMLElement | null;
	const courseCount = document.getElementById('courseCount') as HTMLElement | null;

	const searchInput        = document.getElementById('searchInput')        as HTMLInputElement  | null;
	const categoryFilter     = document.getElementById('categoryFilter')     as HTMLSelectElement | null;
	const sortFilter         = document.getElementById('sortFilter')         as HTMLSelectElement | null;
	const levelFilter        = document.getElementById('levelFilter')        as HTMLSelectElement | null;
	const priceFilter        = document.getElementById('priceFilter')        as HTMLSelectElement | null;
	const certificateFilter  = document.getElementById('certificateFilter')  as HTMLSelectElement | null;
	const accreditationFilter= document.getElementById('accreditationFilter')as HTMLSelectElement | null;

	// Collect all cards once; read everything we need from data-* attributes
	const allCards = Array.from(coursesGrid?.querySelectorAll<HTMLElement>('.card') ?? []);

	// Build a lightweight index from the data-* attributes already on each card
	interface CardMeta {
		el: HTMLElement;
		title: string;
		brand: string;
		category: string;
		categorySlug: string;
		label: string;
		excerpt: string;
		level: string;
		price: string;
		priceNumeric: number;
		certificate: boolean;
		accreditation: string;
		popularity: number;
		ease: number;
		featured: boolean;
		created: number;
	}

	const cardMeta: CardMeta[] = allCards.map(el => ({
		el,
		title:        el.querySelector('.card-title')?.textContent?.toLowerCase() ?? '',
		brand:        el.querySelector('.card-brand')?.textContent?.toLowerCase() ?? '',
		category:     el.dataset.category ?? '',
		categorySlug: (el.dataset.category ?? '').toLowerCase(),
		label:        el.querySelector('.card-label')?.textContent?.toLowerCase() ?? '',
		excerpt:      el.querySelector('.card-excerpt')?.textContent?.toLowerCase() ?? '',
		level:        el.dataset.level ?? '',
		price:        el.dataset.price ?? '',
		priceNumeric: parseFloat(el.dataset.price?.replace(/[^0-9.]/g, '') || '0') || 0,
		certificate:  el.dataset.certificate === 'true',
		accreditation:el.dataset.accreditation ?? '',
		popularity:   parseFloat(el.dataset.popularity ?? '0'),
		ease:         parseFloat(el.dataset.ease ?? '0'),
		featured:     el.dataset.featured === 'true',
		created:      new Date(el.dataset.created ?? 0).getTime(),
	}));

	let visibleMeta = [...cardMeta];

	function applyFilters() {
		const q     = searchInput?.value.trim().toLowerCase() ?? '';
		const cat   = categoryFilter?.value ?? '';
		const level = levelFilter?.value ?? '';
		const price = priceFilter?.value ?? '';
		const cert  = certificateFilter?.value ?? '';
		const accr  = accreditationFilter?.value ?? '';
		const sort  = sortFilter?.value ?? 'featured';

		visibleMeta = cardMeta.filter(m => {
			if (
				q &&
				!m.title.includes(q) &&
				!m.brand.includes(q) &&
				!m.categorySlug.includes(q) &&
				!m.label.includes(q) &&
				!m.excerpt.includes(q)
			) {
				return false;
			}
			if (cat   && m.category     !== cat)   return false;
			if (level && m.level        !== level) return false;
			if (price === 'Free' && m.price !== 'Free') return false;
			if (price === 'Paid' && m.price === 'Free') return false;
			if (cert  && !m.certificate)           return false;
			if (accr  && m.accreditation !== accr) return false;
			return true;
		});

		const accOrder: Record<string, number> = { Regional: 3, National: 2, International: 1 };
		visibleMeta.sort((a, b) => {
			switch (sort) {
				case 'popularity':  return b.popularity   - a.popularity;
				case 'price-low':   return a.priceNumeric - b.priceNumeric;
				case 'price-high':  return b.priceNumeric - a.priceNumeric;
				case 'ease':        return b.ease         - a.ease;
				case 'accreditation': return (accOrder[b.accreditation] ?? 0) - (accOrder[a.accreditation] ?? 0);
				default: // featured
					if (b.featured !== a.featured) return b.featured ? 1 : -1;
					return b.created - a.created;
			}
		});

		render();
	}

	function render() {
		const visibleSet = new Set(visibleMeta.map(m => m.el));

		if (courseCount) courseCount.textContent = visibleMeta.length.toString();

		if (visibleMeta.length === 0) {
			if (coursesGrid) coursesGrid.style.display = 'none';
			if (noResults)   noResults.style.display   = 'block';
			return;
		}

		if (coursesGrid) coursesGrid.style.display = 'grid';
		if (noResults)   noResults.style.display   = 'none';

		// Re-order cards in the DOM to match sort order
		visibleMeta.forEach(m => coursesGrid?.appendChild(m.el));

		// Hide cards that don't match filters
		allCards.forEach(el => {
			(el as HTMLElement).style.display = visibleSet.has(el) ? 'flex' : 'none';
		});
	}

	searchInput?.addEventListener('input', applyFilters);
	categoryFilter?.addEventListener('change', applyFilters);
	sortFilter?.addEventListener('change', applyFilters);
	levelFilter?.addEventListener('change', applyFilters);
	priceFilter?.addEventListener('change', applyFilters);
	certificateFilter?.addEventListener('change', applyFilters);
	accreditationFilter?.addEventListener('change', applyFilters);
</script>

