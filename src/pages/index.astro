	}

	.blog-featured-img {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.blog-featured-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: brightness(0.55);
		transition:
			filter 0.3s ease,
			transform 0.3s ease;
	}

	.blog-featured-card:hover .blog-featured-img img {
		filter: brightness(0.45);
		transform: scale(1.03);
	}

	.blog-featured-card--light-img {
		background: #ffffff;
	}

	.blog-featured-card--light-img .blog-featured-img img {
