---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { supabase, isSupabaseConfigured } from '../lib/supabase';
import type { Course } from '../lib/supabase';
import { resolveCourseImageUrl } from '../lib/courseImageOverrides';
import { filterCourses } from '../lib/excludedCourseSlugs';
let coursesData: Course[] = [];
let featuredCourses: Course[] = [];
let categories: any[] = [];

if (isSupabaseConfigured && supabase) {
	const { data: courses } = await supabase
		.from('courses')
		.select(`*, colleges (*), course_categories (*)`)
		.order('featured', { ascending: false })
		.order('created_at', { ascending: false })
		.limit(50);

	coursesData = filterCourses(courses || []);
	featuredCourses = coursesData.filter(c => c.featured).slice(0, 3);

	const { data: cats } = await supabase
		.from('course_categories')
		.select('*')
		.order('name');

	categories = cats || [];
}

// Fallback static categories (shown in filter even if Supabase is empty)
if (categories.length === 0) {
	categories = [
	{ slug: 'business',        name: 'Business',          icon: '💼' },
	{ slug: 'computer-science',name: 'Computer Science',  icon: '💻' },
	{ slug: 'data-science',    name: 'Data Science',      icon: '📊' },
	{ slug: 'education',       name: 'Education',         icon: '🎓' },
	{ slug: 'engineering',     name: 'Engineering',       icon: '⚙️' },
	{ slug: 'health',          name: 'Health & Medicine', icon: '🏥' },
	{ slug: 'humanities',      name: 'Humanities',        icon: '📚' },
	{ slug: 'mathematics',     name: 'Mathematics',       icon: '➗' },
	{ slug: 'psychology',      name: 'Psychology',        icon: '🧠' },
	{ slug: 'science',         name: 'Natural Sciences',  icon: '🔬' },
	];
}

