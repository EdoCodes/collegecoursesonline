---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us | College Courses Online"
  description="Learn about College Courses Online — our mission, editorial standards, and commitment to helping students find the right accredited online programs."
>
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <span class="header-label">About Us</span>
      <h1>Helping Students Find the Right Online Program</h1>
      <p class="subtitle">Independent, data-driven guidance for online learners since 2024.</p>
    </div>
  </div>

  <main class="main-content">
    <div class="container">

      <!-- Mission -->
      <section class="section">
        <div class="section-inner two-col">
          <div class="section-text">
            <h2>Our Mission</h2>
            <p>We are a team of working professionals who earned our accredited degrees through flexible online programs. Drawing from our own experiences balancing careers and education, we created this platform to help other motivated students do the same — advancing their academic goals and accelerating their careers through high-quality, accredited online education.</p>
            <p>This website acts as a trusted bridge between students and reputable accredited institutions. We simplify the process by guiding you in selecting the right courses, majors, online degree programs (Associate’s and Bachelor’s of Science), and professional certifications that align with your ambitions and schedule. Our mission is to make quality education more accessible, efficient, and achievable for busy adults who are ready to invest in their future.</p>
            <p>If you have any questions, please post them in our <a href="/forum">forum</a> or reach out to us directly via <a href="/contact">email</a>. We’re here to help!</p>
          </div>
          <div class="mission-stats">
            <div class="stat-card">
              <span class="stat-number">5,000+</span>
              <span class="stat-label">Courses Listed</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">200+</span>
              <span class="stat-label">Accredited Colleges</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">50+</span>
              <span class="stat-label">Subject Areas</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">10+</span>
              <span class="stat-label">In-Depth Guides</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Editorial Standards -->
      <section class="section section-alt">
        <div class="section-inner">
          <div class="section-header">
            <h2>Editorial Independence</h2>
            <p>We are editorially independent. Our rankings, guides, and course listings are based on publicly available data and our own research — not on payments from institutions.</p>
          </div>
          <div class="standards-grid">
            <div class="standard-card">
              <div class="standard-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9S3 16.97 3 12 7.03 3 12 3s9 4.03 9 9z"/></svg>
              </div>
              <h3>Data-Driven Rankings</h3>
              <p>We use publicly available sources including IPEDS, College Scorecard, and institutional data to evaluate and rank programs.</p>
            </div>
            <div class="standard-card">
              <div class="standard-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              </div>
              <h3>Transparent Advertising</h3>
              <p>Some pages contain affiliate links or sponsored placements. These are clearly labeled and never influence our editorial rankings or recommendations.</p>
            </div>
            <div class="standard-card">
              <div class="standard-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3>Accreditation Focus</h3>
              <p>We only feature programs from regionally or nationally accredited institutions recognized by the U.S. Department of Education.</p>
            </div>
            <div class="standard-card">
              <div class="standard-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              </div>
              <h3>Regularly Updated</h3>
              <p>Tuition data, program availability, and rankings are reviewed and updated regularly to ensure accuracy for prospective students.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Who We Serve -->
      <section class="section">
        <div class="section-inner">
          <div class="section-header">
            <h2>Who We Serve</h2>
            <p>Our platform is built for every type of online learner.</p>
          </div>
          <div class="audience-grid">
            <div class="audience-card">
              <div class="audience-icon">🎓</div>
              <h3>Traditional Students</h3>
              <p>Recent high school graduates exploring flexible degree options that fit around work or family commitments.</p>
            </div>
            <div class="audience-card">
              <div class="audience-icon">💼</div>
              <h3>Working Professionals</h3>
              <p>Adults looking to advance their careers, earn a promotion, or pivot into a new field without leaving their job.</p>
            </div>
            <div class="audience-card">
              <div class="audience-icon">🔄</div>
              <h3>Career Changers</h3>
              <p>People ready to transition into a new industry and looking for the fastest, most affordable path to new credentials.</p>
            </div>
            <div class="audience-card">
              <div class="audience-icon">📚</div>
              <h3>Lifelong Learners</h3>
              <p>Curious minds who want to keep growing, explore new subjects, and stay sharp — with or without a degree goal.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact CTA -->
      <section class="section cta-section">
        <div class="section-inner cta-inner">
          <h2>Have a Question or Want to List a Course?</h2>
          <p class="cta-lead">We welcome submissions from accredited institutions and love hearing from students about their online learning experiences.</p>
          <div class="cta-buttons">
            <a href="/contact" class="btn-primary">Contact Us</a>
            <a href="/forum" class="btn-tertiary">Visit Student Forum</a>
            <a href="/submit-course" class="btn-secondary">Submit a Course</a>
          </div>
          <p class="cta-disclaimer">
            Disclosure: Our site may earn affiliate revenue from advertisements at no cost to the reader. We use that revenue to expand the site and add more informative content and courses.
          </p>
        </div>
      </section>

    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Page Header ── */
  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 4rem 0 3.5rem;
  }

  .header-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.3rem 0.875rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.625rem;
    line-height: 1.15;
    max-width: 700px;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  /* ── Main ── */
  .main-content {
    padding: 0 0 5rem;
  }

  /* ── Sections ── */
  .section {
    padding: 4rem 0;
  }

  .section-alt {
    background: #f8fafc;
    margin: 0 -1.5rem;
    padding: 4rem 1.5rem;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    max-width: 680px;
    margin-bottom: 2.5rem;
  }

  .section-header h2,
  .section-text h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-header p,
  .section-text p {
    font-size: 1.0625rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* ── Two-col layout ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* ── Mission Stats ── */
  .mission-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .stat-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    text-align: center;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: #1e40af;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #64748b;
    font-weight: 500;
  }

  /* ── Standards Grid ── */
  .standards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .standard-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  .standard-icon {
    width: 48px;
    height: 48px;
    background: #eff6ff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1e40af;
    margin-bottom: 1rem;
  }

  .standard-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .standard-card p {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Audience Grid ── */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 2rem 1.5rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }

  .audience-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .audience-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .audience-card p {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA Section ── */
  .cta-section {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 48%, #0ea5e9 100%);
    border-radius: 16px;
    padding: 1.5rem 1.25rem 1.35rem;
    margin-top: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    box-shadow: 0 10px 32px rgba(37, 99, 235, 0.28);
  }

  .cta-inner {
    text-align: center;
  }

  .cta-section h2 {
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    line-height: 1.25;
  }

  .cta-section .cta-lead {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.5;
    margin-bottom: 1.25rem;
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 0.65rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    background: white;
    color: #1d4ed8;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: #f1f5f9;
    transform: translateY(-2px);
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    background: rgba(255,255,255,0.18);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.28);
    transition: background 0.2s, transform 0.2s, border-color 0.2s;
  }

  .btn-tertiary:hover {
    background: rgba(255,255,255,0.24);
    border-color: rgba(255,255,255,0.38);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.35rem;
    background: rgba(255,255,255,0.14);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    transition: background 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-2px);
  }

  .cta-disclaimer {
    margin-top: 1.1rem;
    margin-bottom: 0;
    margin-left: auto;
    margin-right: auto;
    font-family: 'Dancing Script', cursive;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.45;
    max-width: 32rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .standards-grid,
    .audience-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .standards-grid,
    .audience-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .standards-grid,
    .audience-grid,
    .mission-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
