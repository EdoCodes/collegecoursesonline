---
import Layout from '../../layouts/Layout.astro';

const course = {
  title: 'BIO 100 General Biological Science',
  providerName: 'PrereqCourses',
  providerUrl: 'https://www.prereqcourses.com/product/bio-100-general-biological-science/',
  image: '/images/courses/prereqcourses-bio-100.png',
  price: '$675',
  credits: '3 semester hours',
  format: 'Self-paced',
  location: 'Online',
  description:
    'This course presents the basic concepts of biology; it is intended for non-science majors. Recommended to satisfy the general education requirement for science.',
};

const canonical = '/courses/bio-100-general-biological-science-prereqcourses';

const siteUrl = Astro.site || new URL('https://collegecoursesonline.netlify.app');
const fullCourseUrl = new URL(canonical, siteUrl).toString();
const schemaImageUrl = new URL(course.image.replace(/^\//, ''), siteUrl).toString();

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description: course.description,
  provider: {
    '@type': 'Organization',
    name: course.providerName,
    url: course.providerUrl,
  },
  image: schemaImageUrl,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'USD',
    price: '675',
    url: course.providerUrl,
    availability: 'https://schema.org/InStock',
  },
  educationalCredentialAwarded: course.credits,
  courseMode: [course.location, course.format],
  url: fullCourseUrl,
};
---

<Layout
  title={`${course.title} | ${course.providerName} | College Courses Online`}
  description={`${course.title} is a ${course.format.toLowerCase()}, ${course.location.toLowerCase()} course (${course.credits}) from ${course.providerName}.`}
  canonical={canonical}
  image={course.image}
  type="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  </Fragment>

  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/courses">Courses</a>
        <span>›</span>
        <span>{course.title}</span>
      </nav>
      <div class="hero-grid">
        <div class="hero-media">
          <img src={course.image} alt={course.title} loading="eager" decoding="async" />
        </div>
        <div class="hero-content">
          <div class="hero-kicker">Natural Sciences • Biology</div>
          <h1>{course.title}</h1>
          <p class="hero-sub">{course.description}</p>

          <div class="meta">
            <div class="meta-item">
              <div class="meta-label">Provider</div>
              <div class="meta-value">{course.providerName}</div>
            </div>
            <div class="meta-item">
              <div class="meta-label">Credits</div>
              <div class="meta-value">{course.credits}</div>
            </div>
            <div class="meta-item">
              <div class="meta-label">Format</div>
              <div class="meta-value">{course.format}</div>
            </div>
            <div class="meta-item">
              <div class="meta-label">Location</div>
              <div class="meta-value">{course.location}</div>
            </div>
            <div class="meta-item">
              <div class="meta-label">Price</div>
              <div class="meta-value">{course.price}</div>
            </div>
          </div>

          <div class="actions">
            <a class="btn btn-primary" href={course.providerUrl} target="_blank" rel="noopener noreferrer">
              Register on {course.providerName} →
            </a>
            <a class="btn btn-secondary" href="/courses">
              ← Back to all courses
            </a>
          </div>

          <p class="disclaimer">
            Pricing, availability, and transfer policies can change. Always confirm details on the provider’s website.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0f2744 0%, #1d4ed8 100%);
    color: white;
    padding: 3rem 0 2.75rem;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    opacity: 0.9;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(255,255,255,0.92); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb span { opacity: 0.75; }

  .hero-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  .hero-media {
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 14px;
    padding: 0.75rem;
    overflow: hidden;
    box-shadow: 0 18px 60px rgba(0,0,0,0.22);
  }
  .hero-media img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 10px;
  }
  .hero-kicker {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(191, 219, 254, 0.95);
    margin-bottom: 0.6rem;
  }
  .hero-content h1 {
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    line-height: 1.18;
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }
  .hero-sub {
    color: rgba(255,255,255,0.82);
    max-width: 740px;
    margin: 0 0 1.1rem;
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.25rem;
  }
  .meta-item {
    background: rgba(15, 23, 42, 0.28);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
  }
  .meta-label {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(191, 219, 254, 0.9);
    margin-bottom: 0.25rem;
  }
  .meta-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: rgba(255,255,255,0.94);
    line-height: 1.25;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-weight: 800;
    border-radius: 12px;
    padding: 0.75rem 1.05rem;
    text-decoration: none;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: #fff;
    color: #1d4ed8;
  }
  .btn-primary:hover { background: #eff6ff; }
  .btn-secondary {
    background: rgba(15, 23, 42, 0.28);
    border-color: rgba(255,255,255,0.22);
    color: #fff;
  }
  .btn-secondary:hover { background: rgba(15, 23, 42, 0.38); }

  .disclaimer {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.72);
    margin-top: 1.1rem;
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-media img { height: 220px; }
    .meta { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>

