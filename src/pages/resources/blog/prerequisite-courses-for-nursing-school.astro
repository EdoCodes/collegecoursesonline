---
import Layout from '../../../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('blog', 'prerequisite-courses-for-nursing-school');
if (!entry) {
	throw new Error('Blog entry prerequisite-courses-for-nursing-school not found');
}

const { Content } = await entry.render();
const { title, description, pubDate, author, tags, image } = entry.data;

const categoryLabel = entry.data.categoryLabel ?? 'Nursing';
const authorTitle = entry.data.authorTitle ?? 'Editorial';
const breadcrumbTitle = entry.data.breadcrumbTitle ?? title;
const readTimeFromFrontmatter = entry.data.readTime;

const site = Astro.site?.href?.replace(/\/$/, '') ?? 'https://collegecoursesonline.netlify.app';
const slugPath = '/resources/blog/prerequisite-courses-for-nursing-school';
const pageUrl = new URL(slugPath.replace(/^\//, ''), `${site}/`).href;

const publishDate = pubDate.toISOString().slice(0, 10);
const updatedDate =
	entry.data.updatedDate != null
		? entry.data.updatedDate.toISOString().slice(0, 10)
		: publishDate;

const wordCount = entry.body.trim().split(/\s+/).filter(Boolean).length;
const readingTime =
	readTimeFromFrontmatter ?? `${Math.max(1, Math.ceil(wordCount / 200))} min read`;

const ogImageUrl =
	typeof image === 'string' && image.startsWith('http')
		? image
		: image
			? new URL(image, `${site}/`).href
			: `${site}/og-image.jpg`;

const ogImageForLayout =
	typeof image === 'string' && image.startsWith('http') ? image : image ?? '/og-image.jpg';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	image: [ogImageUrl],
	datePublished: publishDate,
	dateModified: updatedDate,
	author: {
		'@type': 'Organization',
		name: author,
	},
	publisher: {
		'@type': 'Organization',
		name: 'College Courses Online',
		url: site,
		logo: {
			'@type': 'ImageObject',
			url: `${site}/favicon.svg`,
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': pageUrl,
	},
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'What are the most common prerequisite courses for nursing school?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'The core prerequisites at most schools include Anatomy and Physiology I and II with lab, Microbiology with lab, General Chemistry with lab, Biology or Human Biology, English Composition, General Psychology, Developmental or Lifespan Psychology, Statistics, and Nutrition. Some programs also require Sociology, Speech, or College Algebra. Requirements differ by school and degree type, so always check each program directly.',
			},
		},
		{
			'@type': 'Question',
			name: 'Do nursing school prerequisites expire?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes, many do. Anatomy and Physiology courses commonly expire after five years, with some programs extending that to ten. Microbiology and Chemistry also frequently carry recency requirements. General education courses like English and Psychology rarely expire. If you completed science prerequisites more than five years ago, contact your target programs before assuming the courses will count.',
			},
		},
		{
			'@type': 'Question',
			name: 'Can I take nursing prerequisites online?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'For general education subjects — English Composition, Psychology, Sociology, and Statistics — online courses are often accepted, including from providers like Sophia Learning and StraighterLine. However, science courses with lab components are frequently required to be completed in-person. Always confirm with the nursing program before enrolling in any online science course.',
			},
		},
		{
			'@type': 'Question',
			name: 'Are there accredited online nursing programs?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. There are many accredited online and hybrid nursing programs offering ASN, ADN, BSN, and RN-to-BSN pathways. Most are online/hybrid rather than fully online because nursing education still requires clinical experience, labs, or practicum work. Accredited options include Chamberlain University, Western Governors University, Purdue Global, University of Texas at Arlington, Herzing University, Joyce University, Walden University, Baylor University, and others. Always verify CCNE or ACEN accreditation before applying.',
			},
		},
		{
			'@type': 'Question',
			name: 'Can you become an RN completely online?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Not entirely. All nursing programs — even those labeled online — require students to complete clinical hours, labs, or practicum experiences in person. Coursework and lectures can often be completed online, but hands-on clinical training must be done at approved healthcare facilities. Programs typically help students find clinical placements near their location.',
			},
		},
		{
			'@type': 'Question',
			name: 'What is the difference between an online ASN and an online BSN program?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'An online ASN or ADN is typically a 2-year program that prepares students to sit for the NCLEX-RN exam. An online BSN is a 4-year degree that opens more career advancement opportunities and is required by many hospital systems. RN-to-BSN programs allow nurses who already hold an RN license and ADN to complete a BSN online, often in 12 to 18 months.',
			},
		},
		{
			'@type': 'Question',
			name: 'What GPA do I need to get into nursing school?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'ADN programs typically have minimum GPA requirements of 2.0 to 2.8, though competitive applicants tend to have 3.0 or higher. BSN programs usually require a minimum 3.0, with highly competitive programs expecting 3.5 or above. Science GPA — particularly in Anatomy and Physiology, Microbiology, and Chemistry — often matters as much as your cumulative GPA.',
			},
		},
		{
			'@type': 'Question',
			name: 'Which nursing prerequisite is the hardest?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Most students and nursing educators consistently identify Microbiology and Anatomy and Physiology as the most challenging prerequisites. Microbiology is especially demanding due to complex lab work involving bacterial identification. A&P is challenging because of its sheer volume of content. General Chemistry is a close third, particularly for students who find math-based reasoning difficult.',
			},
		},
		{
			'@type': 'Question',
			name: 'How long does it take to finish nursing prerequisites?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'For full-time students, completing all nursing prerequisites typically takes one to two years. Part-time students managing work and family responsibilities may need two to three years. The timeline is constrained by course sequencing — starting science courses as early as possible gives you the most scheduling flexibility.',
			},
		},
		{
			'@type': 'Question',
			name: 'Do all nursing schools require the same prerequisites?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'No. Prerequisite requirements vary significantly by school, degree type, and admissions policy. A course that satisfies a prerequisite at one program may not count at another. Students should always verify requirements directly with each nursing program rather than assuming courses are universally transferable.',
			},
		},
		{
			'@type': 'Question',
			name: 'What happens if I get a C in a nursing prerequisite?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: "It depends on the program. Some nursing schools require a minimum grade of B or better in science prerequisites — a passing C will not satisfy the requirement. If you retake the course, nursing programs average all grades including repeats and do not honor grade replacement policies. Check each program's minimum grade requirement before enrolling.",
			},
		},
		{
			'@type': 'Question',
			name: 'Is CCNE or ACEN accreditation important for online nursing programs?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes — accreditation is non-negotiable. CCNE (Commission on Collegiate Nursing Education) and ACEN (Accreditation Commission for Education in Nursing) are the two primary accrediting bodies for nursing programs in the United States. Graduating from a non-accredited program can disqualify you from licensure, graduate school, and many employer hiring requirements. Always verify accreditation status before enrolling in any nursing program, online or in-person.',
			},
		},
	],
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
		{ '@type': 'ListItem', position: 2, name: 'Resources', item: `${site}/resources/` },
		{ '@type': 'ListItem', position: 3, name: 'Blog', item: `${site}/resources/blog/` },
		{ '@type': 'ListItem', position: 4, name: breadcrumbTitle, item: pageUrl },
	],
};

const authorParts = author.trim().split(/\s+/).filter(Boolean);
const authorInitials =
	authorParts.length >= 2
		? (authorParts[0][0] + authorParts[1][0]).toUpperCase()
		: author.slice(0, 2).toUpperCase();
---

<Layout
	title={`${title} | Online College Courses`}
	description={description}
	type="article"
	canonical={slugPath}
	image={ogImageForLayout}
>
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

	<div class="breadcrumb-bar">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span>›</span>
				<a href="/resources">Resources</a>
				<span>›</span>
				<a href="/resources/blog">Blog</a>
				<span>›</span>
				<span>{breadcrumbTitle}</span>
			</nav>
		</div>
	</div>

	<header class="article-hero">
		<div class="container">
			<div class="article-label">{categoryLabel}</div>
			<h1>{title}</h1>
			<p class="article-subtitle">{description}</p>
			<div class="article-meta">
				<span class="meta-item">Updated {updatedDate}</span>
				<span class="meta-dot">·</span>
				<span class="meta-item">{readingTime}</span>
				<span class="meta-dot">·</span>
				<span class="meta-item">By {author}</span>
			</div>
			<div class="article-tags">
				{tags.map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</div>
		</div>
	</header>

	<div class="article-layout">
		<div class="container">
			<div class="article-body">
				<aside class="toc-sidebar">
					<div class="toc-card">
						<div class="toc-title">Table of Contents</div>
						<ol class="toc-list">
							<li><a href="#summary">Quick Summary</a></li>
							<li><a href="#in-this-guide">In this guide</a></li>
							<li><a href="#why-nursing-prerequisites-matter">Why prerequisites matter</a></li>
							<li><a href="#complete-list-of-nursing-school-prerequisite-courses">Required courses</a></li>
							<li><a href="#which-nursing-prerequisites-are-the-hardest">Hardest prerequisites</a></li>
							<li><a href="#gpa-requirements-you-actually-need">GPA requirements</a></li>
							<li><a href="#do-nursing-school-prerequisite-courses-expire">Course expiration</a></li>
							<li><a href="#online-course-options-and-caveats">Online options</a></li>
							<li><a href="#accredited-online-and-hybrid-nursing-programs">Online nursing programs</a></li>
							<li><a href="#adn-vs-bsn-vs-absn-prerequisites-compared">ADN vs BSN vs ABSN</a></li>
							<li><a href="#7-mistakes-that-delay-nursing-school-applications-by-a-year">Common mistakes</a></li>
							<li><a href="#step-by-step-planning-guide">Planning guide</a></li>
							<li><a href="#paa">People Also Ask</a></li>
							<li><a href="#faq">FAQ</a></li>
							<li><a href="#conclusion">Conclusion</a></li>
						</ol>
					</div>
					<div class="author-card">
						<div class="author-avatar">{authorInitials}</div>
						<div class="author-info">
							<div class="author-name">{author}</div>
							<div class="author-title">{authorTitle}</div>
						</div>
					</div>
					<div class="sidebar-cta">
						<p>Explore health &amp; nursing-related courses</p>
						<a href="/categories/health" class="cta-btn">Browse health courses →</a>
					</div>
				</aside>

				<article class="article-content">
					<Content />
				</article>
			</div>
		</div>
	</div>
</Layout>

<style is:global>
	.breadcrumb-bar {
		background: #f8fafc;
		border-bottom: 1px solid #e2e8f0;
		padding: 0.75rem 0;
	}
	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		color: #64748b;
	}
	.breadcrumb a {
		color: #2563eb;
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}
	.breadcrumb span {
		color: #94a3b8;
	}

	.article-hero {
		background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
		color: white;
		padding: 3.5rem 0 3rem;
	}
	.article-label {
		display: inline-block;
		background: rgba(255, 255, 255, 0.15);
		color: white;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 12px;
		border-radius: 4px;
		margin-bottom: 1rem;
		backdrop-filter: blur(4px);
	}
	.article-hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.03em;
		margin-bottom: 1rem;
		max-width: 820px;
	}
	.article-subtitle {
		font-size: 1.125rem;
		color: rgba(255, 255, 255, 0.82);
		max-width: 680px;
		line-height: 1.6;
		margin-bottom: 1.25rem;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.75);
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.meta-dot {
		opacity: 0.5;
	}
	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		background: rgba(255, 255, 255, 0.12);
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.75rem;
		font-weight: 600;
		padding: 4px 10px;
		border-radius: 4px;
		backdrop-filter: blur(4px);
	}

	.article-layout {
		padding: 3rem 0 5rem;
		background: #fff;
	}
	.article-body {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 3rem;
		align-items: start;
	}

	.toc-sidebar {
		position: sticky;
		top: 80px;
	}
	.toc-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.25rem;
		margin-bottom: 1.25rem;
	}
	.toc-title {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #64748b;
		margin-bottom: 0.875rem;
	}
	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		counter-reset: toc;
	}
	.toc-list li {
		counter-increment: toc;
		padding-left: 0;
		position: relative;
	}
	.toc-list li::before {
		content: counter(toc) '.';
		position: absolute;
		left: 0;
		top: 0.35rem;
		font-size: 0.8rem;
		color: #94a3b8;
		font-weight: 600;
		width: 1.25rem;
		text-align: right;
	}
	.toc-list a {
		display: block;
		padding: 0.35rem 0.5rem 0.35rem 1.5rem;
		font-size: 0.875rem;
		color: #475569;
		text-decoration: none;
		border-radius: 5px;
		transition:
			background 0.12s,
			color 0.12s;
		line-height: 1.4;
	}
	.toc-list a:hover {
		background: #eff6ff;
		color: #1d4ed8;
	}
	.author-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.25rem;
		display: flex;
		align-items: center;
		gap: 0.875rem;
		margin-bottom: 1.25rem;
	}
	.author-avatar {
		width: 44px;
		height: 44px;
		background: linear-gradient(135deg, #2563eb, #0284c7);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.875rem;
		font-weight: 700;
		flex-shrink: 0;
	}
	.author-name {
		font-size: 0.875rem;
		font-weight: 700;
		color: #0f172a;
	}
	.author-title {
		font-size: 0.75rem;
		color: #64748b;
		margin-top: 2px;
	}
	.sidebar-cta {
		background: #eff6ff;
		border: 1px solid #bfdbfe;
		border-radius: 10px;
		padding: 1.25rem;
		text-align: center;
	}
	.sidebar-cta p {
		font-size: 0.875rem;
		color: #1e40af;
		font-weight: 600;
		margin: 0 0 0.75rem;
	}
	.cta-btn {
		display: inline-block;
		background: #dc2626;
		color: #fff !important;
		font-size: 0.8rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 9px 18px;
		border-radius: 6px;
		text-decoration: none !important;
		transition: background 0.15s;
	}
	.cta-btn:hover {
		background: #b91c1c;
	}

	.article-content {
		min-width: 0;
	}
	.article-content p {
		font-size: 1rem;
		color: #374151;
		line-height: 1.75;
		margin-bottom: 1.25rem;
	}
	.article-content section {
		margin-bottom: 3rem;
	}
	.article-content h2 {
		font-size: 1.625rem;
		font-weight: 800;
		color: #0f172a;
		letter-spacing: -0.02em;
		margin: 0.5rem 0 1rem;
		line-height: 1.3;
	}
	.article-content h3 {
		font-size: 1.2rem;
		font-weight: 700;
		color: #0f172a;
		margin: 1.5rem 0 0.65rem;
		line-height: 1.35;
	}
	.article-content a {
		color: #2563eb;
		text-decoration: underline;
	}
	.article-content a:hover {
		color: #1d4ed8;
	}
	.section-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #2563eb;
		margin-bottom: 0.25rem;
	}

	.summary-box {
		background: #eff6ff;
		border-left: 4px solid #2563eb;
		border-radius: 0 10px 10px 0;
		padding: 1.25rem 1.5rem;
		margin-bottom: 2rem;
	}
	.summary-label {
		font-size: 0.875rem;
		font-weight: 700;
		color: #1d4ed8;
		margin-bottom: 0.5rem;
	}
	.summary-box p {
		margin: 0;
		color: #1e3a8a;
		font-size: 0.9375rem;
		line-height: 1.7;
	}

	.accred-box {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.accred-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1rem 1.125rem;
	}
	.accred-icon {
		font-size: 1.375rem;
		flex-shrink: 0;
		line-height: 1;
		margin-top: 2px;
	}
	.accred-item strong {
		display: block;
		font-size: 0.9375rem;
		color: #0f172a;
		margin-bottom: 0.25rem;
	}
	.accred-item p {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.55;
		margin: 0;
	}

	.programs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.program-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.125rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		transition:
			border-color 0.15s,
			box-shadow 0.15s;
	}
	.program-card:hover {
		border-color: #2563eb;
		box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
	}
	.program-icon {
		font-size: 1.5rem;
		line-height: 1;
	}
	.program-name {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #0f172a;
	}
	.program-card p {
		font-size: 0.8125rem;
		color: #64748b;
		line-height: 1.55;
		margin: 0;
		flex: 1;
	}
	.program-card a {
		font-size: 0.8125rem;
		font-weight: 600;
		color: #2563eb;
		text-decoration: none;
		margin-top: auto;
	}
	.program-card a:hover {
		text-decoration: underline;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.info-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.125rem 1.25rem;
	}
	.info-card h4 {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #0f172a;
		margin-bottom: 0.375rem;
	}
	.info-card p {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.6;
		margin: 0;
	}

	.support-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.support-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1rem 1.125rem;
	}
	.support-icon {
		font-size: 1.5rem;
