		<script>
			import Chart from 'chart.js/auto';

		const gridColor = 'rgba(128, 128, 128, 0.12)';

		function initCostCalculator() {
			const coursesEl = document.getElementById('study-courses-range');
			const monthsEl = document.getElementById('study-months-range');
			if (!coursesEl || !monthsEl) {
				console.warn('[study-comparison] Cost calculator inputs not found');
				return;
			}
			function updateCalc() {
				const c = parseInt(coursesEl.value, 10);
				const m = parseInt(monthsEl.value, 10);
				document.getElementById('courses-out').textContent = String(c);
				document.getElementById('months-out').textContent = String(m);
				const study = 95 * m;
				const sophia = 99 * m;
				const straight = (99 + c * 79) * m;
				document.getElementById('study-cost').textContent = '$' + study;
				document.getElementById('sophia-cost').textContent = '$' + sophia;
				document.getElementById('straight-cost').textContent = '$' + straight;
				document.getElementById('straight-note').textContent =
					'$99 + $79 × ' + c + ' course' + (c > 1 ? 's' : '');
				document.getElementById('study-note').textContent =
					m > 1 ? '$95 × ' + m + ' months' : 'College Saver plan';
				const minVal = Math.min(study, sophia, straight);
				['study', 'sophia', 'straight'].forEach((id) => {
					const costs = { study, sophia, straight };
					document.getElementById(id + '-win').style.display =
						costs[id] === minVal ? 'inline-block' : 'none';
				});
			}
			coursesEl.addEventListener('input', updateCalc);
			monthsEl.addEventListener('input', updateCalc);
			updateCalc();
		}

		function initCharts() {
			const costChartEl = document.getElementById('costChart');
			if (costChartEl) {
				new Chart(costChartEl, {
					type: 'line',
					data: {
						labels: Array.from({ length: 10 }, (_, i) => i + 1 + ' course' + (i > 0 ? 's' : '')),
						datasets: [
							{
								label: 'Study.com',
								data: Array.from({ length: 10 }, () => 95),
								borderColor: '#534AB7',
								borderWidth: 2,
								pointRadius: 3,
								pointBackgroundColor: '#534AB7',
								fill: false,
								borderDash: [],
							},
							{
								label: 'Sophia',
								data: Array.from({ length: 10 }, () => 99),
								borderColor: '#1D9E75',
								borderWidth: 2,
								pointRadius: 3,
								pointBackgroundColor: '#1D9E75',
								fill: false,
								borderDash: [6, 3],
							},
							{
								label: 'StraighterLine',
								data: Array.from({ length: 10 }, (_, i) => 99 + (i + 1) * 79),
								borderColor: '#378ADD',
								borderWidth: 2,
								pointRadius: 3,
								pointBackgroundColor: '#378ADD',
								fill: false,
								borderDash: [2, 2],
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								callbacks: {
									label: function (ctx) {
										return ' $' + ctx.raw;
									},
								},
							},
						},
						scales: {
							x: {
								ticks: { font: { size: 12 }, autoSkip: false, maxRotation: 30 },
								grid: { display: false },
							},
							y: {
								ticks: {
									callback: function (v) {
										return '$' + v;
									},
									font: { size: 12 },
								},
								grid: { color: gridColor },
							},
						},
					},
				});
			}

			const levelChartEl = document.getElementById('levelChart');
			if (levelChartEl) {
				new Chart(levelChartEl, {
					type: 'bar',
					data: {
						labels: ['Study.com', 'Sophia Learning', 'StraighterLine'],
						datasets: [
							{
								label: 'Lower-division',
								data: [150, 70, 75],
								backgroundColor: ['#EEEDFE', '#E1F5EE', '#E6F1FB'],
								borderColor: ['#534AB7', '#1D9E75', '#378ADD'],
								borderWidth: 1.5,
							},
							{
								label: 'Upper-division',
								data: [70, 0, 0],
								backgroundColor: ['#AFA9EC', 'rgba(0,0,0,0)', 'rgba(0,0,0,0)'],
								borderColor: ['#534AB7', 'rgba(0,0,0,0)', 'rgba(0,0,0,0)'],
								borderWidth: 1.5,
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: { legend: { display: false } },
						scales: {
							x: { stacked: true, grid: { display: false }, ticks: { font: { size: 13 } } },
							y: { stacked: true, ticks: { font: { size: 12 } }, grid: { color: gridColor } },
						},
					},
				});
			}

			const transferChartEl = document.getElementById('transferChart');
			if (transferChartEl) {
				new Chart(transferChartEl, {
					type: 'bar',
					data: {
						labels: ['Partner schools', 'Institutions reviewed'],
						datasets: [
							{
								label: 'Study.com',
								data: [45, 1750],
								backgroundColor: '#EEEDFE',
								borderColor: '#534AB7',
								borderWidth: 1.5,
							},
							{
								label: 'Sophia',
								data: [100, 3000],
								backgroundColor: '#E1F5EE',
								borderColor: '#1D9E75',
								borderWidth: 1.5,
							},
							{
								label: 'StraighterLine',
								data: [180, 3000],
								backgroundColor: '#E6F1FB',
								borderColor: '#378ADD',
								borderWidth: 1.5,
							},
						],
					},
					options: {
						indexAxis: 'y',
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								callbacks: {
									label: function (ctx) {
										return ' ' + ctx.dataset.label + ': ' + ctx.raw.toLocaleString();
									},
								},
							},
						},
						scales: {
							x: {
								ticks: {
									callback: function (v) {
										return v >= 1000 ? v / 1000 + 'k' : v;
									},
									font: { size: 12 },
								},
								grid: { color: gridColor },
							},
							y: { grid: { display: false }, ticks: { font: { size: 13 } } },
						},
					},
				});
			}
		}

		function initPaaAccordion() {
			const block = document.getElementById('paa-block');
			if (!block) return;
			block.querySelectorAll('.paa-q').forEach((btn) => {
				btn.addEventListener('click', () => {
					const item = btn.closest('.paa-item');
					if (!item) return;
					const panel = item.querySelector('.paa-a');
					const open = !item.classList.contains('is-open');
					item.classList.toggle('is-open', open);
					btn.setAttribute('aria-expanded', open ? 'true' : 'false');
					if (panel) {
						if (open) panel.removeAttribute('hidden');
						else panel.setAttribute('hidden', '');
					}
				});
			});
		}

		function run() {
			try {
				initCostCalculator();
			} catch (e) {
				console.error('[study-comparison] Calculator error:', e);
			}
			try {
				initCharts();
			} catch (e) {
				console.error('[study-comparison] Charts failed to render:', e);
			}
			try {
				initPaaAccordion();
			} catch (e) {
				console.error('[study-comparison] PAA accordion error:', e);
			}
		}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', run);
			} else {
				run();
			}
		</script>
	</main>
</Layout>

