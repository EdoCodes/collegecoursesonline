---
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';

const posts = [
  {
    slug: 'best-online-colleges-2026',
    title: '2026 Best Online Colleges: Top 20 Accredited Programs Ranked',
    excerpt: 'Our data-driven ranking of the best online colleges for 2026. Compare tuition costs, program offerings, accreditation, and student outcomes to find the right school for you.',
    label: 'Rankings',
    date: 'Mar 15, 2026',
    readingTime: '22 min read',
    image: 'https://images.pexels.com/photos/1438072/pexels-photo-1438072.jpeg?auto=compress&cs=tinysrgb&w=800',
    tags: ['Rankings', 'Online Colleges', 'Accreditation', 'Tuition'],
  },
  {
    slug: 'online-degree-vs-certificate',
    title: 'Online Degree vs Certificate: Which Is Right for You? (2026 Guide)',
    excerpt: 'A complete side-by-side comparison of online degrees and certificates — cost, time to complete, career outcomes, employer recognition, and a decision framework to help you choose.',
    label: 'Degree Planning',
    date: 'Mar 10, 2026',
    readingTime: '18 min read',
    image: 'https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg?auto=compress&cs=tinysrgb&w=800',
    tags: ['Certificates', 'Degrees', 'Career Advice', 'Online Learning'],
  },
  {
    slug: 'how-to-choose-right-online-college',
    title: 'How to Choose the Right Online College: The Complete Guide (2025–2026)',
    excerpt: 'Everything you need to know before you enroll—accreditation, true costs, transfer credits, diploma mill warnings, a 9-step decision framework, and comprehensive FAQs.',
    label: 'Complete Guide',
    date: 'Mar 5, 2026',
    readingTime: '28 min read',
    image: 'https://images.pexels.com/photos/5212345/pexels-photo-5212345.jpeg?auto=compress&cs=tinysrgb&w=800',
    tags: ['Accreditation', 'Transfer Credits', 'Costs', '2025–2026'],
  },
];
---

<Layout
  title="Rankings & Guides | Online College Courses Resources"
  description="Data-driven rankings, in-depth guides, and research-backed articles to help you choose the right online college, compare degrees vs certificates, and advance your education."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/resources">Resources</a>
        <span>›</span>
        <span>Rankings &amp; Guides</span>
      </nav>
      <h1>Rankings &amp; Guides</h1>
      <p class="subtitle">Data-driven rankings and expert guides to help you find the right online college, degree, or certificate program</p>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="posts-grid">
        {posts.map(post => (
          <BlogCard
            slug={post.slug}
            title={post.title}
            excerpt={post.excerpt}
            label={post.label}
            date={post.date}
            readingTime={post.readingTime}
            image={post.image}
            tags={post.tags}
          />
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 3rem 0 2.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(255,255,255,0.65); text-decoration: none; }
  .breadcrumb a:hover { color: white; }
  .breadcrumb span:last-child { color: rgba(255,255,255,0.9); }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.625rem;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.8);
    margin: 0;
    max-width: 560px;
  }

  .main-content {
    padding: 3rem 0 5rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
