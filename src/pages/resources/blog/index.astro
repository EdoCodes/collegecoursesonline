---
import Layout from '../../../layouts/Layout.astro';
import {
  resourcesBlogPosts as posts,
  getResourcesBlogPostHref,
} from '../../../data/resourcesBlogPosts';
---

<Layout
  title="Blog | Online College Courses Resources"
  description="In-depth guides, how-tos, and research-backed articles to help you choose the right online college, maximize transfer credits, and advance your education."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/resources">Resources</a>
        <span>›</span>
        <span>Blog</span>
      </nav>
      <h1>Blog</h1>
      <p class="subtitle">In-depth guides to help you find the right program, earn credits faster, and advance your career</p>
    </div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="posts-grid">
        {posts.map(post => (
          <a href={getResourcesBlogPostHref(post)} class="card">
            <div class:list={[
                'card-image',
                (post as { imageObjectFit?: string }).imageObjectFit === 'contain' && 'card-image--contain',
                (post as { imageContainVariant?: string }).imageContainVariant === 'blue' && 'card-image--contain-blue',
                (post as { imageContainVariant?: string }).imageContainVariant === 'white' && 'card-image--contain-white',
              ]}>
              <img
                src={post.image}
                alt={post.imageAlt ?? post.title}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="card-body">
              <span class="card-label">{post.label}</span>
              <h2 class="card-title">{post.title}</h2>
              <p class="card-excerpt">{post.excerpt}</p>
              <div class="card-footer">
                <div class="card-tags">
                  {post.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
                <div class="card-meta">
                  <span>{post.date}</span>
                  <span class="dot">·</span>
                  <span>{post.readingTime}</span>
                </div>
              </div>
              <span class="card-cta">Read the guide →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
    color: white;
    padding: 3rem 0 2.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(255,255,255,0.65); text-decoration: none; }
  .breadcrumb a:hover { color: white; }
  .breadcrumb span:last-child { color: rgba(255,255,255,0.9); }

  .page-header h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.625rem;
  }

  .subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.8);
    margin: 0;
    max-width: 560px;
  }

  .main-content {
    padding: 3rem 0 5rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    height: 100%;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.10);
    border-color: #2563eb;
  }
  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: #f1f5f9;
    flex-shrink: 0;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .card:hover .card-image img { transform: scale(1.06); }

  /* Logo / sharp graphics: contain (no crop/upscale blur), no hover zoom, crisp compositing */
  .card-image--contain {
    background: #faf9f7;
    padding: 1rem 1.25rem;
  }
  .card-image--contain.card-image--contain-blue {
    background: #eff6ff;
  }
  .card-image--contain.card-image--contain-white {
    background: #ffffff;
  }
  .card-image--contain img {
    object-fit: contain;
    object-position: center;
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  .card:hover .card-image--contain img {
    transform: translateZ(0);
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2563eb;
    margin-bottom: 0.5rem;
    display: inline-block;
  }
  .card-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.4;
    margin-bottom: 0.625rem;
    letter-spacing: -0.02em;
  }
  .card:hover .card-title { color: #2563eb; }
  .card-excerpt {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    margin-bottom: 1rem;
  }
  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tag {
    background: #f1f5f9;
    color: #475569;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: #94a3b8;
  }
  .dot { opacity: 0.5; }
  .card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    transition: color 0.2s;
    margin-top: auto;
  }
  .card:hover .card-cta { color: #1d4ed8; }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
