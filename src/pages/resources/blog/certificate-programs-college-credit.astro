---
import Layout from '../../../layouts/Layout.astro';
import CertificateProgramsHub from '../../../components/blog/CertificateProgramsHub.astro';
import { certificatePrograms } from '../../../data/certificatePrograms';

const siteOrigin = Astro.site?.href?.replace(/\/$/, '') ?? 'https://collegecoursesonline.netlify.app';
const canonical = '/resources/blog/certificate-programs-college-credit';
const pageUrl = `${siteOrigin}${canonical}`;

const title = 'Certificate Programs Directory | Paralegal, Health & IT';
const description =
	'Browse certificate programs by area—paralegal, health professions, and IT—search the directory, and read our in-depth guide on how certificate credit and transfer work in the U.S.';
---

<Layout title={title} description={description} canonical={canonical} type="website">
	<script is:inline>
		(function () {
			if (location.hash === '#guide') {
				location.replace('/resources/guides/certificate-programs-college-credit#guide');
			}
		})();
	</script>

	<main class="cert-page">
		<div class="cert-hero">
			<div class="container cert-hero__inner">
				<nav class="cert-breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="cert-breadcrumb__sep" aria-hidden="true">/</span>
					<a href="/resources">Resources</a>
					<span class="cert-breadcrumb__sep" aria-hidden="true">/</span>
					<span class="cert-breadcrumb__current">Certificate programs</span>
				</nav>
				<p class="cert-hero__eyebrow">Directory</p>
				<h1 class="cert-hero__title">Certificate programs</h1>
				<p class="cert-hero__subtitle">
					Explore paralegal, health professions, and IT-focused certificate listings in one place. For how transfer credit, ACE/NCCRS, and
					prior-learning policies actually work, start with our{' '}
					<a href="/resources/guides/certificate-programs-college-credit">certificate programs &amp; college credit guide</a>.
				</p>
				<p class="cert-hero__subtitle cert-hero__subtitle--second">
					The search bar below stays pinned as you scroll so you can filter by program name, school, or topic at any time—then cross-check pathways and
					registrar questions in the same{' '}
					<a href="/resources/guides/certificate-programs-college-credit">certificate programs &amp; college credit guide</a>.
				</p>
			</div>
		</div>

		<div class="container cert-body">
			<CertificateProgramsHub programs={certificatePrograms} />

			<section class="cert-note" aria-label="Disclaimer">
				<p>
					<strong>Note:</strong> We summarize publicly posted program information to help you compare options. Admissions, accreditation, pricing, and
					credit acceptance change over time—use our{' '}
					<a href="/resources/guides/certificate-programs-college-credit">certificate programs &amp; college credit guide</a>{' '}
					for policy context, and confirm every detail on the official provider site and with your target college’s registrar or transfer office.
				</p>
			</section>
		</div>
	</main>
</Layout>

<script type="application/ld+json" slot="head" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: title,
	description: description,
	url: pageUrl,
	isPartOf: { '@type': 'WebSite', name: 'College Courses Online', url: siteOrigin },
})} />

<style>
	.cert-page {
		min-height: 50vh;
	}
	.container {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 calc(var(--spacing, 8px) * 3);
	}
	.cert-hero {
		background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #0369a1 100%);
		color: #fff;
		padding: 2.5rem 0 3rem;
		margin-bottom: 2.5rem;
	}
	.cert-hero__inner {
		max-width: 880px;
	}
	.cert-breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.5rem;
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 1.25rem;
	}
	.cert-breadcrumb a {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
	}
	.cert-breadcrumb a:hover {
		color: #fff;
		text-decoration: underline;
	}
	.cert-breadcrumb__current {
		color: rgba(255, 255, 255, 0.95);
		font-weight: 500;
	}
	.cert-breadcrumb__sep {
		opacity: 0.55;
	}
	.cert-hero__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.75);
	}
	.cert-hero__title {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 4.5vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.15;
		color: #fff;
	}
	.cert-hero__subtitle {
		margin: 0 0 1rem;
		font-size: 1.0625rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.88);
		max-width: 68ch;
	}
	.cert-hero__subtitle--second {
		margin-bottom: 0;
	}
	.cert-hero__subtitle a {
		color: #fff;
		font-weight: 600;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}
	.cert-hero__subtitle a:hover {
		color: #e0e7ff;
	}
	.cert-body {
		padding-bottom: 4rem;
	}
	.cert-note a {
		color: var(--color-primary, #1e40af);
		font-weight: 600;
	}
	.cert-note a:hover {
		text-decoration: underline;
	}
	.cert-note {
		margin-top: 2.5rem;
		padding: 1.15rem 1.25rem;
		background: var(--color-bg-light, #f8fafc);
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 12px;
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--color-text-medium, #475569);
	}
	.cert-note strong {
		color: var(--color-navy, #0f172a);
	}
	@media (max-width: 640px) {
		.cert-hero {
			padding: 2rem 0 2.25rem;
		}
	}
</style>
