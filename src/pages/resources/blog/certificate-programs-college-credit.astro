---
import Layout from '../../../layouts/Layout.astro';
import CertificateProgramsHub from '../../../components/blog/CertificateProgramsHub.astro';
import { certificatePrograms } from '../../../data/certificatePrograms';

const siteOrigin = Astro.site?.href?.replace(/\/$/, '') ?? 'https://collegecoursesonline.netlify.app';
const canonical = '/resources/blog/certificate-programs-college-credit';
const pageUrl = `${siteOrigin}${canonical}`;

const title = 'Certificate Programs Directory | Paralegal, Health & IT';
const description =
	'Browse certificate programs by area—paralegal, health professions, and IT—search the directory, and read our in-depth guide on how certificate credit and transfer work in the U.S.';
---

<Layout title={title} description={description} canonical={canonical} type="website">
	<script is:inline>
		(function () {
			if (location.hash === '#guide') {
				location.replace('/resources/guides/certificate-programs-college-credit#guide');
			}
		})();
	</script>

	<main class="cert-page">
		<div class="cert-hero">
			<div class="container cert-hero__inner">
				<nav class="cert-breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="cert-breadcrumb__sep" aria-hidden="true">/</span>
					<a href="/resources">Resources</a>
					<span class="cert-breadcrumb__sep" aria-hidden="true">/</span>
					<span class="cert-breadcrumb__current">Certificate programs</span>
				</nav>
				<p class="cert-hero__eyebrow">Directory</p>
				<h1 class="cert-hero__title">Certificate programs</h1>
				<p class="cert-hero__subtitle">
					Explore paralegal, health professions, and IT-focused certificate listings in one place. Use search to narrow by program name, school, or topic.
					Transfer and credit rules always depend on your receiving institution—when you need the full policy deep-dive, open our companion guide below.
				</p>
				<div class="cert-hero__actions">
					<a class="cert-btn cert-btn--secondary" href="/resources/guides/certificate-programs-college-credit">
						Read the full guide: certificates &amp; college credit →
					</a>
				</div>
			</div>
		</div>

		<div class="container cert-body">
			<section class="cert-intro" aria-labelledby="cert-intro-heading">
				<h2 id="cert-intro-heading" class="cert-intro__title">How to use this page</h2>
				<p>
					Programs are grouped into three areas that match common student goals: paralegal and legal support, health professions, and information
					technology. Each card links to a program detail page with provider context, format notes, and reminders to verify transfer and financial aid
					before you enroll.
				</p>
				<p>
					<strong>Looking for mechanics of transfer and ACE/NCCRS credit?</strong>{' '}
					<a href="/resources/guides/certificate-programs-college-credit">Open the ultimate guide on certificate programs and college credit</a>
					—it covers community college certificates, university extension credit, RN-to-BSN and IT pathways, and the questions to ask your registrar.
				</p>
			</section>

			<CertificateProgramsHub programs={certificatePrograms} />

			<section class="cert-note" aria-label="Disclaimer">
				<p>
					<strong>Note:</strong> We summarize publicly posted program information to help you compare options. Admissions, accreditation, pricing, and
					credit acceptance change over time. Confirm every detail on the official provider site and with your target college’s registrar or transfer
					office.
				</p>
			</section>
		</div>
	</main>
</Layout>

<script type="application/ld+json" slot="head" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: title,
	description: description,
	url: pageUrl,
	isPartOf: { '@type': 'WebSite', name: 'College Courses Online', url: siteOrigin },
})} />

<style>
	.cert-page {
		min-height: 50vh;
	}
	.container {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 calc(var(--spacing, 8px) * 3);
	}
	.cert-hero {
		background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #0369a1 100%);
		color: #fff;
		padding: 2.5rem 0 3rem;
		margin-bottom: 2.5rem;
	}
	.cert-hero__inner {
		max-width: 880px;
	}
	.cert-breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.5rem;
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 1.25rem;
	}
	.cert-breadcrumb a {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
	}
	.cert-breadcrumb a:hover {
		color: #fff;
		text-decoration: underline;
	}
	.cert-breadcrumb__current {
		color: rgba(255, 255, 255, 0.95);
		font-weight: 500;
	}
	.cert-breadcrumb__sep {
		opacity: 0.55;
	}
	.cert-hero__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.75);
	}
	.cert-hero__title {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 4.5vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.15;
		color: #fff;
	}
	.cert-hero__subtitle {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.88);
		max-width: 65ch;
	}
	.cert-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.cert-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.15rem;
		border-radius: 10px;
		font-weight: 600;
		font-size: 0.9375rem;
		text-decoration: none;
		transition: background 0.2s ease, color 0.2s ease;
	}
	.cert-btn--secondary {
		background: rgba(255, 255, 255, 0.14);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.35);
	}
	.cert-btn--secondary:hover {
		background: rgba(255, 255, 255, 0.24);
	}
	.cert-body {
		padding-bottom: 4rem;
	}
	.cert-intro {
		margin-bottom: 2.25rem;
	}
	.cert-intro__title {
		font-size: 1.35rem;
		font-weight: 800;
		color: var(--color-navy, #0f172a);
		margin: 0 0 0.75rem;
		letter-spacing: -0.02em;
	}
	.cert-intro p {
		margin: 0 0 1rem;
		font-size: 1.02rem;
		line-height: 1.75;
		color: var(--color-text-medium, #475569);
		max-width: 75ch;
	}
	.cert-intro a {
		color: var(--color-primary, #1e40af);
		font-weight: 600;
	}
	.cert-intro a:hover {
		text-decoration: underline;
	}
	.cert-note {
		margin-top: 2.5rem;
		padding: 1.15rem 1.25rem;
		background: var(--color-bg-light, #f8fafc);
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 12px;
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--color-text-medium, #475569);
	}
	.cert-note strong {
		color: var(--color-navy, #0f172a);
	}
	@media (max-width: 640px) {
		.cert-hero {
			padding: 2rem 0 2.25rem;
		}
		.cert-btn {
			width: 100%;
		}
	}
</style>
