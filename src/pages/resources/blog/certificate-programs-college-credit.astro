	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Which certificate programs are most likely to count toward college credit?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'The strongest cases are (1) certificates built from accredited, transcripted college courses—especially community college Certificates of Achievement on CSU/UC-transferable patterns, (2) university extension courses explicitly numbered and documented as undergraduate credit, and (3) industry training that appears in the ACE National Guide or NCCRS with credit recommendations, when your receiving school accepts CPL for that provider. Nothing is automatic until the registrar or transfer office approves it.',
			},
		},
		{
			'@type': 'Question',
			name: 'Can nursing and RN-to-BSN students use certificates for credit?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Sometimes. RN-to-BSN programs usually prioritize your ADN/diploma nursing credits, general education, and statistics. Certificates can help as electives, health-policy or informatics coursework, or prerequisites completed at a regionally accredited college—but clinical nursing credit from non-college certificates is rarely substituted for BSN nursing core. Always confirm with the RN-to-BSN program’s written transfer and substitution policies.',
			},
		},
		{
			'@type': 'Question',
			name: 'Do IT certifications like CompTIA and AWS really count as college credit?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'They can, when a college awards credit for prior learning (CPL) based on ACE or NCCRS recommendations or publishes a direct course substitution list. CompTIA exams and AWS training paths are commonly evaluated in IT and cybersecurity programs at transfer-friendly universities, but each institution sets its own cap on how many CPL credits apply to the major versus electives.',
			},
		},
		{
			'@type': 'Question',
			name: 'Will my paralegal certificate transfer into a bachelor’s degree?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'If the paralegal certificate is made of regionally accredited college courses on your transcript, those courses may transfer as paralegal studies, legal studies, or electives toward a bachelor’s. If it is a noncredit professional certificate from a training vendor, it may only count if your school awards CPL for that program or you portfolio-assess the learning. The receiving college makes the final decision.',
			},
		},
		{
			'@type': 'Question',
			name: 'How can I check if a certificate will transfer before I enroll?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ask the target college’s registrar or transfer center for a pre-transfer or unofficial evaluation, read the CPL handbook, and use ASSIST.org for California community college course articulation to CSU/UC or Transferology where participating schools are listed. Cross-check ACE National Guide entries for industry programs and capture syllabi, transcripts, and completion certificates before you pay.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is there a limit to how many certificate-related credits I can transfer?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. Most bachelor’s programs require a minimum number of credits completed at the awarding institution (residency), cap CPL or exam credit (often well below 90 semester credits), and restrict how many upper-division credits can be satisfied through transfer. Read the catalog residency and CPL sections for exact numbers.',
			},
		},
