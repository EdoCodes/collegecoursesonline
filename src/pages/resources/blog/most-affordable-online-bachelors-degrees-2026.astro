    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .author-avatar {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, #2563eb, #0284c7);
    color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.875rem; font-weight: 700;
