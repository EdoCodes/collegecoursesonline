  .meta-dot { opacity: 0.5; }
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  /* ── Article Layout ── */
  .article-layout { padding: 3rem 0 5rem; background: #fff; }
  .article-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Sidebar ── */
  .toc-sidebar { position: sticky; top: 80px; }
  .toc-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
