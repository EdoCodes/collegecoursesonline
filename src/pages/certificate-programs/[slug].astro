---
import Layout from '../../layouts/Layout.astro';
import CertificateProgramReviewsSection from '../../components/CertificateProgramReviewsSection.astro';
import { certificatePrograms, type CertificateProgram } from '../../data/certificatePrograms';

export async function getStaticPaths() {
	return certificatePrograms.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const program = certificatePrograms.find((p) => p.slug === slug) as CertificateProgram | undefined;
if (!program) {
	return Astro.redirect('/404');
}

const pageTitle = `${program.title} | Accredited Certificate Program`;
const pageDescription =
	program.shortDescription.length > 155 ? program.shortDescription.slice(0, 152) + '…' : program.shortDescription;
const canonical = `/certificate-programs/${program.slug}`;

const programSchema = {
	'@context': 'https://schema.org',
	'@type': 'EducationalOccupationalProgram',
	name: program.title,
	description: program.shortDescription,
	provider: { '@type': 'Organization', name: program.providerName, url: program.sourceUrl },
	educationalCredentialAwarded: 'Certificate',
	url: Astro.url.href,
	image: [new URL(program.image.replace(/^\//, ''), Astro.site ?? Astro.url).href],
	inLanguage: 'en-US',
	...(program.occupationalCategory ? { occupationalCategory: program.occupationalCategory } : {}),
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site ?? Astro.url).href },
		{ '@type': 'ListItem', position: 2, name: 'Certificate programs', item: new URL('/resources/blog/certificate-programs-college-credit', Astro.site ?? Astro.url).href },
		{ '@type': 'ListItem', position: 3, name: program.title, item: Astro.url.href },
	],
};
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical} image={program.image} type="article">
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(programSchema)} />
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

	<main class="course-detail">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="separator">/</span>
				<a href="/resources/blog/certificate-programs-college-credit">Certificate Programs</a>
				<span class="separator">/</span>
				<span class="current">{program.title}</span>
			</nav>
		</div>

		<div class="hero-section">
			<div class="container">
				<div class="hero-grid">
					<div class="hero-content">
						<span class="featured-badge">{program.categoryLabel}</span>
						<h1 class="course-title">{program.title}</h1>
						<p class="course-subtitle">{program.shortDescription}</p>

						<div class="course-meta">
							<div class="meta-item">
								<span><strong>Provider:</strong> {program.providerName}</span>
							</div>
							{program.format && (
								<div class="meta-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/>
										<polyline points="12 6 12 12 16 14"/>
									</svg>
									<span><strong>Format:</strong> {program.format}</span>
								</div>
							)}
							{program.location && (
								<div class="meta-item">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
										<circle cx="12" cy="10" r="3"/>
									</svg>
									<span><strong>Location:</strong> {program.location}</span>
								</div>
							)}
						</div>

						<div class="cta-section">
							<a class="cta-button primary" href={program.sourceUrl} target="_blank" rel="noopener noreferrer">
								<span>View official program page</span>
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M5 12h14M12 5l7 7-7 7"/>
								</svg>
							</a>
							<a class="cta-button secondary" href={`/rate-certificate-program?program=${program.slug}`}>
								Rate this program
							</a>
						</div>
					</div>

					<div class="hero-image">
						<img src={program.image} alt={program.title} class="course-image" loading="eager" />
					</div>
				</div>
			</div>
		</div>

		<div class="container">
			<div class="content-grid">
				<div class="main-content">
					<section class="content-section">
						<h2>Key details to verify (transfer and credit)</h2>
						<div class="description-content">
							<p>
								Programs like this can help with transfer and credit for prior learning—but the receiving school makes the final decision. Before you enroll,
								confirm transferability with your target registrar in writing.
							</p>
							{program.creditNotes?.length ? (
								<ul class="learning-outcomes">
									{program.creditNotes.map((n) => (
										<li>{n}</li>
									))}
								</ul>
							) : null}
						</div>
					</section>

					{program.overview && (
						<section class="content-section">
							<h2>About this program</h2>
							<div class="description-content">
								<p>{program.overview}</p>
							</div>
						</section>
					)}

					{program.highlights?.length ? (
						<section class="content-section">
							<h2>Program highlights</h2>
							<ul class="learning-outcomes">
								{program.highlights.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>
					) : null}

					{program.whatYoullLearn?.length ? (
						<section class="content-section">
							<h2>What you&apos;ll learn</h2>
							<ul class="learning-outcomes">
								{program.whatYoullLearn.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>
					) : null}

					{program.outcomes?.length ? (
						<section class="content-section">
							<h2>Outcomes</h2>
							<ul class="learning-outcomes">
								{program.outcomes.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</section>
					) : null}

					{program.accreditation && (
						<section class="content-section">
							<h2>Accreditation</h2>
							<div class="description-content">
								<p>{program.accreditation}</p>
							</div>
						</section>
					)}

					{program.externalLinks?.length ? (
						<section class="content-section">
							<h2>Official links</h2>
							<ul class="learning-outcomes">
								{program.externalLinks.map((l) => (
									<li>
										<a href={l.url} target="_blank" rel="noopener noreferrer">
											{l.label}
										</a>
									</li>
								))}
							</ul>
						</section>
					) : null}

					<section class="content-section" id="reviews">
						<CertificateProgramReviewsSection programSlug={program.slug} programTitle={program.title} />
					</section>
				</div>

				<aside class="sidebar">
					<div class="info-card">
						<h3>Program Details</h3>
						<div class="info-list">
							<div class="info-item">
								<span class="label">Provider</span>
								<span class="value">{program.providerName}</span>
							</div>
							{program.format && (
								<div class="info-item">
									<span class="label">Format</span>
									<span class="value">{program.format}</span>
								</div>
							)}
							{program.location && (
								<div class="info-item">
									<span class="label">Location</span>
									<span class="value">{program.location}</span>
								</div>
							)}
							<div class="info-item">
								<span class="label">Credential</span>
								<span class="value">Certificate</span>
							</div>
						</div>
					</div>

					<div class="info-card disclosure-card">
						<p class="disclosure-text">
							<strong>Note:</strong> Transfer, credit, and financial aid eligibility vary by school and student circumstances. Always confirm in writing before enrolling.
						</p>
					</div>
				</aside>
			</div>
		</div>
	</main>
</Layout>

<style>
	.course-detail {
		min-height: 100vh;
	}

	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 calc(var(--spacing) * 3);
	}

	/* Breadcrumb */
	.breadcrumb {
		padding: calc(var(--spacing) * 3) 0;
		display: flex;
		align-items: center;
		gap: calc(var(--spacing) * 1);
		font-size: 0.875rem;
		color: var(--neutral-600);
		flex-wrap: wrap;
	}

	.breadcrumb a {
		color: var(--neutral-600);
		transition: var(--transition);
	}

	.breadcrumb a:hover {
		color: var(--color-primary);
	}

	.breadcrumb .separator {
		color: var(--neutral-400);
	}

	.breadcrumb .current {
		color: var(--neutral-900);
		font-weight: 500;
	}

	/* Hero Section */
	.hero-section {
		background: linear-gradient(135deg, #1e40af 0%, #0ea5e9 100%);
		padding: calc(var(--spacing) * 8) 0;
		margin-bottom: calc(var(--spacing) * 6);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: calc(var(--spacing) * 6);
		align-items: center;
	}

	.hero-content {
		color: white;
	}

	.featured-badge {
		display: inline-flex;
		align-items: center;
		padding: calc(var(--spacing) * 1) calc(var(--spacing) * 2);
		background: rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(10px);
		border-radius: calc(var(--border-radius) / 2);
		font-size: 0.875rem;
		font-weight: 700;
		margin-bottom: calc(var(--spacing) * 2);
	}

	.course-title {
		font-size: 3rem;
		margin-bottom: calc(var(--spacing) * 3);
		color: white;
	}

	.course-subtitle {
		font-size: 1.125rem;
		margin-bottom: calc(var(--spacing) * 4);
		color: #e2e8f0;
		font-style: italic;
		line-height: 1.7;
	}

	.course-meta {
		display: flex;
		flex-direction: column;
		gap: calc(var(--spacing) * 2);
		margin-bottom: calc(var(--spacing) * 4);
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: calc(var(--spacing) * 1.5);
		font-size: 1rem;
	}

	.meta-item svg {
		opacity: 0.9;
	}

	.cta-section {
		display: flex;
		gap: calc(var(--spacing) * 2);
		align-items: center;
		flex-wrap: wrap;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: calc(var(--spacing) * 1.5);
		padding: calc(var(--spacing) * 2.5) calc(var(--spacing) * 4);
		border-radius: calc(var(--border-radius) / 2);
		font-weight: 700;
		font-size: 1rem;
		text-decoration: none;
		transition: var(--transition);
		white-space: nowrap;
	}

	.cta-button.primary {
		background: white;
		color: var(--color-primary);
	}

	.cta-button.primary:hover {
		background: var(--neutral-100);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
	}

	.cta-button.secondary {
		background: rgba(255, 255, 255, 0.1);
		color: white;
		border: 2px solid rgba(255, 255, 255, 0.3);
	}

	.cta-button.secondary:hover {
		background: rgba(255, 255, 255, 0.2);
		border-color: rgba(255, 255, 255, 0.5);
	}

	.hero-image {
		position: relative;
		width: 100%;
		border-radius: calc(var(--border-radius) * 1.5);
		overflow: hidden;
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
		background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
		min-height: 260px;
		height: clamp(260px, 38vw, min(440px, 52vh));
	}

	.course-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		object-position: center center;
	}

	/* Main Content Grid */
	.content-grid {
		display: grid;
		grid-template-columns: 1fr 350px;
		gap: calc(var(--spacing) * 6);
		margin-bottom: calc(var(--spacing) * 8);
	}

	.main-content {
		min-width: 0;
	}

	.content-section {
		margin-bottom: calc(var(--spacing) * 6);
	}

	.content-section h2 {
		font-size: 2rem;
		margin-bottom: calc(var(--spacing) * 3);
		color: var(--neutral-900);
	}

	.description-content p {
		font-size: 1.125rem;
		line-height: 1.8;
		color: var(--neutral-700);
	}

	/* Reuse the same list styling */
	.learning-outcomes {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: calc(var(--spacing) * 2);
		margin: 0;
		padding: 0;
	}

	.learning-outcomes li {
		display: flex;
		align-items: flex-start;
		gap: calc(var(--spacing) * 2);
		font-size: 1.05rem;
		line-height: 1.6;
		color: var(--neutral-800);
	}

	.learning-outcomes li::before {
		content: "✓";
		flex-shrink: 0;
		width: 24px;
		height: 24px;
		background: var(--color-success);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 0.875rem;
		margin-top: 2px;
	}

	/* Sidebar */
	.sidebar {
		position: sticky;
		top: calc(var(--spacing) * 3);
		align-self: flex-start;
	}

	.info-card {
		background: white;
		border-radius: calc(var(--border-radius) * 1.25);
		padding: calc(var(--spacing) * 3);
		box-shadow: var(--shadow-md);
		margin-bottom: calc(var(--spacing) * 3);
		border: 1px solid var(--neutral-200);
	}

	.info-card h3 {
		font-size: 1.25rem;
		margin-bottom: calc(var(--spacing) * 3);
		color: var(--neutral-900);
	}

	.info-list {
		display: flex;
		flex-direction: column;
		gap: calc(var(--spacing) * 2);
	}

	.info-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: calc(var(--spacing) * 2);
		border-bottom: 1px solid var(--neutral-200);
	}

	.info-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.info-item .label {
		font-weight: 600;
		color: var(--neutral-700);
	}

	.info-item .value {
		color: var(--neutral-900);
		font-weight: 500;
	}

	.disclosure-card {
		background: var(--neutral-50);
		border: 1px solid var(--neutral-200);
	}

	.disclosure-text {
		font-size: 0.8125rem;
		color: var(--neutral-600);
		line-height: 1.5;
		margin: 0;
	}

	.disclosure-text strong {
		color: var(--neutral-800);
	}

	@media (max-width: 1024px) {
		.content-grid {
			grid-template-columns: 1fr;
		}

		.sidebar {
			position: static;
		}
	}

	@media (max-width: 768px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}

		.course-title {
			font-size: 2rem;
		}

		.hero-image {
			order: -1;
		}

		.cta-section {
			flex-direction: column;
			width: 100%;
		}

		.cta-button {
			width: 100%;
		}
	}
</style>

