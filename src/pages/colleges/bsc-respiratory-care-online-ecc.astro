---
import ResourcesGuideLayout, {
	type ResourcesGuideTocItem,
} from '../../components/blog/ResourcesGuideLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('blog', 'bsc-respiratory-care-online-ecc');
if (!entry) {
	throw new Error('Blog entry bsc-respiratory-care-online-ecc not found');
}

const { Content } = await entry.render();
const { title, description, pubDate, author, tags, image } = entry.data;

const categoryLabel = entry.data.categoryLabel ?? 'Colleges';
const authorTitle = entry.data.authorTitle ?? 'Contributor';
const breadcrumbTitle = entry.data.breadcrumbTitle ?? title;
const readTimeFromFrontmatter = entry.data.readTime;

const site = Astro.site?.href?.replace(/\/$/, '') ?? 'https://collegecoursesonline.netlify.app';
const slugPath = '/colleges/bsc-respiratory-care-online-ecc';
const pageUrl = new URL(slugPath.replace(/^\//, ''), `${site}/`).href;

const publishDate = pubDate.toISOString().slice(0, 10);
const updatedDate =
	entry.data.updatedDate != null
		? entry.data.updatedDate.toISOString().slice(0, 10)
		: publishDate;

const wordCount = entry.body.trim().split(/\s+/).filter(Boolean).length;
const readingTime =
	readTimeFromFrontmatter ?? `${Math.max(1, Math.ceil(wordCount / 200))} min read`;

const ogImageUrl =
	typeof image === 'string' && image.startsWith('http')
		? image
		: image
			? new URL(image, `${site}/`).href
			: `${site}/og-image.jpg`;

const ogImageForLayout =
	typeof image === 'string' && image.startsWith('http') ? image : image ?? '/og-image.jpg';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	image: [ogImageUrl],
	datePublished: publishDate,
	dateModified: updatedDate,
	author: {
		'@type': 'Person',
		name: author,
	},
	publisher: {
		'@type': 'Organization',
		name: 'College Courses Online',
		url: site,
		logo: {
			'@type': 'ImageObject',
			url: `${site}/favicon.svg`,
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': pageUrl,
	},
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Does El Camino College offer an online bachelor’s degree?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. El Camino College offers a Bachelor of Science in Respiratory Care described as an online-format accelerated bachelor’s for qualified applicants. Confirm current details on ECC’s official bachelor’s program page.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is ECC’s respiratory care bachelor’s fully online?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'ECC describes the bachelor’s as an online-format program using eight-week terms across three semesters. Confirm any orientation or other requirements directly with ECC before enrolling.',
			},
		},
		{
			'@type': 'Question',
			name: 'Does El Camino College offer radiology or radiologic technology?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'ECC offers Radiologic Technology at the associate level—a hybrid pathway with some remote coursework components plus required in-person labs and clinical training—not a bachelor’s in radiology completed fully online at ECC.',
			},
		},
		{
			'@type': 'Question',
			name: 'What is El Camino College’s first bachelor’s degree?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'ECC’s first bachelor’s program is the Bachelor of Science in Respiratory Care, launched with a Fall 2023 cohort per ECC news materials.',
			},
		},
		{
			'@type': 'Question',
			name: 'Who can apply to ECC’s B.S. in Respiratory Care?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Applicants must meet ECC’s published prerequisites—including accredited respiratory care associate preparation and COARC-related expectations plus general-education progress—listed on ECC’s respiratory care admission page.',
			},
		},
		{
			'@type': 'Question',
			name: 'Does ECC offer other flexible health-care programs?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. Beyond the respiratory-care bachelor’s, ECC offers programs such as Radiologic Technology in a hybrid format with remote components and required in-person clinical education.',
			},
		},
		{
			'@type': 'Question',
			name: 'Did Brian Wilson go to El Camino College?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Yes. Brian Wilson is documented among ECC’s notable alumni in college materials.',
			},
		},
	],
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
		{ '@type': 'ListItem', position: 2, name: 'Colleges', item: `${site}/colleges/` },
		{ '@type': 'ListItem', position: 3, name: breadcrumbTitle, item: pageUrl },
	],
};

const tocItems: ResourcesGuideTocItem[] = [
	{ href: '#summary', label: 'Quick Summary' },
	{ href: '#in-this-guide', label: 'In this guide' },
	{ href: '#why-el-camino-college-stands-out', label: 'Why ECC stands out' },
	{ href: '#el-camino-college-history', label: 'ECC history' },
	{ href: '#ecc-today', label: 'ECC today' },
	{ href: '#online-bs-in-respiratory-care', label: 'B.S. Respiratory Care' },
	{ href: '#who-should-consider-this-program', label: 'Who should apply' },
	{ href: '#hybrid-as-in-radiologic-technology', label: 'Hybrid Radiologic Technology' },
	{ href: '#cost-and-format', label: 'Cost & format' },
	{ href: '#why-health-care-students-choose-ecc', label: 'Why choose ECC' },
	{ href: '#interesting-facts-about-ecc', label: 'ECC facts' },
	{ href: '#people-also-ask', label: 'People Also Ask' },
	{ href: '#sources', label: 'Sources' },
];
---

<ResourcesGuideLayout
	title={title}
	description={description}
	canonical={slugPath}
	image={ogImageForLayout}
	categoryLabel={categoryLabel}
	breadcrumbTitle={breadcrumbTitle}
	breadcrumbTrail={[{ label: 'Colleges', href: '/colleges' }]}
	author={author}
	authorTitle={authorTitle}
	readingTime={readingTime}
	updatedDate={updatedDate}
	tags={tags}
	tocItems={tocItems}
	sidebarCta={{
		intro: 'More college guides & rankings',
		href: '/resources/blog/best-online-colleges-2026',
		buttonLabel: 'Best online colleges 2026 →',
	}}
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
	<Content />
</ResourcesGuideLayout>
