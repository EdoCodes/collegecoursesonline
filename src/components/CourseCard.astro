---
import type { Course } from '../lib/supabase';

interface Props {
	course: Course;
}

const { course } = Astro.props;
const college = course.colleges;
const category = course.course_categories;
---

<article class="course-card" data-course-id={course.id}>
	<div class="card-image">
		<img
			src={course.image_url || 'https://images.pexels.com/photos/267885/pexels-photo-267885.jpeg?auto=compress&cs=tinysrgb&w=800'}
			alt={course.title}
			loading="lazy"
		/>
		{course.featured && (
			<span class="featured-badge">Featured</span>
		)}
		{course.price === 'Free' ? (
			<span class="price-badge free">Free</span>
		) : course.price && (
			<span class="price-badge">{course.price}</span>
		)}
	</div>

	<div class="card-body">
		<span class="card-label">
			{category ? `${category.icon ?? ''} ${category.name}` : 'Course'}
		</span>
		<h3 class="card-title">
			<a href={course.course_url || '#'} target="_blank" rel="noopener noreferrer">
				{course.title}
			</a>
		</h3>
		{college && (
			<p class="card-brand">{college.name}</p>
		)}
		<p class="card-excerpt">
			{course.short_description || course.description?.slice(0, 160)}
		</p>
		<a
			href={college?.website_url || course.course_url || '#'}
			target="_blank"
			rel="noopener noreferrer"
			class="card-cta"
		>
			View program →
		</a>
	</div>
</article>

<style>
	.course-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		height: 100%;
	}

	.course-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.10);
		border-color: #2563eb;
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 200px;
		overflow: hidden;
		background: #f1f5f9;
		flex-shrink: 0;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.course-card:hover .card-image img {
		transform: scale(1.06);
	}

	.featured-badge {
		position: absolute;
		top: 12px;
		left: 12px;
		padding: 4px 10px;
		background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
		color: white;
		font-size: 0.7rem;
		font-weight: 700;
		border-radius: 6px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.price-badge {
		position: absolute;
		top: 12px;
		right: 12px;
		padding: 4px 10px;
		background: rgba(15, 23, 42, 0.80);
		color: white;
		font-size: 0.8rem;
		font-weight: 700;
		border-radius: 6px;
		backdrop-filter: blur(8px);
	}

	.price-badge.free {
		background: linear-gradient(135deg, #10b981 0%, #059669 100%);
	}

	.card-body {
		padding: 1.25rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #2563eb;
		margin-bottom: 0.5rem;
		display: inline-block;
	}

	.card-title {
		font-family: 'Inter', sans-serif;
		font-size: 1.125rem;
		font-weight: 700;
		color: #0f172a;
		line-height: 1.4;
		margin-bottom: 0.25rem;
		letter-spacing: -0.02em;
	}

	.card-title a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s;
	}

	.course-card:hover .card-title a {
		color: #2563eb;
	}

	.card-brand {
		font-size: 0.85rem;
		color: #94a3b8;
		margin-bottom: 0.625rem;
		font-weight: 500;
	}

	.card-excerpt {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
		margin-bottom: 1rem;
	}

	.card-cta {
		font-size: 0.875rem;
		font-weight: 600;
		color: #2563eb;
		text-decoration: none;
		transition: color 0.2s;
		margin-top: auto;
	}

	.course-card:hover .card-cta {
		color: #1d4ed8;
	}

	@media (max-width: 768px) {
		.card-image {
			height: 180px;
		}

		.card-title {
			font-size: 1rem;
		}
	}
</style>
