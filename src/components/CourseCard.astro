---
import type { Course } from '../lib/supabase';
import { resolveCourseImageUrl } from '../lib/courseImageOverrides';
import { linkAceNccrsHtml } from '../lib/linkAceNccrs';
import CoursePrice from './CoursePrice.astro';

interface Props {
	course: Course;
}

const { course } = Astro.props;
const college = course.colleges;
const category = course.course_categories;
const cardImageUrl = resolveCourseImageUrl(course.slug, course.image_url);
const descriptionHtml = linkAceNccrsHtml(
	course.short_description || `${course.description.slice(0, 120)}...`,
);
const href = `/courses/${course.slug}`;
---

<article class="card card--has-overlay" data-course-id={course.id}>
	<a href={href} class="card-cover" aria-label={`View course: ${course.title}`}>
		<span class="sr-only">View course: {course.title}</span>
	</a>

	<div class="card-front">
		<div class="card-image">
			<img src={cardImageUrl} alt={course.title} loading="lazy" />
			{course.price === 'Free' ? (
				<span class="card-badge-price free">Free</span>
			) : (
				course.price && (
					<span class="card-badge-price">
						<CoursePrice price={course.price} colleges={course.colleges} courseSlug={course.slug} />
					</span>
				)
			)}
		</div>
		<div class="card-body">
			<span class="card-label">
				{category ? `${category.icon ?? ''} ${category.name}` : 'Course'}
			</span>
			<h3 class="card-title">{course.title}</h3>
			{college && <p class="card-brand">{college.name}</p>}
			<p class="card-excerpt" set:html={descriptionHtml} />
			<span class="card-cta">View course details →</span>
		</div>
	</div>
</article>
