---
/**
 * Resources Guide — long-form shell for `/resources/blog/*` guides (Campus-style):
 * gradient hero, numbered TOC, author card, optional sidebar CTA, shared MDX body styles.
 * Pass JSON-LD and extra `<head>` markup via `<Fragment slot="head">` or `slot="head"` on nodes.
 */
import Layout from '../../layouts/Layout.astro';
import GiscusComments from './GiscusComments.astro';

export interface ResourcesGuideTocItem {
	href: string;
	label: string;
}

export interface ResourcesGuideSidebarCta {
	intro: string;
	href: string;
	buttonLabel: string;
}

/** Middle segments between Home and the page title. Default: Resources → Guides. */
export interface ResourcesGuideBreadcrumbSegment {
	label: string;
	href: string;
}

interface Props {
	title: string;
	description: string;
	/** Path only, e.g. `/resources/blog/my-slug` */
	canonical: string;
	image: string;
	layoutTitle?: string;
	categoryLabel?: string;
	breadcrumbTitle: string;
	/**
	 * Breadcrumb after Home. Defaults to Resources → Guides for `/resources/blog/*` articles.
	 * Use `[{ label: 'Colleges', href: '/colleges' }]` for college-only guides under `/colleges/*`.
	 */
	breadcrumbTrail?: ResourcesGuideBreadcrumbSegment[];
	author: string;
	authorTitle?: string;
	readingTime: string;
	updatedDate: string;
	tags?: string[];
	tocItems: ResourcesGuideTocItem[];
	sidebarCta?: ResourcesGuideSidebarCta;
}

const defaultBreadcrumbTrail: ResourcesGuideBreadcrumbSegment[] = [
	{ label: 'Resources', href: '/resources' },
	{ label: 'Guides', href: '/resources/guides' },
];

const {
	title,
	description,
	canonical,
	image,
	layoutTitle = `${title} | Online College Courses`,
	categoryLabel = 'Guide',
	breadcrumbTitle,
	breadcrumbTrail = defaultBreadcrumbTrail,
	author,
	authorTitle = 'Editorial',
	readingTime,
	updatedDate,
	tags = [],
	tocItems,
	sidebarCta,
} = Astro.props;

const authorParts = author.trim().split(/\s+/).filter(Boolean);
const authorInitials =
	authorParts.length >= 2
		? (authorParts[0][0] + authorParts[1][0]).toUpperCase()
		: author.slice(0, 2).toUpperCase();
---

<Layout title={layoutTitle} description={description} type="article" canonical={canonical} image={image}>
	<slot name="head" slot="head" />

	<div class="breadcrumb-bar">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				{breadcrumbTrail.map((segment) => (
					<>
						<span>›</span>
						<a href={segment.href}>{segment.label}</a>
					</>
				))}
				<span>›</span>
				<span>{breadcrumbTitle}</span>
			</nav>
		</div>
	</div>

	<header class="article-hero">
		<div class="container">
			<div class="article-label">{categoryLabel}</div>
			<h1>{title}</h1>
			<p class="article-subtitle">{description}</p>
			<div class="article-meta">
				<span class="meta-item">Updated {updatedDate}</span>
				<span class="meta-dot">·</span>
				<span class="meta-item">{readingTime}</span>
				<span class="meta-dot">·</span>
				<span class="meta-item">By {author}</span>
			</div>
			<div class="article-tags">
				{tags.map((tag) => (
					<span class="tag">{tag}</span>
				))}
			</div>
		</div>
	</header>

	<div class="article-layout">
		<div class="container">
			<div class="article-body">
				<aside class="toc-sidebar">
					<div class="toc-card">
						<div class="toc-title">Table of Contents</div>
						<ol class="toc-list">
							{tocItems.map((item) => (
								<li>
									<a href={item.href}>{item.label}</a>
								</li>
							))}
						</ol>
					</div>
					<div class="author-card">
						<div class="author-avatar">{authorInitials}</div>
						<div class="author-info">
							<div class="author-name">{author}</div>
							<div class="author-title">{authorTitle}</div>
						</div>
					</div>
					{
						sidebarCta && (
							<div class="sidebar-cta">
								<p>{sidebarCta.intro}</p>
								<a href={sidebarCta.href} class="cta-btn">
									{sidebarCta.buttonLabel}
								</a>
							</div>
						)
					}
				</aside>

				<article class="article-content">
					<slot />
					<GiscusComments />
				</article>
			</div>
		</div>
	</div>
</Layout>

<style is:global>
	.breadcrumb-bar {
		background: #f8fafc;
		border-bottom: 1px solid #e2e8f0;
		padding: 0.75rem 0;
	}
	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		color: #64748b;
	}
	.breadcrumb a {
		color: #2563eb;
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}
	.breadcrumb span {
		color: #94a3b8;
	}

	.article-hero {
		background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
		color: white;
		padding: 3.5rem 0 3rem;
	}
	.article-label {
		display: inline-block;
		background: rgba(255, 255, 255, 0.15);
		color: white;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 12px;
		border-radius: 4px;
		margin-bottom: 1rem;
		backdrop-filter: blur(4px);
	}
	.article-hero h1 {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.03em;
		margin-bottom: 1rem;
		max-width: 820px;
	}
	.article-subtitle {
		font-size: 1.125rem;
		color: rgba(255, 255, 255, 0.82);
		max-width: 680px;
		line-height: 1.6;
		margin-bottom: 1.25rem;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.75);
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.meta-dot {
		opacity: 0.5;
	}
	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		background: rgba(255, 255, 255, 0.12);
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.75rem;
		font-weight: 600;
		padding: 4px 10px;
		border-radius: 4px;
		backdrop-filter: blur(4px);
	}

	.article-layout {
		padding: 3rem 0 5rem;
		background: #fff;
	}
	.article-body {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 3rem;
		align-items: start;
	}

	.toc-sidebar {
		position: sticky;
		top: 80px;
	}
	.toc-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.25rem;
		margin-bottom: 1.25rem;
	}
	.toc-title {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #64748b;
		margin-bottom: 0.875rem;
	}
	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		counter-reset: toc;
	}
	.toc-list li {
		counter-increment: toc;
		padding-left: 0;
		position: relative;
	}
	.toc-list li::before {
		content: counter(toc) '.';
		position: absolute;
		left: 0;
		top: 0.35rem;
		font-size: 0.8rem;
		color: #94a3b8;
		font-weight: 600;
		width: 1.25rem;
		text-align: right;
	}
	.toc-list a {
		display: block;
		padding: 0.35rem 0.5rem 0.35rem 1.5rem;
		font-size: 0.875rem;
		color: #475569;
		text-decoration: none;
		border-radius: 5px;
		transition:
			background 0.12s,
			color 0.12s;
		line-height: 1.4;
	}
	.toc-list a:hover {
		background: #eff6ff;
		color: #1d4ed8;
	}
	.author-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.25rem;
		display: flex;
		align-items: center;
		gap: 0.875rem;
		margin-bottom: 1.25rem;
	}
	.author-avatar {
		width: 44px;
		height: 44px;
		background: linear-gradient(135deg, #2563eb, #0284c7);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.875rem;
		font-weight: 700;
		flex-shrink: 0;
	}
	.author-name {
		font-size: 0.875rem;
		font-weight: 700;
		color: #0f172a;
	}
	.author-title {
		font-size: 0.75rem;
		color: #64748b;
		margin-top: 2px;
	}
	.sidebar-cta {
		background: #eff6ff;
		border: 1px solid #bfdbfe;
		border-radius: 10px;
		padding: 1.25rem;
		text-align: center;
	}
	.sidebar-cta p {
		font-size: 0.875rem;
		color: #1e40af;
		font-weight: 600;
		margin: 0 0 0.75rem;
	}
	.cta-btn {
		display: inline-block;
		background: #dc2626;
		color: #fff !important;
		font-size: 0.8rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 9px 18px;
		border-radius: 6px;
		text-decoration: none !important;
		transition: background 0.15s;
	}
	.cta-btn:hover {
		background: #b91c1c;
	}

	.article-content {
		min-width: 0;
	}
	.article-content p {
		font-size: 1rem;
		color: #374151;
		line-height: 1.85;
		margin-bottom: 1.35rem;
	}
	.article-content section {
		margin-bottom: 3.25rem;
	}
	.article-content h2 {
		font-size: 1.625rem;
		font-weight: 800;
		color: #0f172a;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.35rem;
		line-height: 1.32;
		scroll-margin-top: 5rem;
		transition: color 0.18s ease;
	}
	.article-content h2:hover {
		color: #2563eb;
	}
	.article-content h3 {
		font-size: 1.2rem;
		font-weight: 700;
		color: #0f172a;
		margin: 2rem 0 1rem;
		line-height: 1.35;
		scroll-margin-top: 5rem;
		transition: color 0.18s ease;
	}
	.article-content h3:hover {
		color: #2563eb;
	}
	.article-content h4 {
		font-size: 1.0625rem;
		font-weight: 700;
		color: #0f172a;
		margin: 1.5rem 0 0.65rem;
		line-height: 1.35;
		scroll-margin-top: 5rem;
		transition: color 0.18s ease;
	}
	.article-content h4:hover {
		color: #2563eb;
	}
	/*
	 * External + course links: blend with text, blue on hover.
	 * !important beats Layout.astro global `a` / `a:hover` (would otherwise force primary blue always).
	 */
	.article-content a.link-external,
	.article-content a.link-course,
	.article-content a.link-external:visited,
	.article-content a.link-course:visited,
	.article-content .faq-item summary a.link-external,
	.article-content .faq-item summary a.link-external:visited {
		color: inherit !important;
		text-decoration: none !important;
		transition: color 0.15s ease;
	}
	.article-content a.link-external strong,
	.article-content a.link-course strong {
		color: inherit !important;
		font-weight: 700;
	}
	.article-content strong a.link-external,
	.article-content strong a.link-course,
	.article-content td a.link-external,
	.article-content td a.link-course {
		color: inherit !important;
	}
	.article-content .facts-table td a.link-course,
	.article-content .facts-table td a.link-external {
		color: #0f172a !important;
		font-weight: 600;
	}
	.article-content a.link-external:hover,
	.article-content a.link-external:hover strong,
	.article-content a.link-course:hover,
	.article-content a.link-course:hover strong,
	.article-content .facts-table td a.link-external:hover,
	.article-content .facts-table td a.link-external:hover strong,
	.article-content .facts-table td a.link-course:hover,
	.article-content .facts-table td a.link-course:hover strong,
	.article-content .faq-item p a.link-external:hover,
	.article-content .faq-item p a.link-external:hover strong,
	.article-content .faq-item p a.link-course:hover,
	.article-content .faq-item p a.link-course:hover strong,
	.article-content .faq-item summary a.link-external:hover,
	.article-content li a.link-external:hover,
	.article-content li a.link-external:hover strong,
	.article-content li a.link-course:hover,
	.article-content li a.link-course:hover strong {
		color: #2563eb !important;
		text-decoration: none !important;
	}
	/* Any other links in the article (fallback) */
	.article-content a:not(.link-external):not(.link-course) {
		color: #2563eb;
		text-decoration: underline;
	}
	.article-content a:not(.link-external):not(.link-course):hover {
		color: #1d4ed8;
	}
	.section-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #2563eb;
		margin-bottom: 0.25rem;
	}

	.summary-box {
		background: #eff6ff;
		border-left: 4px solid #2563eb;
		border-radius: 0 10px 10px 0;
		padding: 1.5rem 1.75rem;
		margin-bottom: 2.75rem;
	}
	.summary-label {
		font-size: 0.875rem;
		font-weight: 700;
		color: #1d4ed8;
		margin-bottom: 0.5rem;
	}
	.summary-box p {
		margin: 0;
		color: #1e3a8a;
		font-size: 0.9375rem;
		line-height: 1.7;
	}

	.accred-box {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.accred-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1rem 1.125rem;
	}
	.accred-icon {
		font-size: 1.375rem;
		flex-shrink: 0;
		line-height: 1;
		margin-top: 2px;
	}
	.accred-item strong {
		display: block;
		font-size: 0.9375rem;
		color: #0f172a;
		margin-bottom: 0.25rem;
	}
	.accred-item p {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.55;
		margin: 0;
	}

	.programs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.program-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.125rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		transition:
			border-color 0.15s,
			box-shadow 0.15s;
	}
	.program-card:hover {
		border-color: #2563eb;
		box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
	}
	.program-icon {
		font-size: 1.5rem;
		line-height: 1;
	}
	.program-name {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #0f172a;
	}
	.program-card p {
		font-size: 0.8125rem;
		color: #64748b;
		line-height: 1.55;
		margin: 0;
		flex: 1;
	}
	.program-card a {
		font-size: 0.8125rem;
		font-weight: 600;
		color: #2563eb;
		text-decoration: none;
		margin-top: auto;
	}
	.program-card a:hover {
		text-decoration: underline;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.info-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.125rem 1.25rem;
	}
	.info-card h4 {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #0f172a;
		margin-bottom: 0.375rem;
	}
	.info-card p {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.6;
		margin: 0;
	}

	.support-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.support-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1rem 1.125rem;
	}
	.support-icon {
		font-size: 1.5rem;
		flex-shrink: 0;
		line-height: 1;
		margin-top: 2px;
	}
	.support-body strong {
		display: block;
		font-size: 0.9375rem;
		color: #0f172a;
		margin-bottom: 0.25rem;
	}
	.support-body p {
		font-size: 0.875rem;
		color: #64748b;
		line-height: 1.6;
		margin: 0;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin: 1.5rem 0;
	}
	.stat-card {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 1.25rem;
		text-align: center;
	}
	.stat-number {
		font-size: 1.75rem;
		font-weight: 800;
		color: #2563eb;
		letter-spacing: -0.03em;
	}
	.stat-label {
		font-size: 0.8125rem;
		color: #64748b;
		margin-top: 0.25rem;
		line-height: 1.4;
	}

	.two-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin: 1.25rem 0;
	}
	.fit-card {
		border-radius: 10px;
		padding: 1.25rem;
		border: 1px solid;
	}
	.fit-card.good {
		background: #f0fdf4;
		border-color: #86efac;
	}
	.fit-card.less {
		background: #fffbeb;
		border-color: #fcd34d;
	}
	.fit-heading {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #0f172a;
		margin-bottom: 0.75rem;
	}
	.fit-card ul {
		padding-left: 1.25rem;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}
	.fit-card li {
		font-size: 0.875rem;
		color: #374151;
		line-height: 1.55;
	}

	.pros-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 1.25rem 0;
	}
	.pro-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		background: #f0fdf4;
		border: 1px solid #86efac;
		border-radius: 10px;
		padding: 1rem 1.25rem;
		font-size: 0.9375rem;
		color: #374151;
		line-height: 1.65;
	}
	.pro-check {
		width: 24px;
		height: 24px;
		background: #16a34a;
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.8rem;
		font-weight: 800;
		flex-shrink: 0;
		margin-top: 1px;
	}

	.cons-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 1.25rem 0;
	}
	.con-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		background: #fff7ed;
		border: 1px solid #fed7aa;
		border-radius: 10px;
		padding: 1rem 1.25rem;
		font-size: 0.9375rem;
		color: #374151;
		line-height: 1.65;
	}
	.con-x {
		width: 24px;
		height: 24px;
		background: #ea580c;
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.8rem;
		font-weight: 800;
		flex-shrink: 0;
		margin-top: 1px;
	}

	.table-wrap {
		overflow-x: auto;
		margin: 1.5rem 0 2rem;
		-webkit-overflow-scrolling: touch;
		border-radius: 12px;
		border: 1px solid #e2e8f0;
		background: #fff;
