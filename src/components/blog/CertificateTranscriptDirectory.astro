---
interface Props {
	/** Number of placeholder slots to render. */
	placeholderCount?: number;
}

const { placeholderCount = 12 } = Astro.props;
---

<section class="cert-hub" id="search-programs" aria-labelledby="cert-hub-title">
	<div class="cert-hub__intro">
		<h2 id="cert-hub-title" class="cert-hub__title">Search accredited certificate programs (coming soon)</h2>
		<p class="cert-hub__lede">
			We are building a searchable directory of <strong>accredited certificate programs</strong> that may count toward transferable college credit.
			This section is intentionally showing <strong>placeholder slots</strong> for now—we will populate it with programs you provide as we add them.
		</p>
		<p class="cert-hub__jump">
			<a href="#guide" class="cert-hub__jump-link">Skip to the full guide ↓</a>
		</p>
	</div>

	<div class="cert-hub__grid" aria-label="Certificate program placeholders">
		{Array.from({ length: placeholderCount }).map((_, i) => (
			<div class="cert-hub__placeholder" aria-label={`Placeholder program slot ${i + 1}`}>
				<div class="cert-hub__ph-img" aria-hidden="true" />
				<div class="cert-hub__ph-body">
					<div class="cert-hub__ph-line cert-hub__ph-line--sm" aria-hidden="true" />
					<div class="cert-hub__ph-line cert-hub__ph-line--lg" aria-hidden="true" />
					<div class="cert-hub__ph-line" aria-hidden="true" />
					<div class="cert-hub__ph-chip" aria-hidden="true" />
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.cert-hub {
		margin: 0 0 2.5rem;
		padding: 1.5rem 1.25rem 2rem;
		background: linear-gradient(180deg, #f8fafc 0%, #fff 40%);
		border: 1px solid #e2e8f0;
		border-radius: 14px;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
	}
	.cert-hub__intro {
		margin-bottom: 1.5rem;
	}
	.cert-hub__title {
		font-size: clamp(1.25rem, 2.5vw, 1.5rem);
		font-weight: 800;
		color: #0f172a;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
		line-height: 1.25;
	}
	.cert-hub__lede {
		font-size: 0.95rem;
		line-height: 1.65;
		color: #475569;
		margin: 0 0 0.75rem;
		max-width: 72ch;
	}
	.cert-hub__jump {
		margin: 0;
		font-size: 0.9rem;
	}
	.cert-hub__jump-link {
		font-weight: 600;
		color: #2563eb;
		text-decoration: none;
	}
	.cert-hub__jump-link:hover {
		text-decoration: underline;
	}
	.cert-hub__empty {
		padding: 1.5rem;
		background: #fffbeb;
		border: 1px solid #fde68a;
		border-radius: 10px;
		color: #78350f;
		font-size: 0.95rem;
	}
	.cert-hub__empty a {
		color: #b45309;
		font-weight: 600;
	}
	.cert-hub__filters {
		margin-bottom: 1.5rem;
	}
	.cert-hub__filters-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-bottom: 1rem;
	}
	.cert-hub__filters-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		color: #334155;
	}
	.cert-hub__count {
		margin: 0;
		font-size: 0.875rem;
		color: #64748b;
	}
	.cert-hub__count span {
		font-weight: 700;
		color: #2563eb;
	}
	.cert-hub__search {
		margin-bottom: 1rem;
	}
	.cert-hub__search-input {
		width: 100%;
		padding: 0.75rem 1rem;
		border: 2px solid #e2e8f0;
		border-radius: 10px;
		font-size: 1rem;
		color: #0f172a;
		background: #fff;
	}
	.cert-hub__search-input:focus {
		outline: none;
		border-color: #2563eb;
		box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
	}
	.cert-hub__filter-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 0.75rem 1rem;
	}
	.cert-hub__field label {
		display: block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #64748b;
		margin-bottom: 0.35rem;
	}
	.cert-hub__select {
		width: 100%;
		padding: 0.55rem 0.65rem;
		border: 1px solid #cbd5e1;
		border-radius: 8px;
		font-size: 0.9rem;
		background: #fff;
		color: #0f172a;
	}
	.cert-hub__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.25rem;
	}
	.cert-hub__placeholder {
		border-radius: 12px;
		border: 1px solid #e2e8f0;
		background: #fff;
		overflow: hidden;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
	}
	.cert-hub__ph-img {
		height: 160px;
		background: #f1f5f9;
		position: relative;
		overflow: hidden;
	}
	.cert-hub__ph-body {
		padding: 1.1rem 1.25rem 1.35rem;
		display: grid;
		gap: 0.55rem;
	}
	.cert-hub__ph-line,
	.cert-hub__ph-chip {
		background: #e2e8f0;
		border-radius: 8px;
		height: 12px;
		position: relative;
		overflow: hidden;
	}
	.cert-hub__ph-line--sm {
		width: 40%;
		height: 10px;
	}
	.cert-hub__ph-line--lg {
		width: 78%;
		height: 14px;
	}
	.cert-hub__ph-chip {
		width: 36%;
		height: 22px;
		border-radius: 999px;
		margin-top: 0.2rem;
	}

	@media (prefers-reduced-motion: no-preference) {
		.cert-hub__ph-img::after,
		.cert-hub__ph-line::after,
		.cert-hub__ph-chip::after {
			content: '';
			position: absolute;
			inset: 0;
			transform: translateX(-100%);
			background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
			animation: certHubShimmer 1.35s infinite;
		}
	}
	@keyframes certHubShimmer {
		100% {
			transform: translateX(100%);
		}
	}
	.cert-hub__no-results {
		text-align: center;
		padding: 2rem 1rem;
		color: #64748b;
		font-size: 0.95rem;
	}
	.cert-hub__no-results[hidden] {
		display: none;
	}
	@media (max-width: 640px) {
		.cert-hub__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
