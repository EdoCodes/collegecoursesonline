---
/**
 * Giscus comments widget.
 * Repo: EdoCodes/collegecoursesonline (R_kgDORUyy6w)
 * Category: General — swap data-category-id once you confirm from giscus.app.
 * To find your category ID: giscus.app → enter repo → pick category → copy DIC_... value.
 */
const { pageUrl = '' } = Astro.props;
---

<section class="giscus-section" aria-label="Discussion">
	<div class="giscus-header">
		<span class="giscus-header__icon" aria-hidden="true">💬</span>
		<h2 class="giscus-header__title">Join the discussion</h2>
		<p class="giscus-header__sub">
			Have a question or something to add? Sign in with GitHub to leave a comment.
		</p>
	</div>

	<div class="giscus-widget-wrap">
		<script
			is:inline
			src="https://giscus.app/client.js"
			data-repo="EdoCodes/collegecoursesonline"
			data-repo-id="R_kgDORUyy6w"
			data-category="General"
			data-category-id="DIC_kwDORUyy684ClVmN"
			data-mapping="pathname"
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="0"
			data-input-position="top"
			data-theme="light"
			data-lang="en"
			data-loading="lazy"
			crossorigin="anonymous"
			async
		></script>
	</div>
</section>

<style>
	.giscus-section {
		margin: 3rem 0 1rem;
		padding-top: 2rem;
		border-top: 2px solid #e2e8f0;
	}
	.giscus-header {
		margin-bottom: 1.5rem;
	}
	.giscus-header__icon {
		font-size: 1.5rem;
		display: block;
		margin-bottom: 0.35rem;
	}
	.giscus-header__title {
		font-size: 1.25rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 0.35rem;
	}
	.giscus-header__sub {
		font-size: 0.875rem;
		color: #64748b;
		margin: 0;
	}
	.giscus-widget-wrap {
		border-radius: 12px;
		overflow: hidden;
	}
</style>
