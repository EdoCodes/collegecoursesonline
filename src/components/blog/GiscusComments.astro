---
import AskQuestionForm from './AskQuestionForm.astro';
/**
 * Giscus comments widget + no-login question form fallback.
 * Repo: EdoCodes/collegecoursesonline (R_kgDORUyy6w)
 */
interface Props {
	pageTitle?: string;
}
const { pageTitle = 'General' } = Astro.props;
---

<section class="giscus-section" id="giscus-section" aria-label="Discussion">
	<div class="giscus-header">
		<span class="giscus-header__icon" aria-hidden="true">💬</span>
		<h2 class="giscus-header__title">Join the discussion</h2>
		<p class="giscus-header__sub">
			Have a GitHub account? Leave a comment below. No GitHub? Use the form underneath.
		</p>
	</div>

	<div class="giscus-widget-wrap">
		<script
			is:inline
			src="https://giscus.app/client.js"
			data-repo="EdoCodes/collegecoursesonline"
			data-repo-id="R_kgDORUyy6w"
			data-category="General"
			data-category-id="DIC_kwDORUyy684ClVmN"
			data-mapping="pathname"
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="0"
			data-input-position="top"
			data-theme="light"
			data-lang="en"
			data-loading="lazy"
			crossorigin="anonymous"
			async
		></script>
	</div>

	<AskQuestionForm pageTitle={pageTitle} />
</section>

<style>
	.giscus-section {
		margin: 3rem 0 1rem;
		padding-top: 2rem;
		border-top: 2px solid #e2e8f0;
	}
	.giscus-header {
		margin-bottom: 1.5rem;
	}
	.giscus-header__icon {
		font-size: 1.5rem;
		display: block;
		margin-bottom: 0.35rem;
	}
	.giscus-header__title {
		font-size: 1.25rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 0.35rem;
	}
	.giscus-header__sub {
		font-size: 0.875rem;
		color: #64748b;
		margin: 0;
	}
	.giscus-widget-wrap {
		border-radius: 12px;
		overflow: hidden;
	}
</style>
