---
import AskQuestionForm from './AskQuestionForm.astro';

interface Props {
	pageTitle?: string;
}
const { pageTitle = 'General' } = Astro.props;
---

<section class="giscus-section" id="giscus-section" aria-label="Discussion">
	<div class="giscus-header">
		<span class="giscus-header__icon" aria-hidden="true">💬</span>
		<h2 class="giscus-header__title">Have a question?</h2>
		<p class="giscus-header__sub">
			Ask below — no account needed. Or visit the <a href="/forum">community forum</a> to browse all questions by topic.
		</p>
	</div>
	<AskQuestionForm pageTitle={pageTitle} />
</section>

<style>
	.giscus-section {
		margin: 3rem 0 1rem;
		padding-top: 2rem;
		border-top: 2px solid #e2e8f0;
	}
	.giscus-header {
		margin-bottom: 1.5rem;
	}
	.giscus-header__icon {
		font-size: 1.5rem;
		display: block;
		margin-bottom: 0.35rem;
	}
	.giscus-header__title {
		font-size: 1.25rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 0.35rem;
	}
	.giscus-header__sub {
		font-size: 0.875rem;
		color: #64748b;
		margin: 0;
	}
	.giscus-widget-wrap {
		border-radius: 12px;
		overflow: hidden;
	}
</style>
