---
import type { CertificateProgram } from '../../data/certificatePrograms';

interface Props {
	program: CertificateProgram;
	/** Optional: fill empty slots with a subtle “Coming soon” label. */
	comingSoonLabel?: string;
}

const { program, comingSoonLabel } = Astro.props;
const href = `/certificate-programs/${program.slug}/`;
---

<article class="card card--has-overlay" data-program-slug={program.slug}>
	<a href={href} class="card-cover" aria-label={`View certificate program: ${program.title}`}>
		<span class="sr-only">View certificate program: {program.title}</span>
	</a>

	<div class="card-front">
		<div class="card-image">
			<img src={program.image} alt={program.imageAlt ?? program.title} loading="lazy" />
			{comingSoonLabel && <span class="card-badge-price">{comingSoonLabel}</span>}
		</div>
		<div class="card-body">
			<span class="card-label">{program.categoryLabel}</span>
			<h3 class="card-title">{program.title}</h3>
			<p class="card-brand">{program.providerName}</p>
			<p class="card-excerpt">{program.shortDescription}</p>
			<span class="card-cta">View program details →</span>
		</div>
	</div>
</article>

