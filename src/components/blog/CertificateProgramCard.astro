---
import type { CertificateProgram } from '../../data/certificatePrograms';

interface Props {
	program: CertificateProgram;
	/** Optional: fill empty slots with a subtle “Coming soon” label. */
	comingSoonLabel?: string;
}

const { program, comingSoonLabel } = Astro.props;
const href = `/certificate-programs/${program.slug}/`;
---

<article class="cert-card card card--has-overlay">
	<a href={href} class="card-cover" aria-label={`View certificate program: ${program.title}`}>
		<span class="sr-only">View certificate program: {program.title}</span>
	</a>

	<div class="card-front">
		<div class="card-image">
			<img src={program.image} alt={program.title} loading="lazy" />
			{comingSoonLabel && <span class="cert-card-badge">{comingSoonLabel}</span>}
		</div>
		<div class="card-body">
			<span class="card-label">{program.categoryLabel}</span>
			<h3 class="card-title">{program.title}</h3>
			<p class="card-brand">{program.providerName}</p>
			<p class="card-excerpt">{program.shortDescription}</p>
			<span class="card-cta">View program details →</span>
		</div>
	</div>
</article>

<style>
	.cert-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		overflow: hidden;
		color: inherit;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease;
		height: 100%;
	}
	.cert-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 32px rgba(0, 0, 0, 0.09);
		border-color: #2563eb;
	}
	.cert-card .card-image {
		position: relative;
		width: 100%;
		height: 180px;
		overflow: hidden;
		background: #f1f5f9;
		flex-shrink: 0;
	}
	.cert-card .card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}
	.cert-card:hover .card-image img {
		transform: scale(1.05);
	}
	.cert-card .card-body {
		padding: 1.1rem 1.25rem 1.35rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.cert-card .card-label {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #2563eb;
		margin-bottom: 0.45rem;
		display: inline-block;
	}
	.cert-card .card-title {
		font-size: 1.05rem;
		font-weight: 800;
		color: #0f172a;
		line-height: 1.35;
		margin: 0 0 0.5rem;
		letter-spacing: -0.02em;
	}
	.cert-card:hover .card-title {
		color: #2563eb;
	}
	.cert-card .card-brand {
		font-size: 0.8rem;
		color: #94a3b8;
		margin: 0 0 0.5rem;
		font-weight: 600;
	}
	.cert-card .card-excerpt {
		font-size: 0.82rem;
		color: #334155;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
		margin: 0 0 0.75rem;
	}
	.cert-card .card-cta {
		font-size: 0.82rem;
		font-weight: 700;
		color: #2563eb;
		margin-top: auto;
	}
	.cert-card-badge {
		position: absolute;
		top: 10px;
		left: 10px;
		padding: 3px 9px;
		background: rgba(2, 132, 199, 0.92);
		color: #fff;
		font-size: 0.72rem;
		font-weight: 800;
		border-radius: 999px;
		backdrop-filter: blur(8px);
	}
</style>

