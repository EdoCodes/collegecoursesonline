---
import Layout from '../../layouts/Layout.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbItems: { label: string; href?: string }[];
  heroLabel?: string;
  heroSubtitle?: string;
  updatedDate?: string;
  readingTime?: string;
  author?: string;
  tags?: string[];
  heroImage?: string;
  /** Open Graph / Twitter image (defaults in Layout if omitted). */
  image?: string;
  tocItems?: { id: string; label: string }[];
  canonical?: string;
}

const {
  title,
  description,
  breadcrumbItems,
  heroLabel,
  heroSubtitle,
  updatedDate,
  readingTime,
  author = 'Editorial Team',
  tags = [],
  heroImage,
  image,
  tocItems = [],
  canonical,
} = Astro.props;
---

<Layout title={title} description={description} type="article" canonical={canonical} image={image}>
  <slot name="schema" />

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        {breadcrumbItems.map((item, i) => (
          <>
            {i > 0 ? <span class="crumb-sep">›</span> : ''}
            {item.href ? <a href={item.href}>{item.label}</a> : <span class="crumb-current">{item.label}</span>}
          </>
        ))}
      </nav>
    </div>
  </div>

  <!-- Article Hero -->
  <header class="article-hero">
    {heroImage && (
      <div class="hero-image-wrap">
        <img src={heroImage} alt="" class="hero-image" />
        <div class="hero-overlay" />
      </div>
    )}
    <div class="container hero-content">
      {heroLabel && <div class="article-label">{heroLabel}</div>}
      <h1>{title}</h1>
      {heroSubtitle && <p class="article-subtitle">{heroSubtitle}</p>}
      <div class="article-meta">
        {updatedDate && <span class="meta-item">Updated {updatedDate}</span>}
        {updatedDate && readingTime && <span class="meta-dot">·</span>}
        {readingTime && <span class="meta-item">{readingTime}</span>}
        {readingTime && author && <span class="meta-dot">·</span>}
        {author && <span class="meta-item">By {author}</span>}
      </div>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </header>

  <!-- Main Content -->
  <div class="article-layout">
    <div class="container">
      <div class="article-body">
        <!-- Sidebar TOC -->
        {tocItems.length > 0 && (
          <aside class="toc-sidebar">
            <div class="toc-card">
              <div class="toc-title">Table of Contents</div>
              <ol class="toc-list">
                {tocItems.map((item) => (
                  <li>
                    <a href={`#${item.id}`}>{item.label}</a>
                  </li>
                ))}
              </ol>
            </div>
          </aside>
        )}

        <!-- Main Article -->
        <article class="article-content">
          <slot />
        </article>
      </div>
    </div>
  </div>
</Layout>

<style>
  .breadcrumb-bar {
    background: var(--color-bg-light);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
    flex-wrap: wrap;
  }
  .crumb-sep { opacity: 0.6; }
  .breadcrumb a {
    color: var(--color-text-light);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-primary); }
  .crumb-current { color: var(--color-navy); font-weight: 500; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .article-hero {
    position: relative;
    background: linear-gradient(160deg, #1e3a5f 0%, #1e40af 50%, #0284c7 100%);
    color: white;
    padding: 4rem 0 3.5rem;
    text-align: center;
  }
  .hero-image-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15,23,42,0.7) 0%, rgba(30,58,138,0.9) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .article-label {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.35);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.35rem 0.9rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }
  .article-hero h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    max-width: 720px;
    margin: 0 auto 0.875rem;
  }
  .article-subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.9);
    max-width: 600px;
    margin: 0 auto 1.25rem;
    line-height: 1.6;
  }
  .article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .meta-dot { opacity: 0.5; }
  .article-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .tag {
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.95);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
  }

  /* Two-column layout */
  .article-layout { padding: 3rem 0 5rem; }
  .article-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* TOC */
  .toc-sidebar { position: sticky; top: 88px; }
  .toc-card {
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.25rem;
  }
  .toc-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .toc-list li a {
    font-size: 0.8125rem;
    color: var(--color-text-medium);
    text-decoration: none;
    display: block;
    padding: 0.375rem 0.5rem;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
    line-height: 1.4;
  }
  .toc-list li a:hover {
    background: var(--color-border-light);
    color: var(--color-primary);
  }

  /* Article content - optimal reading width */
  .article-content {
    max-width: 72ch;
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .article-body { grid-template-columns: 1fr; }
    .toc-sidebar { display: none; }
    .article-content { max-width: none; }
  }
  @media (max-width: 768px) {
    .article-hero { padding: 2.5rem 0 2rem; }
  }
</style>
