---
/**
 * Embeds a YouTube video (use from MDX so the iframe is not dropped by the MDX pipeline).
 */
interface Props {
	videoId: string;
	title: string;
}
const { videoId, title } = Astro.props;
const src = `https://www.youtube.com/embed/${encodeURIComponent(videoId)}`;
---

<div class="youtube-embed">
	<iframe
		src={src}
		title={title}
		loading="lazy"
		allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		allowfullscreen
	></iframe>
</div>

<style>
	.youtube-embed {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 1.5rem 0 0;
		border-radius: 12px;
		overflow: hidden;
		background: #0f172a;
	}
	.youtube-embed iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>
