---
interface Props {
  universityName: string;
  programName: string;
  description: string;
  bannerSrc?: string;
  logoSrc?: string;
  logoAlt?: string;
  tuition?: string;
  duration?: string;
  credits?: string;
  accreditation?: string;
  badges?: string[];
  href: string;
  applyHref?: string;
}

const {
  universityName,
  programName,
  description,
  bannerSrc,
  logoSrc,
  logoAlt,
  tuition,
  duration,
  credits,
  accreditation,
  badges = [],
  href,
  applyHref,
} = Astro.props;

const initials = universityName
  .split(' ')
  .filter(w => w.length > 2)
  .slice(0, 4)
  .map(w => w[0])
  .join('');
---

<div class="upc">
  <!-- Banner image -->
  <div class="upc-banner">
    {bannerSrc
      ? <img src={bannerSrc} alt={universityName} loading="lazy" />
      : <div class="upc-banner-placeholder" />
    }
    {accreditation && (
      <span class="upc-accreditation">{accreditation}</span>
    )}
  </div>

  <!-- Card body -->
  <div class="upc-body">
    <!-- Logo + university name row -->
    <div class="upc-header">
      <div class="upc-logo">
        {logoSrc
          ? <img src={logoSrc} alt={logoAlt ?? universityName} />
          : <span class="upc-logo-initials">{initials}</span>
        }
      </div>
      <div class="upc-header-text">
        <a href={href} target="_blank" rel="noopener noreferrer" class="upc-university-name">
          {universityName}
        </a>
        <p class="upc-program-name">{programName}</p>
      </div>
    </div>

    <!-- Description -->
    <p class="upc-description">{description}</p>

    <!-- Stat pills -->
    {(tuition || duration || credits) && (
      <div class="upc-stats">
        {tuition && (
          <div class="upc-stat">
            <span class="upc-stat-label">Tuition</span>
            <span class="upc-stat-value">{tuition}</span>
          </div>
        )}
        {duration && (
          <div class="upc-stat">
            <span class="upc-stat-label">Duration</span>
            <span class="upc-stat-value">{duration}</span>
          </div>
        )}
        {credits && (
          <div class="upc-stat">
            <span class="upc-stat-label">Credits</span>
            <span class="upc-stat-value">{credits}</span>
          </div>
        )}
      </div>
    )}

    <!-- Feature badges -->
    {badges.length > 0 && (
      <div class="upc-badges">
        {badges.map(b => <span class="upc-badge">{b}</span>)}
      </div>
    )}

    <!-- CTA buttons -->
    <div class="upc-actions">
      <a href={href} target="_blank" rel="noopener noreferrer" class="upc-btn-primary">
        Visit Website
      </a>
      {applyHref && (
        <a href={applyHref} target="_blank" rel="noopener noreferrer" class="upc-btn-secondary">
          Apply Now
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .upc {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
    transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    max-width: 720px;
  }
  .upc:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(15, 23, 42, 0.12);
    border-color: #2563eb;
  }

  /* ── Banner ── */
  .upc-banner {
    position: relative;
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 60%, #0284c7 100%);
  }
  .upc-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .upc-banner-placeholder {
    width: 100%;
    height: 100%;
  }
  .upc-accreditation {
    position: absolute;
    top: 12px;
    right: 14px;
    background: rgba(255, 255, 255, 0.92);
    color: #166534;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  /* ── Body ── */
  .upc-body {
    padding: 1.375rem 1.5rem 1.5rem;
  }

  /* ── Header row: logo + name ── */
  .upc-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }
  .upc-logo {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .upc-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }
  .upc-logo-initials {
    font-size: 0.8rem;
    font-weight: 800;
    color: #1e3a8a;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1;
  }
  .upc-header-text { flex: 1; min-width: 0; }
  .upc-university-name {
    display: block;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1e40af;
    text-decoration: none;
    line-height: 1.3;
    margin-bottom: 0.2rem;
  }
  .upc-university-name:hover { text-decoration: underline; }
  .upc-program-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #475569;
    margin: 0;
  }

  /* ── Description ── */
  .upc-description {
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  /* ── Stat pills ── */
  .upc-stats {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }
  .upc-stat {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
    padding: 0.375rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }
  .upc-stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #3b82f6;
    margin-bottom: 0.1rem;
  }
  .upc-stat-value {
    font-size: 0.875rem;
    font-weight: 700;
    color: #1e3a8a;
  }

  /* ── Badges ── */
  .upc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.125rem;
  }
  .upc-badge {
    background: transparent;
    border: 1px solid #d1d5db;
    color: #374151;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 4px;
  }

  /* ── CTA buttons ── */
  .upc-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .upc-btn-primary {
    display: inline-block;
    background: #dc2626;
    color: #ffffff !important;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 9px 20px;
    border-radius: 6px;
    text-decoration: none !important;
    transition: background 0.15s;
  }
  .upc-btn-primary:hover { background: #b91c1c; }
  .upc-btn-secondary {
    display: inline-block;
    background: transparent;
    color: #2563eb !important;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 9px 20px;
    border-radius: 6px;
    border: 1.5px solid #2563eb;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s;
  }
  .upc-btn-secondary:hover {
    background: #2563eb;
    color: #ffffff !important;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .upc-banner { height: 120px; }
    .upc-stats { gap: 0.5rem; }
    .upc-stat { min-width: 70px; }
  }
</style>
