---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">

    <div class="footer-top">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="logo">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          <div class="logo-text">
            <span class="logo-name">College Courses</span>
            <span class="logo-slogan">O N L I N E</span>
          </div>
        </a>
        <p class="brand-description">
          Your trusted guide to finding accredited online courses, degrees, and certificate programs from top institutions worldwide.
        </p>
      </div>

      <!-- Links -->
      <div class="footer-links">

        <div class="link-group">
          <h4>Discover</h4>
          <ul>
            <li><a href="/courses">All Courses</a></li>
            <li><a href="/colleges">Colleges</a></li>
            <li><a href="/resources/blog/certificate-programs-college-credit">Certificate Programs</a></li>
          </ul>
        </div>

        <div class="link-group">
          <h4>Resources</h4>
          <ul>
            <li><a href="/resources/glossary/academic-abbreviations/">Glossary</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/resources/guides">Guides</a></li>
            <li><a href="/resources">Resource center</a></li>
            <li><a href="/submit-course">Submit a Course</a></li>
          </ul>
        </div>

        <div class="link-group">
          <h4>Company</h4>
          <ul>
            <li><a href="/submit-course">Submit a Course</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} College Courses Online. All rights reserved.</p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 3.5rem 0 0;
    margin-top: 4rem;
    border-top: 1px solid #1e293b;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Top section ── */
  .footer-top {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #1e293b;
  }

  /* ── Logo ── */
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    margin-bottom: 1.125rem;
    width: fit-content;
  }

  .logo svg {
    color: #1e40af;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: #f8fafc;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .logo-slogan {
    font-size: 0.6rem;
    font-weight: 700;
    color: #3b82f6;
    letter-spacing: 0.3em;
    line-height: 1;
    text-align: center;
    width: 100%;
  }

  .brand-description {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0;
    max-width: 280px;
  }

  /* ── Link columns ── */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .link-group h4 {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f1f5f9;
    margin-bottom: 1rem;
  }

  .link-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .link-group ul li a {
    font-size: 0.9rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s;
  }

  .link-group ul li a:hover {
    color: #f8fafc;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    padding: 1.25rem 0;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: #475569;
    margin: 0;
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .brand-description { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
