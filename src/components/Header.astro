---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container">
    <nav class="nav-bar">

      <!-- Logo -->
      <a href="/" class="logo">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        <div class="logo-text">
          <span class="logo-name">College Courses</span>
          <span class="logo-slogan">O N L I N E</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <ul class="nav-links">
        <li><a href="/" class={`nav-link${currentPath === '/' ? ' active' : ''}`}>Home</a></li>
        <li><a href="/blog" class={`nav-link${currentPath.startsWith('/blog') ? ' active' : ''}`}>News</a></li>
        <li><a href="/colleges" class={`nav-link${currentPath.startsWith('/colleges') ? ' active' : ''}`}>Colleges</a></li>
        <li><a href="/courses" class={`nav-link${currentPath.startsWith('/courses') ? ' active' : ''}`}>Courses</a></li>
        <li><a href="/categories/certificate-programs" class={`nav-link${currentPath.includes('certificate') ? ' active' : ''}`}>Certificate Programs</a></li>
        <li><a href="/resources" class={`nav-link${currentPath.startsWith('/resources') ? ' active' : ''}`}>Resources</a></li>
      </ul>

      <!-- CTA Button -->
      <a href="/submit-course" class="cta-nav-button">Submit a Course</a>

      <!-- Mobile Menu Button -->
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
        <svg class="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu">
      <ul class="mobile-nav-links">
        <li><a href="/" class="mobile-nav-link">Home</a></li>
        <li><a href="/blog" class="mobile-nav-link">News</a></li>
        <li><a href="/colleges" class="mobile-nav-link">Colleges</a></li>
        <li><a href="/courses" class="mobile-nav-link">Courses</a></li>
        <li><a href="/categories/certificate-programs" class="mobile-nav-link">Certificate Programs</a></li>
        <li><a href="/resources" class="mobile-nav-link">Resources</a></li>
      </ul>
      <a href="/submit-course" class="mobile-cta-button">Submit a Course</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: white;
    border-bottom: 1px solid var(--neutral-200);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 calc(var(--spacing) * 3);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: calc(var(--spacing) * 2.5) 0;
    gap: calc(var(--spacing) * 2);
  }

  /* ── Logo ── */
  .logo {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 1.5);
    text-decoration: none;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .logo svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .logo:hover svg {
    color: var(--color-primary-dark);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--neutral-900);
    line-height: 1.2;
    letter-spacing: -0.02em;
    transition: var(--transition);
  }

  .logo:hover .logo-name {
    color: var(--color-primary);
  }

  .logo-slogan {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.3em;
    line-height: 1;
    text-align: center;
    width: 100%;
  }

  /* ── Desktop Nav ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 2.5);
    list-style: none;
    margin: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    color: var(--neutral-700);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: var(--transition);
    padding: calc(var(--spacing) * 1) 0;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  /* ── CTA Button ── */
  .cta-nav-button {
    display: inline-flex;
    align-items: center;
    padding: calc(var(--spacing) * 1.75) calc(var(--spacing) * 3);
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: calc(var(--border-radius) / 2);
    text-decoration: none;
    transition: var(--transition);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cta-nav-button:hover {
    background: var(--color-primary-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);
  }

  /* ── Mobile toggle ── */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--neutral-700);
    cursor: pointer;
    padding: calc(var(--spacing) * 1);
  }

  /* ── Mobile Menu ── */
  .mobile-menu {
    display: none;
    padding: calc(var(--spacing) * 3) 0;
    border-top: 1px solid var(--neutral-200);
  }

  .mobile-menu.active {
    display: block;
  }

  .mobile-nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 0.5);
    margin-bottom: calc(var(--spacing) * 3);
  }

  .mobile-nav-link {
    display: block;
    padding: calc(var(--spacing) * 2);
    color: var(--neutral-700);
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    border-radius: calc(var(--border-radius) / 2);
    transition: var(--transition);
  }

  .mobile-nav-link:hover {
    background: var(--neutral-100);
    color: var(--color-primary);
  }

  .mobile-cta-button {
    display: block;
    text-align: center;
    padding: calc(var(--spacing) * 2.5);
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border-radius: calc(var(--border-radius) / 2);
    text-decoration: none;
    transition: var(--transition);
  }

  .mobile-cta-button:hover {
    background: var(--color-primary-dark);
    color: white;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .nav-links {
      gap: calc(var(--spacing) * 1.5);
    }
    .nav-link {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 768px) {
    .nav-links,
    .cta-nav-button {
      display: none;
    }
    .mobile-menu-btn {
      display: block;
    }
  }
</style>

<script>
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  const menuIcon = mobileMenuBtn?.querySelector('.menu-icon') as SVGElement;
  const closeIcon = mobileMenuBtn?.querySelector('.close-icon') as SVGElement;

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('active');
    if (mobileMenu?.classList.contains('active')) {
      menuIcon.style.display = 'none';
      closeIcon.style.display = 'block';
    } else {
      menuIcon.style.display = 'block';
      closeIcon.style.display = 'none';
    }
  });
</script>
