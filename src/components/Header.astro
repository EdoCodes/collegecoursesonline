---
import { supabase, isSupabaseConfigured } from '../lib/supabase';

const currentPath = Astro.url.pathname;

// Fetch categories + subcategories for mega-menu
const categoryIcons: Record<string, string> = {
  business: '💼', 'computer-science': '💻', 'data-science': '📊',
  education: '🎓', engineering: '⚙️', health: '🏥',
  humanities: '📚', mathematics: '➗', psychology: '🧠', science: '🔬',
};

let menuCategories: { slug: string; name: string; icon: string; subcategories: { name: string; slug: string; count: number }[] }[] = [];

if (isSupabaseConfigured && supabase) {
  const { data: cats } = await supabase.from('course_categories').select('slug, name').order('name');
  const { data: courses } = await supabase.from('courses').select('subcategory, course_categories(slug)').not('subcategory', 'is', null);

  for (const cat of cats || []) {
    const subMap: Record<string, number> = {};
    for (const c of courses || []) {
      if ((c.course_categories as any)?.slug !== cat.slug) continue;
      const sub = c.subcategory as string;
      subMap[sub] = (subMap[sub] || 0) + 1;
    }
    const subcategories = Object.entries(subMap)
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
        count,
      }));
    if (subcategories.length > 0) {
      menuCategories.push({ slug: cat.slug, name: cat.name, icon: categoryIcons[cat.slug] ?? '📖', subcategories });
    }
  }
}
---

<header class="site-header">
  <div class="container">
    <nav class="nav-bar">

      <!-- Logo -->
      <a href="/" class="logo">
        <svg width="36" height="40" viewBox="0 0 24 28" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <!-- graduation cap — black, hovering above the book -->
          <g stroke="#0f172a" stroke-width="1.75" fill="none">
            <path d="M4 10l8-4 8 4-8 4-8-4z" fill="#0f172a" stroke="none"/>
            <path d="M4 10l8-4 8 4-8 4-8-4z"/>
            <!-- tassel -->
            <line x1="20" y1="10" x2="20" y2="14"/>
            <circle cx="20" cy="14.5" r="0.8" fill="#0f172a" stroke="none"/>
          </g>
          <!-- open book — original design, shifted down -->
          <g stroke="currentColor" stroke-width="2" fill="none">
            <path d="M2 17h6a4 4 0 0 1 4 4v6a3 3 0 0 0-3-3H2z"/>
            <path d="M22 17h-6a4 4 0 0 0-4 4v6a3 3 0 0 1 3-3h7z"/>
          </g>
        </svg>
        <div class="logo-text">
          <span class="logo-name">College Courses</span>
          <span class="logo-slogan">O N L I N E</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <ul class="nav-links">
        <li><a href="/" class={`nav-link${currentPath === '/' ? ' active' : ''}`}>Home</a></li>
        <li><a href="/blog" class={`nav-link${currentPath.startsWith('/blog') ? ' active' : ''}`}>News</a></li>
        <li><a href="/colleges" class={`nav-link${currentPath.startsWith('/colleges') ? ' active' : ''}`}>Colleges</a></li>
        <li class="nav-item-mega">
          <a href="/courses" class={`nav-link${currentPath.startsWith('/courses') ? ' active' : ''}`}>
            Courses
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="display:inline-block;margin-left:3px;vertical-align:middle;">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="mega-menu">
            <div class="mega-inner">
              <div class="mega-categories">
                {menuCategories.map((cat, i) => (
                  <button class={`mega-cat-btn${i === 0 ? ' active' : ''}`} data-cat={cat.slug}>
                    <span class="mega-cat-icon">{cat.icon}</span>
                    <span class="mega-cat-name">{cat.name}</span>
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="mega-cat-arrow">
                      <path d="M3 2l4 3-4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                ))}
                <a href="/courses" class="mega-view-all">Explore all courses →</a>
              </div>
              <div class="mega-subcategories">
                {menuCategories.map((cat, i) => (
                  <div class={`mega-sub-panel${i === 0 ? ' active' : ''}`} data-panel={cat.slug}>
                    <p class="mega-sub-heading">{cat.icon} {cat.name}</p>
                    <div class="mega-sub-links">
                      {cat.subcategories.map(sub => (
                        <a href={`/courses/category/${cat.slug}/${sub.slug}`} class="mega-sub-link">
                          {sub.name}
                          <span class="mega-sub-count">{sub.count}</span>
                        </a>
                      ))}
                      <a href={`/courses/category/${cat.slug}`} class="mega-sub-link mega-sub-all">
                        All {cat.name} →
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </li>
        <li><a href="/categories/certificate-programs" class={`nav-link${currentPath.includes('certificate') ? ' active' : ''}`}>Certificate Programs</a></li>
        <li class="nav-item-dropdown">
          <a href="/resources" class={`nav-link${currentPath.startsWith('/resources') ? ' active' : ''}`}>
            Resources
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="display:inline-block;margin-left:3px;vertical-align:middle;">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="nav-dropdown">
            <a href="/resources/blog" class="dropdown-link">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Blog
            </a>
          </div>
        </li>
      </ul>

      <!-- CTA Button -->
      <a href="/submit-course" class="cta-nav-button">Submit a Course</a>

      <!-- Mobile Menu Button -->
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
        <svg class="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu">
      <ul class="mobile-nav-links">
        <li><a href="/" class="mobile-nav-link">Home</a></li>
        <li><a href="/blog" class="mobile-nav-link">News</a></li>
        <li><a href="/colleges" class="mobile-nav-link">Colleges</a></li>
        <li><a href="/courses" class="mobile-nav-link">Courses</a></li>
        <li><a href="/categories/certificate-programs" class="mobile-nav-link">Certificate Programs</a></li>
        <li><a href="/resources" class="mobile-nav-link">Resources</a></li>
      </ul>
      <a href="/submit-course" class="mobile-cta-button">Submit a Course</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: white;
    border-bottom: 1px solid var(--neutral-200);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 calc(var(--spacing) * 3);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: calc(var(--spacing) * 2.5) 0;
    gap: calc(var(--spacing) * 2);
  }

  /* ── Logo ── */
  .logo {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 1.5);
    text-decoration: none;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .logo svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .logo:hover svg {
    color: var(--color-primary-dark);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--neutral-900);
    line-height: 1.2;
    letter-spacing: -0.02em;
    transition: var(--transition);
  }

  .logo:hover .logo-name {
    color: var(--color-primary);
  }

  .logo-slogan {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.3em;
    line-height: 1;
    text-align: center;
    width: 100%;
  }

  /* ── Desktop Nav ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 4);
    list-style: none;
    margin: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    color: var(--neutral-700);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: var(--transition);
    padding: calc(var(--spacing) * 1) calc(var(--spacing) * 0.5);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  /* ── Dropdown ── */
  .nav-item-dropdown {
    position: relative;
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    min-width: 160px;
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    transform: translateX(-50%) translateY(-4px);
    z-index: 200;
  }

  .nav-item-dropdown:hover .nav-dropdown,
  .nav-item-dropdown:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #334155;
    text-decoration: none;
    border-radius: 7px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background: #f1f5f9;
    color: #1e40af;
  }

  /* ── CTA Button ── */
  .cta-nav-button {
    display: inline-flex;
    align-items: center;
    padding: calc(var(--spacing) * 1.75) calc(var(--spacing) * 3);
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: calc(var(--border-radius) / 2);
    text-decoration: none;
    transition: var(--transition);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cta-nav-button:hover {
    background: var(--color-primary-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);
  }

  /* ── Mobile toggle ── */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--neutral-700);
    cursor: pointer;
    padding: calc(var(--spacing) * 1);
  }

  /* ── Mobile Menu ── */
  .mobile-menu {
    display: none;
    padding: calc(var(--spacing) * 3) 0;
    border-top: 1px solid var(--neutral-200);
  }

  .mobile-menu.active {
    display: block;
  }

  .mobile-nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 0.5);
    margin-bottom: calc(var(--spacing) * 3);
  }

  .mobile-nav-link {
    display: block;
    padding: calc(var(--spacing) * 2);
    color: var(--neutral-700);
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    border-radius: calc(var(--border-radius) / 2);
    transition: var(--transition);
  }

  .mobile-nav-link:hover {
    background: var(--neutral-100);
    color: var(--color-primary);
  }

  .mobile-cta-button {
    display: block;
    text-align: center;
    padding: calc(var(--spacing) * 2.5);
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border-radius: calc(var(--border-radius) / 2);
    text-decoration: none;
    transition: var(--transition);
  }

  .mobile-cta-button:hover {
    background: var(--color-primary-dark);
    color: white;
  }

  /* ── Mega Menu ── */
  .nav-item-mega {
    position: static;
  }

  .mega-menu {
    position: fixed;
    top: var(--header-height, 65px);
    left: 0;
    right: 0;
    background: white;
    border-top: 1px solid #e2e8f0;
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 500;
  }

  .nav-item-mega:hover .mega-menu,
  .nav-item-mega:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 320px;
    max-height: 480px;
  }

  .mega-categories {
    border-right: 1px solid #f1f5f9;
    padding: 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow-y: auto;
  }

  .mega-cat-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1rem;
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    font-size: 0.9rem;
    font-weight: 500;
    color: #334155;
    transition: background 0.15s, color 0.15s;
    width: 100%;
  }

  .mega-cat-btn:hover,
  .mega-cat-btn.active {
    background: #eff6ff;
    color: #1d4ed8;
  }

  .mega-cat-icon { font-size: 1.1rem; flex-shrink: 0; }
  .mega-cat-name { flex: 1; }
  .mega-cat-arrow { opacity: 0.4; flex-shrink: 0; }
  .mega-cat-btn.active .mega-cat-arrow { opacity: 1; }

  .mega-view-all {
    margin-top: auto;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    border-top: 1px solid #f1f5f9;
  }
  .mega-view-all:hover { text-decoration: underline; }

  .mega-subcategories {
    padding: 1.25rem 1.5rem;
    overflow-y: auto;
  }

  .mega-sub-panel { display: none; }
  .mega-sub-panel.active { display: block; }

  .mega-sub-heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
    margin-bottom: 0.875rem;
  }

  .mega-sub-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.25rem;
  }

  .mega-sub-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: 7px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #334155;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .mega-sub-link:hover { background: #eff6ff; color: #1d4ed8; }

  .mega-sub-count {
    background: #f1f5f9;
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 999px;
  }

  .mega-sub-link:hover .mega-sub-count { background: #dbeafe; color: #1d4ed8; }

  .mega-sub-all {
    color: #2563eb;
    font-weight: 600;
    margin-top: 0.5rem;
    grid-column: 1 / -1;
    justify-content: flex-start;
    gap: 0.25rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .nav-links {
      gap: calc(var(--spacing) * 2.5);
    }
    .nav-link {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 768px) {
    .nav-links,
    .cta-nav-button {
      display: none;
    }
    .mobile-menu-btn {
      display: block;
    }
  }
</style>

<script>
  // Mega menu category switching
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.mega-cat-btn');
  const subPanels = document.querySelectorAll<HTMLElement>('.mega-sub-panel');

  catBtns.forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      const cat = btn.dataset.cat;
      catBtns.forEach(b => b.classList.remove('active'));
      subPanels.forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.querySelector<HTMLElement>(`.mega-sub-panel[data-panel="${cat}"]`)?.classList.add('active');
    });
  });

  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  const menuIcon = mobileMenuBtn?.querySelector('.menu-icon') as SVGElement;
  const closeIcon = mobileMenuBtn?.querySelector('.close-icon') as SVGElement;

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('active');
    if (mobileMenu?.classList.contains('active')) {
      menuIcon.style.display = 'none';
      closeIcon.style.display = 'block';
    } else {
      menuIcon.style.display = 'block';
      closeIcon.style.display = 'none';
    }
  });
</script>
