---
---

<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&display=swap" rel="stylesheet" />

<section class="hero">

  <!-- Chalkboard decorative writings -->
  <div class="chalk-layer" aria-hidden="true">

    <!-- Physics equations -->
    <span class="chalk" style="top:8%;left:3%;font-size:1.4rem;opacity:0.18;transform:rotate(-6deg)">E = mc²</span>
    <span class="chalk" style="top:22%;left:1%;font-size:1.1rem;opacity:0.13;transform:rotate(3deg)">F = ma</span>
    <span class="chalk" style="top:55%;left:2%;font-size:1.25rem;opacity:0.16;transform:rotate(-4deg)">PV = nRT</span>
    <span class="chalk" style="top:72%;left:4%;font-size:1.0rem;opacity:0.12;transform:rotate(5deg)">v = u + at</span>
    <span class="chalk" style="top:38%;left:0.5%;font-size:1.3rem;opacity:0.14;transform:rotate(-2deg)">ΔE = hf</span>
    <span class="chalk" style="top:85%;left:3%;font-size:1.15rem;opacity:0.13;transform:rotate(4deg)">p = mv</span>

    <span class="chalk" style="top:10%;right:4%;font-size:1.35rem;opacity:0.17;transform:rotate(5deg)">F = GMm/r²</span>
    <span class="chalk" style="top:28%;right:2%;font-size:1.1rem;opacity:0.13;transform:rotate(-3deg)">λ = h/mv</span>
    <span class="chalk" style="top:50%;right:3%;font-size:1.2rem;opacity:0.15;transform:rotate(6deg)">∇·E = ρ/ε₀</span>
    <span class="chalk" style="top:68%;right:1.5%;font-size:1.0rem;opacity:0.12;transform:rotate(-5deg)">W = F·d</span>
    <span class="chalk" style="top:82%;right:4%;font-size:1.25rem;opacity:0.14;transform:rotate(3deg)">KE = ½mv²</span>

    <!-- Math equations -->
    <span class="chalk" style="top:15%;left:8%;font-size:1.3rem;opacity:0.14;transform:rotate(4deg)">a² + b² = c²</span>
    <span class="chalk" style="top:62%;left:7%;font-size:1.2rem;opacity:0.13;transform:rotate(-5deg)">∫f(x)dx</span>
    <span class="chalk" style="top:42%;left:9%;font-size:1.4rem;opacity:0.12;transform:rotate(2deg)">π ≈ 3.14159</span>
    <span class="chalk" style="top:78%;left:6%;font-size:1.15rem;opacity:0.15;transform:rotate(-3deg)">lim(x→∞)</span>
    <span class="chalk" style="top:30%;left:10%;font-size:1.1rem;opacity:0.11;transform:rotate(6deg)">d/dx(xⁿ) = nxⁿ⁻¹</span>
    <span class="chalk" style="top:90%;left:8%;font-size:1.2rem;opacity:0.13;transform:rotate(-2deg)">∑ₙ₌₁∞ 1/n²</span>

    <span class="chalk" style="top:18%;right:9%;font-size:1.3rem;opacity:0.14;transform:rotate(-4deg)">y = mx + b</span>
    <span class="chalk" style="top:45%;right:8%;font-size:1.15rem;opacity:0.13;transform:rotate(5deg)">√x² + y²</span>
    <span class="chalk" style="top:60%;right:7%;font-size:1.2rem;opacity:0.12;transform:rotate(-6deg)">∂f/∂x</span>
    <span class="chalk" style="top:75%;right:9%;font-size:1.1rem;opacity:0.14;transform:rotate(3deg)">e^(iπ) + 1 = 0</span>
    <span class="chalk" style="top:88%;right:6%;font-size:1.25rem;opacity:0.13;transform:rotate(-3deg)">∇²ψ = 0</span>

    <!-- English literary / academic sentences -->
    <span class="chalk chalk-italic" style="top:5%;left:18%;font-size:1.05rem;opacity:0.11;transform:rotate(-2deg)">"To be, or not to be — that is the question."</span>
    <span class="chalk chalk-italic" style="top:93%;left:20%;font-size:1.0rem;opacity:0.10;transform:rotate(2deg)">"Knowledge is the wing wherewith we fly to heaven."</span>
    <span class="chalk chalk-italic" style="top:48%;left:16%;font-size:1.0rem;opacity:0.10;transform:rotate(-3deg)">"The more that you read, the more things you will know."</span>
    <span class="chalk chalk-italic" style="top:35%;right:15%;font-size:1.05rem;opacity:0.10;transform:rotate(4deg)">"An investment in knowledge pays the best interest."</span>
    <span class="chalk chalk-italic" style="top:80%;right:14%;font-size:1.0rem;opacity:0.11;transform:rotate(-2deg)">"Education is not the filling of a pail, but the lighting of a fire."</span>

    <!-- Small decorative chalk marks -->
    <span class="chalk" style="top:25%;left:5%;font-size:2rem;opacity:0.08;transform:rotate(10deg)">✕</span>
    <span class="chalk" style="top:65%;right:5%;font-size:2rem;opacity:0.08;transform:rotate(-10deg)">○</span>
    <span class="chalk" style="top:50%;left:14%;font-size:1.6rem;opacity:0.09;transform:rotate(5deg)">△</span>
    <span class="chalk" style="top:20%;right:13%;font-size:1.8rem;opacity:0.08;transform:rotate(-8deg)">◻</span>

    <!-- Faint underlines / chalk marks -->
    <svg class="chalk-line" style="top:14%;left:6%;width:80px;opacity:0.10;transform:rotate(-3deg)" viewBox="0 0 80 8" fill="none"><path d="M0 4 Q20 1 40 5 Q60 8 80 3" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
    <svg class="chalk-line" style="top:72%;right:6%;width:70px;opacity:0.09;transform:rotate(4deg)" viewBox="0 0 70 8" fill="none"><path d="M0 4 Q18 2 35 5 Q52 7 70 3" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
    <svg class="chalk-line" style="top:38%;left:7%;width:60px;opacity:0.10;transform:rotate(2deg)" viewBox="0 0 60 8" fill="none"><path d="M0 4 Q15 2 30 5 Q45 7 60 3" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>

  </div>

  <!-- Hero Content -->
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">Find Your Program</div>
      <h1>Discover Accredited<br/>Online College Courses</h1>
      <p class="hero-sub">Search thousands of online degrees, certificates, and courses from top accredited institutions. Built for working adults, transfer students, and lifelong learners.</p>
      <div class="hero-cta">
        <a href="#coursesGrid" class="btn-primary">Browse Courses</a>
        <a href="/submit-course" class="btn-outline">Submit a Course</a>
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 55%, #0284c7 100%);
    overflow: hidden;
    padding: 5rem 0 4.5rem;
    min-height: 420px;
    display: flex;
    align-items: center;
  }

  /* ── Chalk layer ── */
  .chalk-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .chalk {
    position: absolute;
    font-family: 'Caveat', cursive;
    color: #ffffff;
    line-height: 1.2;
    white-space: nowrap;
  }

  .chalk-italic {
    font-style: italic;
    font-size: 0.95rem !important;
    white-space: normal;
    max-width: 320px;
  }

  .chalk-line {
    position: absolute;
  }

  /* ── Container ── */
  .container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
  }

  /* ── Hero Content ── */
  .hero-content {
    max-width: 680px;
    text-align: center;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.375rem 1rem;
    border-radius: 20px;
    margin-bottom: 1.375rem;
  }

  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.035em;
    line-height: 1.15;
    margin-bottom: 1.125rem;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.875rem 2rem;
    background: white;
    color: #1e40af;
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    color: #1e3a8a;
  }

  .btn-outline {
    padding: 0.875rem 2rem;
    background: transparent;
    color: rgba(255,255,255,0.92);
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 8px;
    border: 1.5px solid rgba(255,255,255,0.45);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.7);
    color: white;
  }

  @media (max-width: 768px) {
    .hero { padding: 3.5rem 0 3rem; }
    .chalk { display: none; }
    .chalk-italic { display: none; }
    .chalk-line { display: none; }
  }
</style>
